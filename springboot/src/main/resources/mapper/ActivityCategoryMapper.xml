<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ActivityCategoryMapper">

    <!-- 字段映射 -->
    <resultMap id="activityCategoryMap" type="com.example.entity.ActivityCategory">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="icon" column="icon"/>
        <result property="color" column="color"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createdBy" column="created_by"/>
    </resultMap>

    <!-- 通用查询字段 -->
    <sql id="Base_Column_List">
        id, name, description, icon, color, sort_order, status, create_time, update_time, created_by
    </sql>

    <!-- 插入活动分类 -->
    <insert id="insert" parameterType="com.example.entity.ActivityCategory">
        insert into activity_category (name, description, icon, color, sort_order, status, created_by)
        values (#{name}, #{description}, #{icon}, #{color}, #{sortOrder}, #{status}, #{createdBy})
    </insert>

    <!-- 根据ID删除活动分类 -->
    <delete id="deleteById" parameterType="java.lang.Integer">
        delete from activity_category where id = #{id}
    </delete>

    <!-- 批量删除活动分类 -->
    <delete id="deleteBatch" parameterType="java.util.List">
        delete from activity_category where id in
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 更新活动分类 -->
    <update id="updateById" parameterType="com.example.entity.ActivityCategory">
        update activity_category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="description != null">description = #{description},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="color != null">color = #{color},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <!-- 根据ID查询活动分类 -->
    <select id="selectById" resultMap="activityCategoryMap">
        select <include refid="Base_Column_List"/>
        from activity_category
        where id = #{id}
    </select>

    <!-- 查询所有活动分类 -->
    <select id="selectAll" resultMap="activityCategoryMap">
        select <include refid="Base_Column_List"/>
        from activity_category
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_order
    </select>

    <!-- 分页查询活动分类 -->
    <select id="selectPage" resultMap="activityCategoryMap">
        select <include refid="Base_Column_List"/>
        from activity_category
        <where>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by sort_order
    </select>
</mapper> 