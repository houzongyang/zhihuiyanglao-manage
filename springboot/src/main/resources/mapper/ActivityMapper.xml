<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ActivityMapper">

    <sql id="Base_Column_List">
        id,category_id,title,description,activity_date,start_time,end_time,location,
        max_participants,current_participants,organizer,organizer_phone,requirements,
        materials_needed,cost,status,registration_deadline,notes,image_url,cover_image,
        create_time,update_time,created_by
    </sql>

    <select id="selectAll" resultType="com.example.entity.Activity">
        select
        <include refid="Base_Column_List" />
        from activity
        <where>
            <if test="id != null"> and id = #{id}</if>
            <if test="categoryId != null"> and category_id = #{categoryId}</if>
            <if test="title != null"> and title like concat('%', #{title}, '%')</if>
            <if test="description != null"> and description like concat('%', #{description}, '%')</if>
            <if test="activityDate != null"> and activity_date = #{activityDate}</if>
            <if test="startTime != null"> and start_time = #{startTime}</if>
            <if test="endTime != null"> and end_time = #{endTime}</if>
            <if test="location != null"> and location like concat('%', #{location}, '%')</if>
            <if test="maxParticipants != null"> and max_participants = #{maxParticipants}</if>
            <if test="currentParticipants != null"> and current_participants = #{currentParticipants}</if>
            <if test="organizer != null"> and organizer like concat('%', #{organizer}, '%')</if>
            <if test="organizerPhone != null"> and organizer_phone = #{organizerPhone}</if>
            <if test="requirements != null"> and requirements like concat('%', #{requirements}, '%')</if>
            <if test="materialsNeeded != null"> and materials_needed like concat('%', #{materialsNeeded}, '%')</if>
            <if test="cost != null"> and cost = #{cost}</if>
            <if test="status != null"> and status = #{status}</if>
            <if test="registrationDeadline != null"> and registration_deadline = #{registrationDeadline}</if>
            <if test="notes != null"> and notes like concat('%', #{notes}, '%')</if>
            <if test="imageUrl != null"> and image_url = #{imageUrl}</if>
            <if test="coverImage != null"> and cover_image = #{coverImage}</if>
            <if test="createTime != null"> and create_time = #{createTime}</if>
            <if test="updateTime != null"> and update_time = #{updateTime}</if>
            <if test="createdBy != null"> and created_by = #{createdBy}</if>
        </where>
        order by activity_date desc, start_time asc
    </select>

    <select id="selectById" resultType="com.example.entity.Activity">
        select
        <include refid="Base_Column_List" />
        from activity
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from activity
        where id = #{id}
    </delete>

