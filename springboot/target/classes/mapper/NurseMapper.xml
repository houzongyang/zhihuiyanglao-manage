            </if>
            <if test="position != null">
                position = #{position},
            </if>
            <if test="workYears != null">
                work_years = #{workYears},
            </if>
            <if test="specialty != null">
                specialty = #{specialty},
            </if>
            <if test="workSchedule != null">
