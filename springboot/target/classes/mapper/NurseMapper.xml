<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.NurseMapper">

    <sql id="Base_Column_List">
        id,username,password,name,phone,email,avatar,role,department,position,work_years,specialty,work_schedule,status,introduction,create_time
    </sql>

    <select id="selectAll" resultType="com.example.entity.Nurse">
        select *
        from nurse
        <where>
            <if test="id != null"> and id= #{id}</if>
            <if test="username != null"> and username like concat('%', #{username}, '%')</if>
            <if test="password != null"> and password= #{password}</if>
            <if test="name != null"> and name like concat('%', #{name}, '%')</if>
            <if test="phone != null"> and phone= #{phone}</if>
            <if test="email != null"> and email= #{email}</if>
            <if test="avatar != null"> and avatar= #{avatar}</if>
            <if test="role != null"> and role= #{role}</if>
            <if test="department != null"> and department like concat('%', #{department}, '%')</if>
            <if test="position != null"> and position like concat('%', #{position}, '%')</if>
            <if test="workYears != null"> and work_years= #{workYears}</if>
            <if test="specialty != null"> and specialty like concat('%', #{specialty}, '%')</if>
            <if test="workSchedule != null"> and work_schedule= #{workSchedule}</if>
            <if test="status != null"> and status= #{status}</if>
            <if test="introduction != null"> and introduction like concat('%', #{introduction}, '%')</if>
        </where>
        order by id desc
    </select>

    <select id="selectById" resultType="com.example.entity.Nurse">
        select
        <include refid="Base_Column_List" />
        from nurse
        where id = #{id}
    </select>

    <delete id="deleteById">
        delete from nurse
        where id = #{id}
    </delete>

    <insert id="insert" parameterType="com.example.entity.Nurse" useGeneratedKeys="true">
        insert into nurse
        <trim prefix="(" suffix=")" suffixOverrides=",">
                <if test="id != null">id,</if>
