 {\r\n  background-color: #1a2d3f !important;\r\n  border-right: 3px solid #1890ff;\r\n}\r\n\r\n.el-menu-item.is-active i {\r\n  color: #1890ff;\r\n}\r\n\r\n/* 内容区样式 */\r\n.layout-content {\r\n  flex: 1;\r\n  overflow: auto;\r\n  padding: 20px;\r\n  transition: margin-left 0.3s;\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.content-expanded {\r\n  margin-left: -156px;\r\n}\r\n\r\n.breadcrumb {\r\n  margin-bottom: 20px;\r\n  padding: 10px;\r\n  background-color: #fff;\r\n  border-radius: 4px;\r\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\r\n}\r\n\r\n.content-container {\r\n  background-color: #fff;\r\n  border-radius: 4px;\r\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\r\n  min-height: calc(100vh - 180px);\r\n}\r\n</style> "],"mappings":";AAkHA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;MACAC,MAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACAC,WAAA;MACA,YAAAC,MAAA,CAAAC,IAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,KAAAC,eAAA;;IAEA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAC,eAAA;MACA,KAAAX,UAAA,SAAAA,UAAA;IACA;IACAY,cAAAC,OAAA;MACA,IAAAA,OAAA;QACA,KAAAC,OAAA,CAAAC,IAAA;MACA,WAAAF,OAAA;QACAG,YAAA,CAAAC,UAAA;QACA,KAAAH,OAAA,CAAAC,IAAA;MACA;IACA;IACAP,gBAAA;MACA,MAAAU,IAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAJ,YAAA,CAAAK,OAAA;MACA,KAAAH,IAAA,CAAAI,KAAA;QACA,KAAAR,OAAA,CAAAC,IAAA;QACA;MACA;MAEA,IAAAG,IAAA,CAAAK,IAAA;QACA,KAAAC,QAAA,CAAAC,KAAA;QACA,KAAAX,OAAA,CAAAC,IAAA;MACA;IACA;IACAN,YAAA;MACA;MACA,MAAAS,IAAA,GAAAC,IAAA,CAAAC,KAAA,CAAAJ,YAAA,CAAAK,OAAA;MACA,IAAAH,IAAA,CAAApB,IAAA;QACA,KAAAI,QAAA,GAAAgB,IAAA,CAAApB,IAAA;MACA;MACA,IAAAoB,IAAA,CAAAjB,MAAA;QACA,KAAAA,MAAA,GAAAiB,IAAA,CAAAjB,MAAA;MACA;IACA;EACA;AACA","ignoreList":[]}]}