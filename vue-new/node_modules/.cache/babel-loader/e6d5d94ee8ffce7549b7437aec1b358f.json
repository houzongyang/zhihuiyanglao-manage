{"remainingRequest":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\babel-loader\\lib\\index.js!D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\src\\views\\manager\\Home.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\src\\views\\manager\\Home.vue","mtime":1753499666072},{"path":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\babel.config.js","mtime":1753409336095},{"path":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\babel-loader\\lib\\index.js","mtime":1753409923129},{"path":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\模版\\新版本vue模版，样式好看\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["echarts","name","data","currentDate","formatDate","Date","notices","recentBooks","colors","isLoading","statistics","textbookCount","userCount","applicationCount","categoryCount","applicationStatistics","pieChartInstance","mounted","loadData","window","addEventListener","resizePieChart","beforeDestroy","dispose","removeEventListener","methods","Promise","all","loadStatistics","loadRecentNotices","loadRecentTextbooks","loadApplicationStatistics","error","console","$message","resize","_textbookRes$data","_userRes$data","_applicationRes$data","_categoryRes$data","textbookRes","userRes","applicationRes","categoryRes","$request","get","params","pageNum","pageSize","list","length","res","code","_res$data","map","notice","title","time","createTime","msg","_res$data2","slice","book","textbookName","author","publisher","publishDate","appRes","_appRes$data","_textbookRes$data2","_categoryRes$data2","applications","textbooks","categories","textbookToCategoryMap","forEach","id","categoryId","categoryMap","category","categoryName","value","Object","keys","app","textbookId","values","filter","item","log","$nextTick","initPieChart","date","short","year","getFullYear","month","getMonth","day","getDate","weekDays","weekDay","getDay","toString","padStart","getRandomColor","index","$refs","pieChart","init","chartData","itemStyle","color","option","tooltip","trigger","formatter","legend","orient","left","series","type","radius","center","emphasis","shadowBlur","shadowOffsetX","shadowColor","label","show","setOption"],"sources":["src/views/manager/Home.vue"],"sourcesContent":["<template>\n  <div class=\"p-6\">\n    <!-- 顶部操作栏：添加刷新按钮 -->\n    <div class=\"flex justify-end mb-4\">\n      <el-button type=\"primary\" icon=\"el-icon-refresh\" size=\"small\" @click=\"loadData\" :loading=\"isLoading\">\n        刷新数据\n      </el-button>\n    </div>\n    \n    <!-- 欢迎区域 -->\n    <div class=\"bg-gradient-to-r from-blue-500 to-indigo-600 rounded-xl p-6 mb-6 shadow-lg flex flex-wrap text-white relative overflow-hidden\">\n      <div class=\"relative z-10 w-full md:w-2/3\">\n        <h1 class=\"text-2xl font-bold mb-2\">欢迎使用高校教材管理系统</h1>\n        <p class=\"text-white text-opacity-90 mb-6\">今天是 {{ currentDate }}，祝您工作愉快！</p>\n        <div class=\"flex space-x-4\">\n          <button @click=\"$router.push('/manager/textbook-application')\" \n                  class=\"flex items-center px-4 py-2 bg-white bg-opacity-20 hover:bg-opacity-30 rounded-full transition-all shadow-md\">\n            <i class=\"el-icon-document-checked mr-2\"></i> 教材申报\n          </button>\n          <button @click=\"$router.push('/manager/textbook')\" \n                  class=\"flex items-center px-4 py-2 bg-white bg-opacity-20 hover:bg-opacity-30 rounded-full transition-all shadow-md\">\n            <i class=\"el-icon-notebook-2 mr-2\"></i> 教材管理\n          </button>\n        </div>\n      </div>\n      <div class=\"hidden md:flex md:w-1/3 items-center justify-center\">\n        <img src=\"/img/admin-welcome.svg\" alt=\"Welcome\" class=\"max-h-40 filter drop-shadow-lg\">\n      </div>\n      \n      <!-- 装饰圆圈 -->\n      <div class=\"absolute top-0 right-0 rounded-full bg-white bg-opacity-10 w-60 h-60 -mt-20 -mr-20\"></div>\n      <div class=\"absolute bottom-0 left-0 rounded-full bg-white bg-opacity-10 w-80 h-80 -mb-40 -ml-40\"></div>\n    </div>\n    \n    <!-- 数据统计卡片区域 -->\n    <el-row :gutter=\"20\" class=\"mb-6\">\n      <el-col :xs=\"12\" :sm=\"12\" :md=\"6\" :lg=\"6\" :xl=\"6\" class=\"mb-4 md:mb-0\">\n        <div class=\"bg-gradient-to-r from-blue-400 to-blue-500 rounded-xl p-5 shadow-md h-full text-white relative overflow-hidden\">\n          <div class=\"flex items-center mb-3\">\n            <div class=\"p-2 bg-white bg-opacity-20 rounded-lg\">\n              <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                <path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"></path>\n                <polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"></polyline>\n                <line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"></line>\n              </svg>\n            </div>\n            <div class=\"ml-3\">\n              <div class=\"text-2xl font-bold\">{{ statistics.textbookCount }}</div>\n              <div class=\"text-sm opacity-80\">教材总数</div>\n            </div>\n          </div>\n          <div class=\"absolute bottom-0 left-0 w-full opacity-30\">\n            <svg viewBox=\"0 0 100 30\" preserveAspectRatio=\"none\" class=\"w-full h-8\">\n              <path d=\"M0,15 Q20,5 40,15 T80,15 T100,15\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\" fill=\"none\" />\n            </svg>\n          </div>\n        </div>\n      </el-col>\n      <el-col :xs=\"12\" :sm=\"12\" :md=\"6\" :lg=\"6\" :xl=\"6\" class=\"mb-4 md:mb-0\">\n        <div class=\"bg-gradient-to-r from-green-400 to-green-500 rounded-xl p-5 shadow-md h-full text-white relative overflow-hidden\">\n          <div class=\"flex items-center mb-3\">\n            <div class=\"p-2 bg-white bg-opacity-20 rounded-lg\">\n              <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                <path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path>\n                <circle cx=\"9\" cy=\"7\" r=\"4\"></circle>\n                <path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path>\n                <path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path>\n              </svg>\n            </div>\n            <div class=\"ml-3\">\n              <div class=\"text-2xl font-bold\">{{ statistics.userCount }}</div>\n              <div class=\"text-sm opacity-80\">用户总数</div>\n            </div>\n          </div>\n          <div class=\"absolute bottom-0 left-0 w-full opacity-30\">\n            <svg viewBox=\"0 0 100 30\" preserveAspectRatio=\"none\" class=\"w-full h-8\">\n              <path d=\"M0,20 Q30,5 50,15 T100,10\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\" fill=\"none\" />\n            </svg>\n          </div>\n        </div>\n      </el-col>\n      <el-col :xs=\"12\" :sm=\"12\" :md=\"6\" :lg=\"6\" :xl=\"6\" class=\"mb-4 md:mb-0\">\n        <div class=\"bg-gradient-to-r from-yellow-400 to-orange-500 rounded-xl p-5 shadow-md h-full text-white relative overflow-hidden\">\n          <div class=\"flex items-center mb-3\">\n            <div class=\"p-2 bg-white bg-opacity-20 rounded-lg\">\n              <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                <path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"></path>\n                <polyline points=\"14 2 14 8 20 8\"></polyline>\n                <line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"></line>\n                <line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"></line>\n                <polyline points=\"10 9 9 9 8 9\"></polyline>\n              </svg>\n            </div>\n            <div class=\"ml-3\">\n              <div class=\"text-2xl font-bold\">{{ statistics.applicationCount }}</div>\n              <div class=\"text-sm opacity-80\">申报数量</div>\n            </div>\n          </div>\n          <div class=\"absolute bottom-0 left-0 w-full opacity-30\">\n            <svg viewBox=\"0 0 100 30\" preserveAspectRatio=\"none\" class=\"w-full h-8\">\n              <path d=\"M0,10 Q25,20 50,10 T100,15\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\" fill=\"none\" />\n            </svg>\n          </div>\n        </div>\n      </el-col>\n      <el-col :xs=\"12\" :sm=\"12\" :md=\"6\" :lg=\"6\" :xl=\"6\" class=\"mb-4 md:mb-0\">\n        <div class=\"bg-gradient-to-r from-red-400 to-red-500 rounded-xl p-5 shadow-md h-full text-white relative overflow-hidden\">\n          <div class=\"flex items-center mb-3\">\n            <div class=\"p-2 bg-white bg-opacity-20 rounded-lg\">\n              <svg viewBox=\"0 0 24 24\" width=\"22\" height=\"22\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n                <path d=\"M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9\"></path>\n                <path d=\"M13.73 21a2 2 0 0 1-3.46 0\"></path>\n              </svg>\n            </div>\n            <div class=\"ml-3\">\n              <div class=\"text-2xl font-bold\">{{ statistics.categoryCount }}</div>\n              <div class=\"text-sm opacity-80\">教材分类</div>\n            </div>\n          </div>\n          <div class=\"absolute bottom-0 left-0 w-full opacity-30\">\n            <svg viewBox=\"0 0 100 30\" preserveAspectRatio=\"none\" class=\"w-full h-8\">\n              <path d=\"M0,15 Q35,5 50,15 T100,5\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\" fill=\"none\" />\n            </svg>\n          </div>\n        </div>\n      </el-col>\n    </el-row>\n    \n    <!-- 图表和通知区域 -->\n    <el-row :gutter=\"20\" class=\"mb-6\">\n      <el-col :span=\"12\" class=\"mb-4 md:mb-0\">\n        <!-- 饼图区域 -->\n        <div class=\"bg-white rounded-xl shadow-md overflow-hidden h-full\">\n          <div class=\"flex justify-between items-center px-5 py-4 border-b border-gray-100\">\n            <div class=\"flex items-center\">\n              <i class=\"el-icon-pie-chart text-purple-500 text-xl mr-2\"></i>\n              <span class=\"font-semibold text-gray-800\">申报分类统计</span>\n            </div>\n          </div>\n          <div class=\"p-5\">\n            <div ref=\"pieChart\" class=\"w-full h-80\"></div>\n          </div>\n        </div>\n      </el-col>\n      <el-col :span=\"12\">\n        <div class=\"bg-white rounded-xl shadow-md overflow-hidden h-full\">\n          <div class=\"flex justify-between items-center px-5 py-4 border-b border-gray-100\">\n            <div class=\"flex items-center\">\n              <i class=\"el-icon-bell text-orange-500 text-xl mr-2\"></i>\n              <span class=\"font-semibold text-gray-800\">最新通知</span>\n            </div>\n            <button @click=\"$router.push('/manager/notice')\" class=\"text-blue-500 hover:text-blue-600 text-sm font-medium\">\n              查看更多\n            </button>\n          </div>\n          <div class=\"px-5 py-3 max-h-80 overflow-y-auto\">\n            <div v-for=\"(item, index) in notices\" :key=\"index\" class=\"py-3 border-b border-gray-100 last:border-0\">\n              <div class=\"flex\">\n                <span class=\"flex-shrink-0 w-2 h-2 rounded-full mt-2\" :class=\"index < 2 ? 'bg-red-500' : 'bg-gray-300'\"></span>\n                <div class=\"ml-3\">\n                  <p class=\"text-gray-800 mb-1 text-sm\">{{ item.title }}</p>\n                  <p class=\"text-gray-400 text-xs\">{{ item.time }}</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </el-col>\n    </el-row>\n    \n    <!-- 最近教材和快捷入口 -->\n    <el-row :gutter=\"20\">\n      <el-col :span=\"16\" class=\"mb-4 md:mb-0\">\n        <div class=\"bg-white rounded-xl shadow-md overflow-hidden\">\n          <div class=\"flex justify-between items-center px-5 py-4 border-b border-gray-100\">\n            <div class=\"flex items-center\">\n              <i class=\"el-icon-collection text-blue-500 text-xl mr-2\"></i>\n              <span class=\"font-semibold text-gray-800\">最近教材</span>\n            </div>\n            <button @click=\"$router.push('/manager/textbook')\" class=\"text-blue-500 hover:text-blue-600 text-sm font-medium\">\n              查看全部\n            </button>\n          </div>\n          <div class=\"p-0\">\n            <el-table :data=\"recentBooks\" style=\"width: 100%\" :stripe=\"true\" :border=\"false\"\n                      :header-cell-style=\"{ background: '#f8fafc', color: '#475569', fontWeight: 'bold' }\">\n              <el-table-column width=\"60\">\n                <template slot-scope=\"scope\">\n                  <el-avatar size=\"small\" :style=\"{ backgroundColor: getRandomColor(scope.$index) }\">\n                    {{ scope.row.name.substring(0, 1) }}\n                  </el-avatar>\n                </template>\n              </el-table-column>\n              <el-table-column prop=\"name\" label=\"教材名称\" min-width=\"180\"></el-table-column>\n              <el-table-column prop=\"author\" label=\"作者\" width=\"120\"></el-table-column>\n              <el-table-column prop=\"publisher\" label=\"出版社\" min-width=\"140\"></el-table-column>\n              <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"120\"></el-table-column>\n            </el-table>\n          </div>\n        </div>\n      </el-col>\n      <el-col :span=\"8\">\n        <div class=\"bg-white rounded-xl shadow-md overflow-hidden\">\n          <div class=\"flex items-center px-5 py-4 border-b border-gray-100\">\n            <i class=\"el-icon-menu text-green-500 text-xl mr-2\"></i>\n            <span class=\"font-semibold text-gray-800\">快捷入口</span>\n          </div>\n          <div class=\"p-5\">\n            <div class=\"grid grid-cols-2 gap-4\">\n              <div @click=\"$router.push('/manager/textbook-category')\" \n                   class=\"flex flex-col items-center justify-center bg-blue-50 hover:bg-blue-100 rounded-xl p-4 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md\">\n                <div class=\"w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center text-white mb-2\">\n                  <i class=\"el-icon-collection-tag\"></i>\n                </div>\n                <span class=\"text-sm text-gray-700\">教材分类</span>\n              </div>\n              <div @click=\"$router.push('/manager/textbook')\" \n                   class=\"flex flex-col items-center justify-center bg-green-50 hover:bg-green-100 rounded-xl p-4 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md\">\n                <div class=\"w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center text-white mb-2\">\n                  <i class=\"el-icon-notebook-2\"></i>\n                </div>\n                <span class=\"text-sm text-gray-700\">教材管理</span>\n              </div>\n              <div @click=\"$router.push('/manager/textbook-application')\" \n                   class=\"flex flex-col items-center justify-center bg-orange-50 hover:bg-orange-100 rounded-xl p-4 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md\">\n                <div class=\"w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center text-white mb-2\">\n                  <i class=\"el-icon-document-checked\"></i>\n                </div>\n                <span class=\"text-sm text-gray-700\">申报管理</span>\n              </div>\n              <div @click=\"$router.push('/manager/user')\" \n                   class=\"flex flex-col items-center justify-center bg-red-50 hover:bg-red-100 rounded-xl p-4 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md\">\n                <div class=\"w-10 h-10 bg-red-500 rounded-lg flex items-center justify-center text-white mb-2\">\n                  <i class=\"el-icon-user\"></i>\n                </div>\n                <span class=\"text-sm text-gray-700\">用户管理</span>\n              </div>\n              <div @click=\"$router.push('/manager/teacher')\" \n                   class=\"flex flex-col items-center justify-center bg-purple-50 hover:bg-purple-100 rounded-xl p-4 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md\">\n                <div class=\"w-10 h-10 bg-purple-500 rounded-lg flex items-center justify-center text-white mb-2\">\n                  <i class=\"el-icon-s-custom\"></i>\n                </div>\n                <span class=\"text-sm text-gray-700\">教师管理</span>\n              </div>\n              <div @click=\"$router.push('/manager/notice')\" \n                   class=\"flex flex-col items-center justify-center bg-gray-50 hover:bg-gray-100 rounded-xl p-4 cursor-pointer transition-all hover:-translate-y-1 hover:shadow-md\">\n                <div class=\"w-10 h-10 bg-gray-500 rounded-lg flex items-center justify-center text-white mb-2\">\n                  <i class=\"el-icon-bell\"></i>\n                </div>\n                <span class=\"text-sm text-gray-700\">公告管理</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </el-col>\n    </el-row>\n  </div>\n</template>\n<script>\n// 引入echarts\nimport * as echarts from 'echarts'\n\nexport default {\n  name: \"ManagerHome\",\n  data() {\n    return {\n      currentDate: this.formatDate(new Date()),\n      notices: [],\n      recentBooks: [],\n      colors: ['#409EFF', '#67C23A', '#E6A23C', '#F56C6C', '#909399'],\n      isLoading: false, // 添加加载状态\n      // 统计数据\n      statistics: {\n        textbookCount: 0,\n        userCount: 0,\n        applicationCount: 0,\n        categoryCount: 0\n      },\n      // 申报统计数据（用于饼图）\n      applicationStatistics: [],\n      pieChartInstance: null\n    };\n  },\n  mounted() {\n    this.loadData();\n    \n    // 添加窗口大小变化时重新渲染饼图\n    window.addEventListener('resize', this.resizePieChart);\n  },\n  beforeDestroy() {\n    // 销毁饼图实例\n    if (this.pieChartInstance) {\n      this.pieChartInstance.dispose();\n      this.pieChartInstance = null;\n    }\n    \n    // 移除事件监听\n    window.removeEventListener('resize', this.resizePieChart);\n  },\n\n  methods: {\n    // 加载所有数据\n    async loadData() {\n      try {\n        this.isLoading = true;\n        await Promise.all([\n          this.loadStatistics(),\n          this.loadRecentNotices(),\n          this.loadRecentTextbooks(),\n          this.loadApplicationStatistics()\n        ]);\n      } catch (error) {\n        console.error('加载数据失败:', error);\n        this.$message.error('加载数据失败，请稍后重试');\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    \n    // 饼图自适应大小\n    resizePieChart() {\n      if (this.pieChartInstance) {\n        this.pieChartInstance.resize();\n      }\n    },\n    \n    // 加载统计数据\n    async loadStatistics() {\n      try {\n        const [textbookRes, userRes, applicationRes, categoryRes] = await Promise.all([\n          this.$request.get('/textbook/selectPage', { params: { pageNum: 1, pageSize: 9999 } }),\n          this.$request.get('/user/selectPage', { params: { pageNum: 1, pageSize: 9999 } }),\n          this.$request.get('/textbookApplication/selectPage', { params: { pageNum: 1, pageSize: 9999 } }),\n          this.$request.get('/textbookCategory/selectPage', { params: { pageNum: 1, pageSize: 9999 } })\n        ]);\n\n        this.statistics = {\n          textbookCount: textbookRes.data?.list?.length || 0,\n          userCount: userRes.data?.list?.length || 0,\n          applicationCount: applicationRes.data?.list?.length || 0,\n          categoryCount: categoryRes.data?.list?.length || 0\n        };\n      } catch (error) {\n        console.error('加载统计数据失败:', error);\n        this.$message.error('加载统计数据失败');\n      }\n    },\n    \n    // 加载最新通知\n    async loadRecentNotices() {\n      try {\n        const res = await this.$request.get('/notice/selectPage', { \n          params: { pageNum: 1, pageSize: 4 } \n        });\n        if (res.code === '200') {\n          this.notices = (res.data?.list || []).map(notice => ({\n            title: notice.title,\n            time: this.formatDate(notice.createTime, true)\n          }));\n        } else {\n          console.error('加载最新通知失败:', res.msg);\n        }\n      } catch (error) {\n        console.error('加载最新通知请求异常:', error);\n      }\n    },\n    \n    // 加载最近教材\n    async loadRecentTextbooks() {\n      try {\n        const res = await this.$request.get('/textbook/selectPage', { \n          params: { pageNum: 1, pageSize: 4 } \n        });\n        if (res.code === '200') {\n          this.recentBooks = (res.data?.list || []).slice(0, 4).map(book => ({\n            ...book,\n            name: book.textbookName || book.name,\n            author: book.author,\n            publisher: book.publisher,\n            createTime: this.formatDate(book.createTime || book.publishDate, true)\n          }));\n        } else {\n          console.error('加载最近教材失败:', res.msg);\n        }\n      } catch (error) {\n        console.error('加载最近教材请求异常:', error);\n      }\n    },\n    \n    // 加载申报统计数据\n    async loadApplicationStatistics() {\n      try {\n        // 1. 获取所有申报记录\n        const appRes = await this.$request.get('/textbookApplication/selectPage', { \n          params: { pageNum: 1, pageSize: 9999 } \n        });\n        \n        // 2. 获取所有教材信息\n        const textbookRes = await this.$request.get('/textbook/selectPage', { \n          params: { pageNum: 1, pageSize: 9999 } \n        });\n        \n        // 3. 获取所有教材分类\n        const categoryRes = await this.$request.get('/textbookCategory/selectPage', { \n          params: { pageNum: 1, pageSize: 9999 } \n        });\n        \n        if (appRes.code === '200' && textbookRes.code === '200' && categoryRes.code === '200') {\n          const applications = appRes.data?.list || [];\n          const textbooks = textbookRes.data?.list || [];\n          const categories = categoryRes.data?.list || [];\n          \n          // 创建教材ID到分类ID的映射\n          const textbookToCategoryMap = {};\n          textbooks.forEach(book => {\n            if (book.id && book.categoryId) {\n              textbookToCategoryMap[book.id] = book.categoryId;\n            }\n          });\n          \n          // 创建分类ID到分类名称的映射\n          const categoryMap = {};\n          categories.forEach(category => {\n            if (category.id) {\n              categoryMap[category.id] = {\n                name: category.categoryName || '未知分类',\n                value: 0\n              };\n            }\n          });\n          \n          // 如果没有分类，添加一个默认分类避免图表为空\n          if (Object.keys(categoryMap).length === 0) {\n            categoryMap['default'] = {\n              name: '未分类',\n              value: 0\n            };\n          }\n          \n          // 统计各分类的申报数量\n          applications.forEach(app => {\n            if (app.textbookId) {\n              const categoryId = textbookToCategoryMap[app.textbookId];\n              if (categoryId && categoryMap[categoryId]) {\n                categoryMap[categoryId].value++;\n              } else {\n                // 如果找不到对应分类，放入未知分类\n                if (!categoryMap['unknown']) {\n                  categoryMap['unknown'] = {\n                    name: '未知分类',\n                    value: 0\n                  };\n                }\n                categoryMap['unknown'].value++;\n              }\n            }\n          });\n          \n          // 转换为数组形式，