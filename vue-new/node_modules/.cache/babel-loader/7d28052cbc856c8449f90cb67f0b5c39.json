 = JSON.parse(localStorage.getItem(\"xm-user\") || '{}')\r\n    config.headers['token'] = user.token\r\n\r\n    return config\r\n}, error => {\r\n    console.error('请求拦截器错误:', error)\r\n    return Promise.reject(error)\r\n});\r\n\r\n// response拦截器\r\n// 响应后的统一处理\r\nrequest.interceptors.response.use(\r\n    response => {\r\n        console.log('收到响应:', response);\r\n        let res = response.data;\r\n\r\n        // 兼容服务端返回字符串数据\r\n        if (typeof res === 'string') {\r\n            res = res ? JSON.parse(res) : res\r\n        }\r\n        if (res.code === '401') {\r\n            router.push('/login')\r\n        }\r\n        return res;\r\n    },\r\n    error => {\r\n        console.error('响应错误:', error);\r\n        if (error.response) {\r\n            console.error('错误状态码:', error.response.status);\r\n            console.error('错误数据:', error.response.data);\r\n            \r\n            if (error.response.status === 401) {\r\n                router.push('/login')\r\n            }\r\n        }\r\n        return Promise.reject(error)\r\n    }\r\n)\r\n\r\nexport default request "],"mappings":";AAAA,OAAOA,KAAK,MAAM,OAAO;AACzB,OAAOC,MAAM,MAAM,UAAU;;AAE7B;AACA,MAAMC,OAAO,GAAGF,KAAK,CAACG,MAAM,CAAC;EACzBC,OAAO,EAAEC,OAAO,CAACC,GAAG,CAACC,eAAe,IAAI,uBAAuB;EAC/DC,OAAO,EAAE;AACb,CAAC,CAAC;;AAEF;AACA;AACAN,OAAO,CAACO,YAAY,CAACP,OAAO,CAACQ,GAAG,CAACC,MAAM,IAAI;EACvCC,OAAO,CAACC,GAAG,CAAC,OAAO,EAAEF,MAAM,CAACG,GAAG,EAAEH,MAAM,CAAC;EAExCA,MAAM,CAACI,OAAO,CAAC,cAAc,CAAC,GAAG,gCAAgC;EACjE,IAAIC,IAAI,GAAGC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,SAAS,CAAC,IAAI,IAAI,CAAC;EAC9DT,MAAM,CAACI,OAAO,CAAC,OAAO,CAAC,GAAGC,IAAI,CAACK,KAAK;EAEpC,OAAOV,MAAM;AACjB,CAAC,EAAEW,KAAK,IAAI;EACRV,OAAO,CAACU,KAAK,CAAC,UAAU,EAAEA,KAAK,CAAC;EAChC,OAAOC,OAAO,CAACC,MAAM,CAACF,KAAK,CAAC;AAChC,CAAC,CAAC;;AAEF;AACA;AACApB,OAAO,CAACO,YAAY,CAACgB,QAAQ,CAACf,GAAG,CAC7Be,QAAQ,IAAI;EACRb,OAAO,CAACC,GAAG,CAAC,OAAO,EAAEY,QAAQ,CAAC;EAC9B,IAAIC,GAAG,GAAGD,QAAQ,CAACE,IAAI;;EAEvB;EACA,IAAI,OAAOD,GAAG,KAAK,QAAQ,EAA