{"remainingRequest":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\babel-loader\\lib\\index.js!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\manager\\TextbookCategory.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\manager\\TextbookCategory.vue","mtime":1753450395129},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\babel.config.js","mtime":1753409336095},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\babel-loader\\lib\\index.js","mtime":1753409923129},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["name","data","viewMode","searchForm","tableData","loading","treeLoading","treeData","total","pageNum","pageSize","selection","parentOptions","dialogVisible","dialogTitle","submitLoading","detailDialogVisible","currentCategory","form","id","parentId","description","rules","required","message","trigger","min","max","created","fetchData","loadAllCategories","methods","params","$request","get","then","res","code","list","forEach","item","parent","find","p","parentName","$message","error","msg","catch","finally","loadTreeData","handleSearch","resetSearch","$refs","resetFields","success","queryAllCategories","handleSizeChange","val","handleCurrentChange","handleSelectionChange","handleAdd","$nextTick","clearValidate","handleEdit","row","JSON","parse","stringify","handleDetail","saveCategory","validate","valid","request","put","post","handleDelete","$confirm","confirmButtonText","cancelButtonText","type","delete","handleBatchDelete","length","warning","ids","map","watch","newVal"],"sources":["src/views/manager/TextbookCategory.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <!-- 功能说明 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm p-6 mb-5\">\r\n      <div class=\"flex items-center\">\r\n        <i class=\"el-icon-collection-tag text-3xl text-blue-500 mr-3\"></i>\r\n        <div>\r\n          <h2 class=\"text-xl font-bold text-gray-800 mb-1\">教材分类管理</h2>\r\n          <p class=\"text-gray-600\">本模块用于管理教材分类目录，提供分类信息的增加、修改、删除和查询功能，支持树形结构展示</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 搜索和操作区域 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm p-6 mb-5\">\r\n      <div class=\"flex flex-wrap items-center justify-between\">\r\n        <div class=\"w-full lg:w-auto mb-4 lg:mb-0\">\r\n          <el-form :inline=\"true\" :model=\"searchForm\" ref=\"searchForm\">\r\n            <el-form-item>\r\n              <el-input \r\n                v-model=\"searchForm.name\" \r\n                placeholder=\"请输入分类名称\" \r\n                prefix-icon=\"el-icon-collection\" \r\n                clearable\r\n                size=\"small\"\r\n              ></el-input>\r\n            </el-form-item>\r\n            <el-form-item>\r\n              <el-button type=\"primary\" @click=\"handleSearch\" icon=\"el-icon-search\" size=\"small\" class=\"mr-2\">查询</el-button>\r\n              <el-button @click=\"resetSearch\" icon=\"el-icon-refresh\" size=\"small\" class=\"mr-2\">重置</el-button>\r\n              <el-button type=\"success\" @click=\"queryAllCategories\" icon=\"el-icon-menu\" size=\"small\">查询全部</el-button>\r\n            </el-form-item>\r\n          </el-form>\r\n        </div>\r\n        <div class=\"w-full lg:w-auto flex justify-end space-x-3\">\r\n          <el-button type=\"primary\" @click=\"handleAdd\" icon=\"el-icon-plus\" size=\"small\">添加分类</el-button>\r\n          <el-button type=\"danger\" @click=\"handleBatchDelete\" :disabled=\"selection.length === 0\" icon=\"el-icon-delete\" size=\"small\">\r\n            批量删除\r\n          </el-button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 切换视图按钮 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm p-4 mb-5 flex justify-end\">\r\n      <el-radio-group v-model=\"viewMode\" size=\"small\">\r\n        <el-radio-button label=\"table\">表格视图</el-radio-button>\r\n        <el-radio-button label=\"tree\">树形视图</el-radio-button>\r\n      </el-radio-group>\r\n    </div>\r\n\r\n    <!-- 表格视图 -->\r\n    <div v-if=\"viewMode === 'table'\" class=\"bg-white rounded-lg shadow-sm overflow-hidden mb-5\">\r\n      <el-table\r\n        :data=\"tableData\"\r\n        style=\"width: 100%\"\r\n        v-loading=\"loading\"\r\n        @selection-change=\"handleSelectionChange\"\r\n        :border=\"false\"\r\n        stripe\r\n        :cell-style=\"{padding: '16px 0'}\"\r\n        :header-cell-style=\"{background:'#f8fafc', color:'#475569', fontWeight: '600'}\"\r\n      >\r\n        <el-table-column type=\"selection\" width=\"55\"></el-table-column>\r\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\r\n        <el-table-column prop=\"categoryName\" label=\"分类名称\" min-width=\"150\">\r\n          <template slot-scope=\"scope\">\r\n            <div class=\"flex items-center\">\r\n              <i class=\"el-icon-folder text-amber-500 mr-2\"></i>\r\n              <span>{{ scope.row.categoryName }}</span>\r\n            </div>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"parentName\" label=\"父级分类\" min-width=\"150\">\r\n          <template slot-scope=\"scope\">\r\n            <span v-if=\"scope.row.parentName\">{{ scope.row.parentName }}</span>\r\n            <span v-else class=\"text-gray-400\">无（顶级分类）</span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"description\" label=\"分类描述\" min-width=\"200\">\r\n          <template slot-scope=\"scope\">\r\n            <el-tooltip v-if=\"scope.row.description && scope.row.description.length > 30\" :content=\"scope.row.description\" placement=\"top\">\r\n              <span>{{ scope.row.description.substring(0, 30) + '...' }}</span>\r\n            </el-tooltip>\r\n            <span v-else>{{ scope.row.description || '暂无描述' }}</span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" fixed=\"right\" width=\"180\" align=\"center\">\r\n          <template slot-scope=\"scope\">\r\n            <div class=\"flex justify-center space-x-2\">\r\n              <el-button type=\"primary\" size=\"mini\" icon=\"el-icon-edit\" circle @click=\"handleEdit(scope.row)\" class=\"transform hover:-translate-y-1 transition-transform\"></el-button>\r\n              <el-button type=\"info\" size=\"mini\" icon=\"el-icon-view\" circle @click=\"handleDetail(scope.row)\" class=\"transform hover:-translate-y-1 transition-transform\"></el-button>\r\n              <el-button type=\"danger\" size=\"mini\" icon=\"el-icon-delete\" circle @click=\"handleDelete(scope.row)\" class=\"transform hover:-translate-y-1 transition-transform\"></el-button>\r\n            </div>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n      \r\n      <!-- 分页组件 -->\r\n      <div class=\"p-4 flex justify-end\">\r\n        <el-pagination\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\"\r\n          :current-page=\"pageNum\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :page-size=\"pageSize\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          :total=\"total\"\r\n          background\r\n        ></el-pagination>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 树形视图 -->\r\n    <div v-else class=\"bg-white rounded-lg shadow-sm p-6 mb-5\">\r\n      <el-tree\r\n        v-if=\"treeData.length > 0\"\r\n        :data=\"treeData\"\r\n        :props=\"{\r\n          children: 'children',\r\n          label: 'name'\r\n        }\"\r\n        node-key=\"id\"\r\n        default-expand-all\r\n        :expand-on-click-node=\"false\"\r\n        v-loading=\"treeLoading\"\r\n      >\r\n        <span class=\"custom-tree-node\" slot-scope=\"{ node, data }\">\r\n          <span class=\"flex items-center\">\r\n            <i class=\"el-icon-folder text-amber-500 mr-2\"></i>\r\n            <span>{{ node.label }}</span>\r\n          </span>\r\n          <span class=\"flex items-center ml-4\">\r\n            <el-button type=\"text\" size=\"mini\" @click=\"handleEdit(data)\">\r\n              <i class=\"el-icon-edit text-blue-500\"></i>\r\n            </el-button>\r\n            <el-button type=\"text\" size=\"mini\" @click=\"handleDetail(data)\">\r\n              <i class=\"el-icon-view text-green-500\"></i>\r\n            </el-button>\r\n            <el-button type=\"text\" size=\"mini\" @click=\"handleDelete(data)\">\r\n              <i class=\"el-icon-delete text-red-500\"></i>\r\n            </el-button>\r\n          </span>\r\n        </span>\r\n      </el-tree>\r\n      <div v-else class=\"text-center p-10 text-gray-400\">\r\n        <i class=\"el-icon-folder-opened text-4xl mb-3\"></i>\r\n        <p>暂无分类数据</p>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 添加/编辑分类对话框 -->\r\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"600px\" :close-on-click-modal=\"false\" custom-class=\"rounded-lg\">\r\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"100px\">\r\n        <el-form-item label=\"分类名称\" prop=\"name\">\r\n          <el-input v-model=\"form.name\" placeholder=\"请输入分类名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"父级分类\">\r\n          <el-select v-model=\"form.parentId\" placeholder=\"请选择父级分类\" clearable style=\"width: 100%\">\r\n            <el-option label=\"无（顶级分类）\" :value=\"null\"></el-option>\r\n            <el-option\r\n              v-for=\"item in parentOptions\"\r\n              :key=\"item.id\"\r\n              :label=\"item.name\"\r\n              :value=\"item.id\"\r\n              :disabled=\"form.id === item.id\"\r\n            ></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"分类描述\" prop=\"description\">\r\n          <el-input type=\"textarea\" v-model=\"form.description\" placeholder=\"请输入分类描述\" :rows=\"4\"></el-input>\r\n        </el-form-item>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"flex justify-end space-x-3\">\r\n        <el-button @click=\"dialogVisible = false\" icon=\"el-icon-close\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveCategory\" :loading=\"submitLoading\" icon=\"el-icon-check\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 分类详情对话框 -->\r\n    <el-dialog title=\"分类详情\" :visible.sync=\"detailDialogVisible\" width=\"500px\" custom-class=\"rounded-lg\">\r\n      <div v-if=\"currentCategory\" class=\"px-5\">\r\n        <div class=\"bg-gray-50 rounded-lg p-4 mb-4\">\r\n          <h4 class=\"flex items-center text-gray-700 font-medium mb-3\">\r\n            <i class=\"el-icon-folder text-amber-500 mr-2\"></i> 基本信息\r\n          </h4>\r\n          <div class=\"space-y-3\">\r\n            <div class=\"flex\">\r\n              <span class=\"text-gray-500 w-24\">分类ID:</span>\r\n              <span class=\"text-gray-800\">{{ currentCategory.id }}</span>\r\n            </div>\r\n            <div class=\"flex\">\r\n              <span class=\"text-gray-500 w-24\">分类名称:</span>\r\n              <span class=\"text-gray-800\">{{ currentCategory.name }}</span>\r\n            </div>\r\n            <div class=\"flex\">\r\n              <span class=\"text-gray-500 w-24\">父级分类:</span>\r\n              <span class=\"text-gray-800\">{{ currentCategory.parentName || '无（顶级分类）' }}</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"bg-gray-50 rounded-lg p-4\">\r\n          <h4 class=\"flex items-center text-gray-700 font-medium mb-3\">\r\n            <i class=\"el-icon-document text-blue-500 mr-2\"></i> 详细描述\r\n          </h4>\r\n          <p class=\"text-gray-700 whitespace-pre-wrap\">{{ currentCategory.description || '暂无描述' }}</p>\r\n        </div>\r\n      </div>\r\n      <div slot=\"footer\" class=\"flex justify-end space-x-3\">\r\n        <el-button @click=\"detailDialogVisible = false\" icon=\"el-icon-close\">关 闭</el-button>\r\n        <el-button type=\"primary\" @click=\"handleEdit(currentCategory)\" icon=\"el-icon-edit\">编辑分类</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"TextbookCategoryManage\",\r\n  data() {\r\n    return {\r\n      // 视图模式：表格/树形\r\n      viewMode: 'table',\r\n      \r\n      // 搜索表单\r\n      searchForm: {\r\n        name: \"\",\r\n      },\r\n      // 表格数据\r\n      tableData: [],\r\n      loading: false,\r\n      treeLoading: false,\r\n      treeData: [],\r\n      total: 0,\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      \r\n      // 选中项\r\n      selection: [],\r\n      \r\n      // 父级分类选项\r\n      parentOptions: [],\r\n      \r\n      // 对话框\r\n      dialogVisible: false,\r\n      dialogTitle: \"添加分类\",\r\n      submitLoading: false,\r\n      \r\n      // 详情对话框\r\n      detailDialogVisible: false,\r\n      currentCategory: null,\r\n      \r\n      // 表单\r\n      form: {\r\n        id: null,\r\n        name: \"\",\r\n        parentId: null,\r\n        description: \"\"\r\n      },\r\n      \r\n      // 表单验证规则\r\n      rules: {\r\n        name: [\r\n          { required: true, message: \"请输入分类名称\", trigger: \"blur\" },\r\n          { min: 2, max: 50, message: \"长度在 2 到 50 个字符\", trigger: \"blur\" }\r\n        ],\r\n        description: [\r\n          { max: 500, message: \"长度不能超过 500 个字符\", trigger: \"blur\" }\r\n        ]\r\n      }\r\n    };\r\n  },\r\n  created() {\r\n    this.fetchData();\r\n    this.loadAllCategories();\r\n  },\r\n  methods: {\r\n    // 获取数据\r\n    fetchData() {\r\n      this.loading = true;\r\n      \r\n      // 构建请求参数\r\n      const params = {\r\n        pageNum: this.pageNum,\r\n        pageSize: this.pageSize\r\n      };\r\n      \r\n      // 只有当搜索表单中有值时才添加到请求参数中\r\n      if (this.searchForm.name) {\r\n        params.name = this.searchForm.name;\r\n      }\r\n      \r\n      this.$request.get(\"/textbookCategory/selectPage\", { params })\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.tableData = res.data.list || [];\r\n            // 处理父级分类名称显示\r\n            this.tableData.forEach(item => {\r\n              if (item.parentId) {\r\n                const parent = this.parentOptions.find(p => p.id === item.parentId);\r\n                item.parentName = parent ? parent.name : '';\r\n              }\r\n            });\r\n            this.total = res.data.total || 0;\r\n          } else {\r\n            this.$message.error(res.msg || \"获取分类数据失败\");\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"获取分类数据异常\");\r\n        })\r\n        .finally(() => {\r\n          this.loading = false;\r\n        });\r\n    },\r\n    \r\n    // 加载所有分类作为父级选项\r\n    loadAllCategories() {\r\n      this.$request.get(\"/textbookCategory/selectAll\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.parentOptions = res.data || [];\r\n          }\r\n        });\r\n    },\r\n    \r\n    // 加载树形结构数据\r\n    loadTreeData() {\r\n      this.treeLoading = true;\r\n      this.$request.get(\"/textbookCategory/tree\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.treeData = res.data || [];\r\n          } else {\r\n            this.$message.error(res.msg || \"获取分类树形数据失败\");\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"获取分类树形数据异常\");\r\n        })\r\n        .finally(() => {\r\n          this.treeLoading = false;\r\n        });\r\n    },\r\n    \r\n    // 查询\r\n    handleSearch() {\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 重置查询\r\n    resetSearch() {\r\n      // 清除搜索表单\r\n      this.$refs.searchForm.resetFields();\r\n      this.pageNum = 1;\r\n      // 重新加载所有数据\r\n      this.fetchData();\r\n      this.$message.success(\"已重置搜索条件，显示所有分类数据\");\r\n    },\r\n    \r\n    // 查询全部分类\r\n    queryAllCategories() {\r\n      // 清除搜索表单\r\n      this.$refs.searchForm.resetFields();\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n      this.$message.success(\"已显示所有分类数据\");\r\n    },\r\n    \r\n    // 分页相关\r\n    handleSizeChange(val) {\r\n      this.pageSize = val;\r\n      this.fetchData();\r\n    },\r\n    \r\n    handleCurrentChange(val) {\r\n      this.pageNum = val;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 表格选中项变化\r\n    handleSelectionChange(selection) {\r\n      this.selection = selection;\r\n    },\r\n    \r\n    // 添加分类\r\n    handleAdd() {\r\n      this.dialogTitle = \"添加分类\";\r\n      this.form = {\r\n        id: null,\r\n        name: \"\",\r\n        parentId: null,\r\n        description: \"\"\r\n      };\r\n      this.dialogVisible = true;\r\n      \r\n      // 清除验证\r\n      this.$nextTick(() => {\r\n        if (this.$refs.form) {\r\n          this.$refs.form.clearValidate();\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 编辑分类\r\n    handleEdit(row) {\r\n      this.dialogTitle = \"编辑分类\";\r\n      this.form = JSON.parse(JSON.stringify(row)); // 深拷贝，防止直接修改表格数据\r\n      this.dialogVisible = true;\r\n      \r\n      // 清除验证\r\n      this.$nextTick(() => {\r\n        if (this.$refs.form) {\r\n          this.$refs.form.clearValidate();\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 查看详情\r\n    handleDetail(row) {\r\n      this.currentCategory = row;\r\n      this.detailDialogVisible = true;\r\n    },\r\n    \r\n    // 保存分类（添加或更新）\r\n    saveCategory() {\r\n      this.$refs.form.validate(valid => {\r\n        if (valid) {\r\n          this.submitLoading = true;\r\n          \r\n          const request = this.form.id \r\n            ? this.$request.put(\"/textbookCategory/update\", this.form)\r\n            : this.$request.post(\"/textbookCategory/add\", this.form);\r\n            \r\n          request.then(res => {\r\n              if (res.code === '200') {\r\n                this.$message.success(this.form.id ? \"编辑成功\" : \"添加成功\");\r\n                this.dialogVisible = false;\r\n                this.fetchData();\r\n                // 重新加载树形结构数据\r\n                if (this.viewMode === 'tree') {\r\n                  this.loadTreeData();\r\n                }\r\n                // 重新加载所有分类作为父级选项\r\n                this.loadAllCategories();\r\n              } else {\r\n                this.$message.error(res.msg || (this.form.id ? \"编辑失败\" : \"添加失败\"));\r\n              }\r\n            })\r\n            .catch(() => {\r\n              this.$message.error(this.form.id ? \"编辑分类请求异常\" : \"添加分类请求异常\");\r\n            })\r\n            .finally(() => {\r\n              this.submitLoading = false;\r\n            });\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 删除分类\r\n    handleDelete(row) {\r\n      this.$confirm(\"确定删除该分类吗?\", \"提示\", {\r\n        confirmButtonText: \"确定\",\r\n        cancelButtonText: \"取消\",\r\n        type: \"warning\"\r\n      }).then(() => {\r\n        this.$request.delete(`/textbookCategory/delete/${row.id}`)\r\n          .then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success(\"删除成功\");\r\n              this.fetchData();\r\n              // 重新加载树形结构数据\r\n              if (this.viewMode === 'tree') {\r\n                this.loadTreeData();\r\n              }\r\n              // 重新加载所有分类作为