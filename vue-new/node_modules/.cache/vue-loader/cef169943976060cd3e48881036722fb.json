{"remainingRequest":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\front\\Textbooks.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\front\\Textbooks.vue","mtime":1753453252795},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\babel-loader\\lib\\index.js","mtime":1753409923129},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Textbooks.vue"],"names":[],"mappings":";AA4SA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;;AAEA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Textbooks.vue","sourceRoot":"src/views/front","sourcesContent":["<template>\r\n  <div class=\"textbook-container\">\r\n    <!-- 头部展示区 -->\r\n    <div class=\"relative bg-blue-600 h-64 rounded-lg overflow-hidden mb-6\">\r\n      <div class=\"absolute inset-0 bg-gradient-to-r from-blue-700 to-blue-500 opacity-90\"></div>\r\n      <div class=\"absolute inset-0 bg-pattern opacity-10\"></div>\r\n      <div class=\"container mx-auto px-6 relative z-10 flex h-full items-center\">\r\n        <div class=\"w-full md:w-2/3\">\r\n          <h1 class=\"text-white text-3xl md:text-4xl font-bold mb-2\">教材资源中心</h1>\r\n          <p class=\"text-blue-100 text-lg md:text-xl mb-6\">\r\n            浏览全校精选教材资源，助力学习和教学\r\n          </p>\r\n          <div class=\"relative w-full max-w-xl\">\r\n            <input\r\n              v-model=\"searchForm.textbookName\"\r\n              type=\"text\"\r\n              placeholder=\"搜索教材名称、作者或出版社...\"\r\n              @keyup.enter=\"handleSearch\"\r\n              class=\"w-full px-5 py-3 pr-12 text-gray-700 bg-white rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400\"\r\n            />\r\n            <button \r\n              @click=\"handleSearch\"\r\n              class=\"absolute right-2 top-1/2 transform -translate-y-1/2 text-gray-500 hover:text-blue-500\"\r\n            >\r\n              <i class=\"el-icon-search text-xl\"></i>\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 主体内容区 -->\r\n    <div class=\"container mx-auto px-4\">\r\n      <div class=\"flex flex-wrap -mx-4\">\r\n        <!-- 左侧筛选区 -->\r\n        <div class=\"w-full lg:w-1/4 px-4 mb-6\">\r\n          <div class=\"bg-white rounded-lg shadow-sm p-5 mb-6\">\r\n            <h3 class=\"text-lg font-semibold text-gray-800 mb-4 flex items-center\">\r\n              <i class=\"el-icon-filter text-blue-500 mr-2\"></i>\r\n              筛选条件\r\n            </h3>\r\n            \r\n            <!-- 分类筛选 -->\r\n            <div class=\"mb-5\">\r\n              <h4 class=\"text-gray-600 font-medium mb-2\">教材分类</h4>\r\n              <el-select \r\n                v-model=\"searchForm.categoryId\" \r\n                placeholder=\"选择分类\"\r\n                clearable\r\n                size=\"small\"\r\n                class=\"w-full\"\r\n              >\r\n                <el-option\r\n                  v-for=\"item in categories\"\r\n                  :key=\"item.id\"\r\n                  :label=\"item.categoryName\"\r\n                  :value=\"item.id\"\r\n                >\r\n                </el-option>\r\n              </el-select>\r\n            </div>\r\n            \r\n            <!-- 出版社筛选 -->\r\n            <div class=\"mb-5\">\r\n              <h4 class=\"text-gray-600 font-medium mb-2\">出版社</h4>\r\n              <el-select \r\n                v-model=\"searchForm.publisher\" \r\n                placeholder=\"选择出版社\"\r\n                clearable\r\n                size=\"small\"\r\n                class=\"w-full\"\r\n              >\r\n                <el-option\r\n                  v-for=\"item in publishers\"\r\n                  :key=\"item\"\r\n                  :label=\"item\"\r\n                  :value=\"item\"\r\n                >\r\n                </el-option>\r\n              </el-select>\r\n            </div>\r\n            \r\n            <!-- 年份筛选 -->\r\n<!--            <div class=\"mb-5\">-->\r\n<!--              <h4 class=\"text-gray-600 font-medium mb-2\">出版年份</h4>-->\r\n<!--              <el-date-picker-->\r\n<!--                v-model=\"searchForm.publishDate\"-->\r\n<!--                type=\"year\"-->\r\n<!--                placeholder=\"选择年份\"-->\r\n<!--                clearable-->\r\n<!--                size=\"small\"-->\r\n<!--                class=\"w-full\"-->\r\n<!--                value-format=\"yyyy\"-->\r\n<!--              >-->\r\n<!--              </el-date-picker>-->\r\n<!--            </div>-->\r\n\r\n            <!-- 筛选操作按钮 -->\r\n            <div class=\"flex justify-between pt-3 border-t border-gray-100\">\r\n              <el-button size=\"small\" @click=\"resetSearch\" icon=\"el-icon-refresh\">\r\n                重置\r\n              </el-button>\r\n              <el-button size=\"small\" type=\"primary\" @click=\"handleSearch\" icon=\"el-icon-search\">\r\n                查询\r\n              </el-button>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 热门推荐区 -->\r\n          <div class=\"bg-white rounded-lg shadow-sm p-5\">\r\n            <h3 class=\"text-lg font-semibold text-gray-800 mb-4 flex items-center\">\r\n              <i class=\"el-icon-star-on text-yellow-500 mr-2\"></i>\r\n              热门教材\r\n            </h3>\r\n            <div v-if=\"recommendBooks.length\" class=\"space-y-4\">\r\n              <div \r\n                v-for=\"item in recommendBooks\" \r\n                :key=\"item.id\"\r\n                class=\"flex items-start hover:bg-gray-50 p-2 rounded-md transition cursor-pointer\"\r\n                @click=\"handleViewDetail(item)\"\r\n              >\r\n                <div class=\"bg-gray-100 w-12 h-16 rounded overflow-hidden flex-shrink-0\">\r\n                  <img v-if=\"item.coverImage\" :src=\"item.coverImage\" class=\"w-full h-full object-cover\" />\r\n                  <div v-else class=\"w-full h-full flex items-center justify-center\">\r\n                    <i class=\"el-icon-notebook-2 text-gray-400 text-xl\"></i>\r\n                  </div>\r\n                </div>\r\n                <div class=\"ml-3 flex-1 min-w-0\">\r\n                  <p class=\"text-sm font-medium text-gray-800 mb-1 truncate\">{{ item.textbookName }}</p>\r\n                  <p class=\"text-xs text-gray-500 truncate\">{{ item.author }}</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div v-else class=\"text-center py-4 text-gray-500\">\r\n              <i class=\"el-icon-document text-4xl mb-2\"></i>\r\n              <p>暂无推荐教材</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 右侧教材列表 -->\r\n        <div class=\"w-full lg:w-3/4 px-4\">\r\n          <!-- 排序选项 -->\r\n          <div class=\"bg-white rounded-lg shadow-sm p-4 mb-6 flex items-center justify-between flex-wrap\">\r\n<!--            <div class=\"text-gray-700 flex items-center mb-2 sm:mb-0\">-->\r\n<!--              <span>排序方式：</span>-->\r\n<!--              <div class=\"ml-2\">-->\r\n<!--                <el-radio-group v-model=\"sortOption\" size=\"small\" @change=\"handleSortChange\">-->\r\n<!--                  <el-radio-button label=\"newest\">最新上架</el-radio-button>-->\r\n<!--                  <el-radio-button label=\"popular\">人气最高</el-radio-button>-->\r\n<!--                </el-radio-group>-->\r\n<!--              </div>-->\r\n<!--            </div>-->\r\n            <div class=\"text-gray-500 text-sm\">\r\n              共找到 <span class=\"text-blue-600 font-semibold\">{{ total }}</span> 个教材\r\n            </div>\r\n          </div>\r\n\r\n          <!-- 教材列表 -->\r\n          <div v-loading=\"loading\">\r\n            <div v-if=\"tableData.length > 0\" class=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6\">\r\n              <div \r\n                v-for=\"item in tableData\" \r\n                :key=\"item.id\"\r\n                class=\"bg-white rounded-lg shadow-sm overflow-hidden hover:shadow-md transition cursor-pointer\"\r\n                @click=\"handleViewDetail(item)\"\r\n              >\r\n                <!-- 教材封面 -->\r\n                <div class=\"aspect-w-2 aspect-h-3 relative\">\r\n                  <div class=\"bg-gray-100 w-full h-48 flex items-center justify-center\">\r\n                    <img v-if=\"item.coverImage\" :src=\"item.coverImage\" class=\"h-full object-cover\" />\r\n                    <div v-else class=\"flex flex-col items-center\">\r\n                      <i class=\"el-icon-notebook-2 text-gray-300 text-6xl\"></i>\r\n                      <span class=\"text-gray-400 mt-2\">无封面</span>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n                \r\n                <!-- 教材信息 -->\r\n                <div class=\"p-4\">\r\n                  <h3 class=\"text-lg font-semibold text-gray-800 mb-1 truncate\">{{ item.textbookName }}</h3>\r\n                  <div class=\"text-sm text-gray-500 mb-2 truncate\">\r\n                    <span>{{ item.author || '暂无作者信息' }}</span>\r\n                  </div>\r\n                  <div class=\"flex justify-between items-center text-xs\">\r\n                    <span class=\"text-blue-600\">{{ item.publisher || '暂无出版社' }}</span>\r\n                    <span class=\"text-gray-500\">{{ item.publishDate || '暂无年份' }}</span>\r\n                  </div>\r\n                  \r\n                  <!-- 分类标签 -->\r\n                  <div class=\"mt-3\" v-if=\"item.categoryName\">\r\n                    <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800\">\r\n                      {{ item.categoryName }}\r\n                    </span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            \r\n            <!-- 空状态 -->\r\n            <div v-else class=\"bg-white rounded-lg shadow-sm p-10 text-center\">\r\n              <img src=\"\" alt=\"No Data\" class=\"w-32 h-32 mx-auto mb-4 opacity-75\" />\r\n              <h3 class=\"text-lg font-medium text-gray-500\">暂无相关教材</h3>\r\n              <p class=\"text-gray-400 mt-1\">请尝试更换筛选条件</p>\r\n              <el-button type=\"primary\" plain class=\"mt-4\" @click=\"resetSearch\">重置筛选</el-button>\r\n            </div>\r\n            \r\n            <!-- 分页 -->\r\n            <div class=\"mt-8 flex justify-center\" v-if=\"total > 0\">\r\n              <el-pagination\r\n                @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\"\r\n                :current-page=\"pageNum\"\r\n                :page-sizes=\"[9, 18, 36, 72]\"\r\n                :page-size=\"pageSize\"\r\n                layout=\"total, sizes, prev, pager, next, jumper\"\r\n                :total=\"total\"\r\n                background\r\n              ></el-pagination>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- 教材详情对话框 -->\r\n    <el-dialog \r\n      title=\"教材详情\" \r\n      :visible.sync=\"detailDialogVisible\" \r\n      width=\"800px\" \r\n      :close-on-click-modal=\"true\"\r\n      custom-class=\"textbook-detail-dialog\"\r\n    >\r\n      <div v-if=\"currentBook\" class=\"flex flex-col md:flex-row\">\r\n        <!-- 封面 -->\r\n        <div class=\"w-full md:w-1/3 flex justify-center md:justify-start mb-6 md:mb-0\">\r\n          <div class=\"bg-gray-100 w-48 h-64 rounded-lg overflow-hidden flex items-center justify-center shadow\">\r\n            <img v-if=\"currentBook.coverImage\" :src=\"currentBook.coverImage\" class=\"w-full h-full object-cover\" />\r\n            <div v-else class=\"flex flex-col items-center\">\r\n              <i class=\"el-icon-notebook-2 text-gray-300 text-6xl\"></i>\r\n              <span class=\"text-gray-400 mt-2\">无封面</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 信息 -->\r\n        <div class=\"w-full md:w-2/3 md:pl-6\">\r\n          <h2 class=\"text-2xl font-bold text-gray-800 mb-2\">{{ currentBook.textbookName }}</h2>\r\n          \r\n          <div class=\"bg-gray-50 rounded-lg p-4 mb-4\">\r\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">作者</div>\r\n                <div class=\"font-medium\">{{ currentBook.author || '暂无作者信息' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">出版社</div>\r\n                <div class=\"font-medium\">{{ currentBook.publisher || '暂无出版社信息' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">出版年份</div>\r\n                <div class=\"font-medium\">{{ currentBook.publishDate || '暂无出版年份' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">分类</div>\r\n                <div class=\"font-medium\">{{ currentBook.categoryName || '暂无分类信息' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">ISBN</div>\r\n                <div class=\"font-medium\">{{ currentBook.isbn || '暂无ISBN信息' }}</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 详细描述 -->\r\n          <div>\r\n            <h3 class=\"text-lg font-semibold text-gray-700 mb-2\">教材简介</h3>\r\n            <div class=\"bg-gray-50 rounded-lg p-4\">\r\n              <p class=\"text-gray-700 whitespace-pre-wrap\">\r\n                {{ currentBook.description || '暂无教材简介' }}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"detailDialogVisible = false\">关闭</el-button>\r\n        <el-button \r\n          type=\"primary\" \r\n          v-if=\"currentBook && currentBook.downloadUrl\"\r\n          @click=\"handleDownload\"\r\n        >\r\n          下载教材\r\n        </el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Textbooks\",\r\n  data() {\r\n    return {\r\n      // 搜索表单\r\n      searchForm: {\r\n        textbookName: \"\",\r\n        categoryId: null,\r\n        publisher: \"\",\r\n        publishYear: \"\"\r\n      },\r\n      \r\n      // 表格数据\r\n      tableData: [],\r\n      loading: false,\r\n      total: 0,\r\n      pageNum: 1,\r\n      pageSize: 9,\r\n      \r\n      // 分类选项\r\n      categories: [],\r\n      \r\n      // 出版社选项\r\n      publishers: [],\r\n      \r\n      // 推荐书籍\r\n      recommendBooks: [],\r\n      \r\n      // 排序选项\r\n      sortOption: 'newest',\r\n      \r\n      // 详情对话框\r\n      detailDialogVisible: false,\r\n      currentBook: null\r\n    };\r\n  },\r\n  created() {\r\n    this.fetchData();\r\n    this.loadCategories();\r\n    this.loadPublishers();\r\n    this.loadRecommendBooks();\r\n  },\r\n  methods: {\r\n    // 获取教材数据\r\n    fetchData() {\r\n      this.loading = true;\r\n      \r\n      // 构建请求参数\r\n      const params = {\r\n        pageNum: this.pageNum,\r\n        pageSize: this.pageSize,\r\n        ...this.searchForm\r\n      };\r\n      \r\n      // 添加排序条件\r\n      if (this.sortOption === 'newest') {\r\n        params.sortField = 'createTime';\r\n        params.sortOrder = 'desc';\r\n      } else if (this.sortOption === 'popular') {\r\n        params.sortField = 'viewCount';\r\n        params.sortOrder = 'desc';\r\n      }\r\n      \r\n      this.$request.get(\"/textbook/selectPage\", { params })\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.tableData = res.data.list || [];\r\n            this.total = res.data.total || 0;\r\n          } else {\r\n            this.$message.error(res.msg || \"获取教材数据失败\");\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"获取教材数据异常\");\r\n        })\r\n        .finally(() => {\r\n          this.loading = false;\r\n        });\r\n    },\r\n    \r\n    // 加载分类选项\r\n    loadCategories() {\r\n      this.$request.get(\"/textbookCategory/selectAll\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.categories = res.data || [];\r\n          }\r\n        });\r\n    },\r\n    \r\n    // 加载出版社选项\r\n    loadPublishers() {\r\n      this.$request.get(\"/textbook/publishers\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.publishers = res.data || [];\r\n          }\r\n        })\r\n        .catch(() => {\r\n          // 如果接口不存在，使用空数组\r\n          this.publishers = [];\r\n        });\r\n    },\r\n    \r\n    // 加载推荐书籍\r\n    loadRecommendBooks() {\r\n      this.$request.get(\"/textbook/recommend\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.recommendBooks = res.data || [];\r\n          }\r\n        })\r\n        .catch(() => {\r\n          // 如果接口不存在，使用空数组\r\n          this.recommendBooks = [];\r\n        });\r\n    },\r\n    \r\n    // 查询\r\n    handleSearch() {\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 重置查询\r\n    resetSearch() {\r\n      this.searchForm = {\r\n        textbookName: \"\",\r\n        categoryId: null,\r\n        publisher: \"\",\r\n        publishYear: \"\"\r\n      };\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 排序变更\r\n    handleSortChange() {\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 分页相关\r\n    handleSizeChange(val) {\r\n      this.pageSize = val;\r\n      this.fetchData();\r\n    },\r\n    \r\n    handleCurrentChange(val) {\r\n      this.pageNum = val;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 查看详情\r\n    handleViewDetail(book) {\r\n      // 查询详细信息\r\n      this.$request.get(`/textbook/selectById/${book.id}`)\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.currentBook = res.data;\r\n            this.detailDialogVisible = true;\r\n          } else {\r\n            this.$message.error(res.msg || \"获取教材详情失败\");\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"获取教材详情异常\");\r\n        });\r\n    },\r\n    \r\n    // 下载教材\r\n    handleDownload() {\r\n      if (this.currentBook && this.currentBook.downloadUrl) {\r\n        window.open(this.currentBook.downloadUrl, '_blank');\r\n      } else {\r\n        this.$message.warning(\"该教材暂无下载链接\");\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* 背景图案 */\r\n.bg-pattern {\r\n  background-image: url(\"data:image/svg+xml,%3Csvg wi