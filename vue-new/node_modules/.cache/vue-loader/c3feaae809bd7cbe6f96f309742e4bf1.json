div>\n          </div>\n          \n          <div class=\"register-process\">\n            <div class=\"process-title\">注册流程</div>\n            \n            <div class=\"process-item\">\n              <div class=\"process-step\">\n                <span class=\"step-number\">01</span>\n                <div class=\"step-line\"></div>\n              </div>\n              <div class=\"process-content\">\n                <h3>填写信息</h3>\n                <p>完善您的基本信息与联系方式</p>\n              </div>\n            </div>\n            \n            <div class=\"process-item\">\n              <div class=\"process-step\">\n                <span class=\"step-number\">02</span>\n                <div class=\"step-line\"></div>\n              </div>\n              <div class=\"process-content\">\n                <h3>账号注册</h3>\n                <p>系统审核通过后创建您的账号</p>\n              </div>\n            </div>\n            \n            <div class=\"process-item\">\n              <div class=\"process-step\">\n                <span class=\"step-number\">03</span>\n              </div>\n              <div class=\"process-content\">\n                <h3>立即使用</h3>\n                <p>登录系统，享受完整功能</p>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"footer\">\n            <p>©2023 高校教材管理系统 版权所有</p>\n          </div>\n        </div>\n        \n        <!-- 背景装饰 -->\n        <div class=\"decoration\">\n          <div class=\"circle circle-1\"></div>\n          <div class=\"circle circle-2\"></div>\n          <div class=\"circle circle-3\"></div>\n          <div class=\"floating-icon icon-1\">\n            <i class=\"el-icon-edit-outline\"></i>\n          </div>\n          <div class=\"floating-icon icon-2\">\n            <i class=\"el-icon-user\"></i>\n          </div>\n          <div class=\"floating-icon icon-3\">\n            <i class=\"el-icon-s-cooperation\"></i>\n          </div>\n        </div>\n      </div>\n      \n      <!-- 右侧注册表单区域 -->\n      <div class=\"right-section\">\n        <div class=\"form-container\">\n          <div class=\"form-header\">\n            <h2>用户注册</h2>\n            <p>请完成以下信息填写，注册一个新账号</p>\n          </div>\n          \n          <el-form :model=\"form\" :rules=\"rules\" ref=\"registerForm\" class=\"register-form\">\n            <!-- 修改注册表单，将图标放在输入框外部 -->\n            <el-form-item prop=\"username\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-user\"></i>\n                </div>\n                <el-input v-model=\"form.username\" placeholder=\"请输入账号\"></el-input>\n              </div>\n            </el-form-item>\n            <el-form-item prop=\"password\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-lock\"></i>\n                </div>\n                <el-input v-model=\"form.password\" type=\"password\" placeholder=\"请输入密码\"></el-input>\n              </div>\n            </el-form-item>\n            <!-- 修复确认密码输入框 -->\n            <el-form-item prop=\"confirmPassword\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-key\"></i>\n                </div>\n                <el-input v-model=\"form.confirmPassword\" type=\"password\" placeholder=\"请确认密码\"></el-input>\n              </div>\n            </el-form-item>\n            \n            <el-form-item prop=\"name\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-s-custom\"></i>\n                </div>\n                <el-input v-model=\"form.name\" placeholder=\"请输入姓名\"></el-input>\n              </div>\n            </el-form-item>\n            \n            <el-form-item prop=\"phone\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-phone\"></i>\n                </div>\n                <el-input v-model=\"form.phone\" placeholder=\"请输入手机号\"></el-input>\n              </div>\n            </el-form-item>\n            \n            <el-form-item prop=\"email\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-message\"></i>\n                </div>\n                <el-input v-model=\"form.email\" placeholder=\"请输入邮箱\"></el-input>\n              </div>\n            </el-form-item>\n            \n            <el-form-item prop=\"role\">\n              <div class=\"input-with-icon\">\n                <div class=\"icon-column\">\n                  <i class=\"el-icon-s-check\"></i>\n                </div>\n                <el-select v-model=\"form.role\" placeholder=\"学生\" style=\"width: 100%\">\n                  <el-option label=\"学生\" value=\"USER\"></el-option>\n                  <el-option label=\"教师\" value=\"TEACHER\"></el-option>\n                </el-select>\n              </div>\n            </el-form-item>\n            \n            <div v-if=\"form.role === 'TEACHER'\" class=\"role-extra-fields\">\n              <el-form-item prop=\"department\">\n                <div class=\"input-icon-wrapper\">\n                  <i class=\"el-icon-office-building input-icon\"></i>\n                  <el-input \n                    v-model=\"form.department\" \n                    placeholder=\"请输入所在院系\" \n                    class=\"custom-input\">\n                  </el-input>\n                </div>\n              </el-form-item>\n            </div>\n            \n            <div v-if=\"form.role === 'USER'\" class=\"role-extra-fields\">\n              <el-form-item prop=\"college\">\n                <div class=\"input-icon-wrapper\">\n                  <i class=\"el-icon-school input-icon\"></i>\n                  <el-input \n                    v-model=\"form.college\" \n                    placeholder=\"请输入所在学院\" \n                    class=\"custom-input\">\n                  </el-input>\n                </div>\n              </el-form-item>\n              \n              <el-form-item prop=\"major\">\n                <div class=\"input-icon-wrapper\">\n                  <i class=\"el-icon-reading input-icon\"></i>\n                  <el-input \n                    v-model=\"form.major\" \n                    placeholder=\"请输入所学专业\" \n                    class=\"custom-input\">\n                  </el-input>\n                </div>\n              </el-form-item>\n            </div>\n            \n            <el-form-item>\n              <el-button \n                type=\"primary\" \n                class=\"submit-button\" \n                @click=\"register\"\n                :loading=\"loading\">\n                立即注册\n              </el-button>\n            </el-form-item>\n          </el-form>\n          \n          <div class=\"form-footer\">\n            <p>已有账号? <router-link to=\"/login\" class=\"login-link\">立即登录</router-link></p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"Register\",\n  data() {\n    // 确认密码验证规则\n    const validateConfirmPassword = (rule, value, callback) => {\n      if (value !== this.form.password) {\n        callback(new Error('两次输入的密码不一致'));\n      } else {\n        callback();\n      }\n    };\n    \n    return {\n      form: {\n        username: \"\",\n        password: \"\",\n        confirmPassword: \"\",\n        name: \"\",\n        phone: \"\",\n        email: \"\",\n        role: \"USER\",\n        department: \"\",\n        college: \"\",\n        major: \"\"\n      },\n      rules: {\n        username: [\n          { required: true, message: \"请输入账号\", trigger: \"blur\" },\n          { min: 3, max: 20, message: \"长度在 3 到 20 个字符\", trigger: \"blur\" }\n        ],\n        password: [\n          { required: true, message: \"请输入密码\", trigger: \"blur\" },\n          { min: 6, max: 20, message: \"长度在 6 到 20 个字符\", trigger: \"blur\" }\n        ],\n        confirmPassword: [\n          { required: true, message: \"请确认密码\", trigger: \"blur\" },\n          { validator: validateConfirmPassword, trigger: \"blur\" }\n        ],\n        name: [\n          { required: true, message: \"请输入姓名\", trigger: \"blur\" }\n        ],\n        phone: [\n          { required: true, message: \"请输入手机号\", trigger: \"blur\" },\n          { pattern: /^1[3-9]\\d{9}$/, message: \"请输入正确的手机号\", trigger: \"blur\" }\n        ],\n        email: [\n          { required: true, message: \"请输入邮箱\", trigger: \"blur\" },\n          { type: \"email\", message: \"请输入正确的邮箱地址\", trigger: \"blur\" }\n        ],\n        role: [\n          { required: true, message: \"请选择角色\", trigger: \"change\" }\n        ],\n        department: [\n          { required: true, message: \"请输入所在院系\", trigger: \"blur\" }\n        ],\n        college: [\n          { required: true, message: \"请输入所在学院\", trigger: \"blur\" }\n        ],\n        major: [\n          { required: true, message: \"请输入所学专业\", trigger: \"blur\" }\n        ]\n      },\n      loading: false\n    };\n  },\n  created() {\n    // 清除可能存在的用户信息\n    localStorage.removeItem(\"xm-user\");\n  },\n  methods: {\n    register() {\n      this.$refs.registerForm.validate(valid => {\n        if (valid) {\n          this.loading = true;\n          \n          // 构建注册数据\n          const registerData = {\n            username: this.form.username,\n            password: this.form.password,\n            name: this.form.name,\n            phone: this.form.phone,\n            email: this.form.email,\n            role: this.form.role\n          };\n          \n          // 根据角色添加不同的字段\n          if (this.form.role === 'TEACHER') {\n            registerData.department = this.form.department;\n          } else if (this.form.role === 'USER') {\n            registerData.college = this.form.college;\n            registerData.major = this.form.major;\n          }\n          \n          // 调用注册API\n          this.$request.post(\"/register\", registerData).then(res => {\n            if (res.code === '0') {\n              this.$message.success(\"注册成功，请登录\");\n              this.$router.push(\"/login\");\n            } else {\n              this.$message.error(res.msg || \"注册失败\");\n            }\n          }).catch(() => {\n            this.$message.error(\"注册请求异常\");\n          }).finally(() => {\n            this.loading = false;\n          });\n        }\n      });\n    }\n  }\n};\n</script>\n\n<style scoped>\n/* 页面容器 */\n.page-container {\n  min-height: 100vh;\n  width: 100%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: linear-gradient(135deg, #e8f0fe 0%, #f0f7ff 25%, #edf7ff 50%, #e6f2ff 75%, #e0edfe 100%);\n  background-size: 400% 400%;\n  animation: gradientBackground 15s ease infinite;\n  padding: 20px;\n  position: relative;\n  overflow: hidden;\n}\n\n@keyframes gradientBackground {\n  0% {\n    background-position: 0% 50%;\n  }\n  50% {\n    background-position: 100% 50%;\n  }\n  100% {\n    background-position: 0% 50%;\n  }\n}\n\n/* 背景装饰 */\n.page-container:before {\n  content: \"\";\n  position: absolute;\n  top: -50%;\n  left: -50%;\n  width: 200%;\n  height: 200%;\n  background: radial-gradient(circle, rgba(63, 81, 181, 0.03) 0%, rgba(33, 150, 243, 0.01) 50%, rgba(240, 247, 255, 0) 70%);\n  animation: rotate 30s linear infinite;\n  z-index: 0;\n}\n\n.page-container:after {\n  content: \"\";\n  position: absolute;\n  top: -50%;\n  left: -50%;\n  width: 200%;\n  height: 200%;\n  background: radial-gradient(circle, rgba(33, 150, 243, 0.03) 0%, rgba(63, 81, 181, 0.01) 50%, rgba(240, 247, 255, 0) 70%);\n  animation: rotate 30s linear infinite reverse;\n  z-index: 0;\n}\n\n@keyframes rotate {\n  0% {\n    transform: rotate(0deg);\n  }\n  100% {\n    transform: rotate(360deg);\n  }\n}\n\n/* 主容器样式 */\n.register-container {\n  width: 1000px;\n  max-width: 100%;\n  height: 680px;\n  display: flex;\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 10px 30px rgba(33, 150, 243, 0.15), 0 5px 15px rgba(63, 81, 181, 0.1);\n  margin: auto;\n  position: relative;\n  z-index: 1;\n  backdrop-filter: blur(5px);\n  background-color: rgba(255, 255, 255, 0.8);\n}\n\n/* 左侧展示区域 */\n.left-section {\n  flex: 1;\n  background: linear-gradient(135deg, #3f51b5, #2196f3);\n  color: white;\n  position: relative;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n}\n\n.content-wrapper {\n  position: relative;\n  z-index: 2;\n  padding: 40px 30px;\n  height: 100%;\n  display: flex;\n  flex-direction: column;\n}\n\n.brand {\n  margin-bottom: 40px;\n}\n\n.logo-container {\n  display: flex;\n  align-items: center;\n}\n\n.logo {\n  width: 50px;\n  height: 50px;\n  margin-right: 15px;\n}\n\n.title-group h1 {\n  font-size: 24px;\n  font-weight: bold;\n  margin: 0 0 5px;\n}\n\n.title-group p {\n  font-size: 14px;\n  opacity: 0.9;\n  margin: 0;\n}\n\n/* 注册流程 */\n.register-process {\n  flex: 1;\n  margin: 20px 0;\n}\n\n.process-title {\n  font-size: 20px;\n  font-weight: 600;\n  margin-bottom: 30px;\n  position: relative;\n  display: inline-block;\n}\n\n.process-title:after {\n  content: '';\n  position: absolute;\n  bottom: -8px;\n  left: 0;\n  width: 50px;\n  height: 3px;\n  background-color: rgba(255, 255, 255, 0.6);\n  border-radius: 2px;\n}\n\n.process-item {\n  display: flex;\n  margin-bottom: 25px;\n}\n\n.process-step {\n  margin-right: 15px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.step-number {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.2);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 16px;\n  font-weight: bold;\n  margin-bottom: 8px;\n}\n\n.step-line {\n  width: 2px;\n  height: 40px;\n  background: rgba(255, 255, 255, 0.2);\n}\n\n.proce