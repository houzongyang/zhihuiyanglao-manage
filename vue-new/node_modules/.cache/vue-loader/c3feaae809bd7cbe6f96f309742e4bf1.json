m {\n  margin-bottom: 20px;\n}\n\n/* 修复图标对齐问题 */\n.input-icon-wrapper {\n  position: relative;\n}\n\n.input-icon-wrapper i.input-icon {\n  position: absolute;\n  left: 15px;\n  top: 50%;\n  transform: translateY(-50%);\n  font-size: 16px;\n  color: #bbb;\n  z-index: 2;\n  height: 16px;\n  width: 16px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  pointer-events: none; /* 防止图标干扰输入 */\n}\n\n.input-icon-wrapper .el-input__inner,\n.input-icon-wrapper .el-input input {\n  padding-left: 40px !important;\n}\n\n.custom-input input {\n  height: 40px;\n  font-size: 14px;\n  border-radius: 8px;\n}\n\n.custom-select {\n  width: 100%;\n}\n\n.custom-select .el-input input {\n  height: 40px;\n  font-size: 14px;\n  border-radius: 8px;\n}\n\n.option-content {\n  display: flex;\n  align-items: center;\n}\n\n.option-content i {\n  margin-right: 8px;\n  font-size: 16px;\n}\n\n.role-extra-fields {\n  padding: 10px 15px;\n  background-color: #f9f9f9;\n  border-radius: 8px;\n  margin-bottom: 20px;\n  box-shadow: inset 0 2px 6px rgba(0,0,0,0.05);\n  animation: fadeIn 0.3s;\n}\n\n@keyframes fadeIn {\n  from { opacity: 0; transform: translateY(-10px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n\n.submit-button {\n  width: 100%;\n  height: 40px;\n  border-radius: 8px;\n  font-size: 16px;\n  letter-spacing: 2px;\n  background: linear-gradient(135deg, #3f51b5, #2196f3);\n  border: none;\n  box-shadow: 0 4px 12px rgba(33, 150, 243, 0.3);\n  transition: all 0.3s;\n}\n\n.submit-button:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 6px 20px rgba(33, 150, 243, 0.4);\n}\n\n.form-footer {\n  text-align: center;\n  color: #888;\n  font-size: 14px;\n}\n\n.login-link {\n  color: #2196f3;\n  font-weight: 600;\n  text-decoration: none;\n}\n\n/* 响应式调整 */\n@media screen and (max-width: 768px) {\n  .register-container {\n    flex-direction: column;\n    height: auto;\n  }\n  \n  .left-section {\n    display: none;\n  }\n  \n  .right-section {\n    width: 