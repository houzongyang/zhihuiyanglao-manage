{"remainingRequest":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\front\\TextbookApplication.vue?vue&type=style&index=0&id=1196f62a&scoped=true&lang=css","dependencies":[{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\front\\TextbookApplication.vue","mtime":1753456219635},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\css-loader\\dist\\cjs.js","mtime":1753409944823},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1753409923452},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\postcss-loader\\src\\index.js","mtime":1753409944465},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["TextbookApplication.vue"],"names":[],"mappings":";AAu0BA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"TextbookApplication.vue","sourceRoot":"src/views/front","sourcesContent":["<template>\r\n  <div class=\"bg-gray-50 min-h-screen py-8\">\r\n    <div class=\"container mx-auto px-4 sm:px-6 lg:px-8\">\r\n      <!-- 页面头部 - 带有装饰性背景 -->\r\n      <div class=\"relative bg-gradient-to-r from-blue-500 to-indigo-600 rounded-xl shadow-lg mb-8 overflow-hidden\">\r\n        <div class=\"absolute inset-0 opacity-10\">\r\n          <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1440 320\" class=\"absolute bottom-0 left-0\">\r\n            <path fill=\"#FFFFFF\" fill-opacity=\"1\" d=\"M0,32L48,80C96,128,192,224,288,229.3C384,235,480,149,576,128C672,107,768,149,864,154.7C960,160,1056,128,1152,133.3C1248,139,1344,181,1392,202.7L1440,224L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z\"></path>\r\n          </svg>\r\n        </div>\r\n        <div class=\"relative px-8 py-10 flex justify-between items-center\">\r\n          <div>\r\n            <h1 class=\"text-3xl font-bold text-white mb-2\">我的教材申报</h1>\r\n            <p class=\"text-blue-100 max-w-2xl\">管理您的教材申请记录，跟踪审核进度和结果</p>\r\n          </div>\r\n          <el-button type=\"primary\" size=\"medium\" @click=\"handleAdd\" \r\n            class=\"bg-white text-blue-600 border-none hover:bg-blue-50 transform hover:-translate-y-1 transition-all duration-300 shadow-md\">\r\n            <i class=\"el-icon-plus mr-2\"></i>新增申报\r\n          </el-button>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 搜索和筛选区域 -->\r\n      <div class=\"bg-white rounded-xl shadow-md mb-8 transition-all duration-300 transform hover:shadow-lg border border-gray-100\">\r\n        <div class=\"p-5\">\r\n          <h2 class=\"flex items-center text-lg font-semibold text-gray-800 mb-4\">\r\n            <i class=\"el-icon-search text-blue-500 mr-2\"></i>筛选条件\r\n          </h2>\r\n          <div class=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\r\n            <div class=\"flex flex-col\">\r\n              <label class=\"text-xs font-medium text-gray-600 mb-1\">课程名称</label>\r\n              <el-input v-model=\"params.courseName\" placeholder=\"请输入课程名称\" prefix-icon=\"el-icon-notebook-1\" \r\n                clearable size=\"mini\" class=\"w-full\"></el-input>\r\n            </div>\r\n            <div class=\"flex flex-col\">\r\n              <label class=\"text-xs font-medium text-gray-600 mb-1\">学期</label>\r\n              <el-input v-model=\"params.semester\" placeholder=\"请输入学期\" prefix-icon=\"el-icon-date\" \r\n                clearable size=\"mini\" class=\"w-full\"></el-input>\r\n            </div>\r\n            <div class=\"flex flex-col\">\r\n              <label class=\"text-xs font-medium text-gray-600 mb-1\">审核状态</label>\r\n              <el-select v-model=\"params.status\" placeholder=\"全部状态\" clearable size=\"mini\" class=\"w-full\">\r\n                <el-option label=\"待审核\" :value=\"0\"></el-option>\r\n                <el-option label=\"已通过\" :value=\"1\"></el-option>\r\n                <el-option label=\"已驳回\" :value=\"2\"></el-option>\r\n              </el-select>\r\n            </div>\r\n            <div class=\"flex items-end\">\r\n              <el-button plain icon=\"el-icon-refresh-right\" size=\"mini\" @click=\"resetParams\" \r\n                class=\"mr-2 hover:bg-gray-50 hover:text-gray-700 transition-all\">重置</el-button>\r\n              <el-button type=\"primary\" icon=\"el-icon-search\" size=\"mini\" @click=\"loadData\"\r\n                class=\"hover:bg-blue-600 transition-colors duration-300\">查询</el-button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 统计概览卡片 -->\r\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 mb-8\">\r\n        <div class=\"bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500 transform hover:-translate-y-1 transition-all duration-300\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <h3 class=\"text-sm font-medium text-gray-500\">总申报数</h3>\r\n              <p class=\"text-2xl font-bold text-gray-800 mt-1\">{{ total }}</p>\r\n            </div>\r\n            <div class=\"h-12 w-12 rounded-full bg-blue-50 flex items-center justify-center\">\r\n              <i class=\"el-icon-document text-2xl text-blue-500\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500 transform hover:-translate-y-1 transition-all duration-300\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <h3 class=\"text-sm font-medium text-gray-500\">已通过</h3>\r\n              <p class=\"text-2xl font-bold text-gray-800 mt-1\">\r\n                {{ tableData.filter(item => item.status === 1).length }}\r\n              </p>\r\n            </div>\r\n            <div class=\"h-12 w-12 rounded-full bg-green-50 flex items-center justify-center\">\r\n              <i class=\"el-icon-check text-2xl text-green-500\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"bg-white rounded-xl shadow-md p-6 border-l-4 border-amber-500 transform hover:-translate-y-1 transition-all duration-300\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <h3 class=\"text-sm font-medium text-gray-500\">待审核</h3>\r\n              <p class=\"text-2xl font-bold text-gray-800 mt-1\">\r\n                {{ tableData.filter(item => item.status === 0).length }}\r\n              </p>\r\n            </div>\r\n            <div class=\"h-12 w-12 rounded-full bg-amber-50 flex items-center justify-center\">\r\n              <i class=\"el-icon-time text-2xl text-amber-500\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 申报记录区域 -->\r\n      <div class=\"bg-white rounded-xl shadow-md overflow-hidden transition-all duration-300\">\r\n        <div class=\"border-b border-gray-100 p-6\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <h2 class=\"flex items-center text-lg font-semibold text-gray-800\">\r\n              <i class=\"el-icon-document-copy text-blue-500 mr-2\"></i>申报记录\r\n            </h2>\r\n            <span class=\"text-sm text-gray-500 bg-gray-100 px-3 py-1 rounded-full\">{{ total }} 条记录</span>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 卡片式布局替代表格 -->\r\n        <div v-loading=\"loading\" \r\n          element-loading-text=\"加载中...\" \r\n          element-loading-spinner=\"el-icon-loading\"\r\n          element-loading-background=\"rgba(255, 255, 255, 0.8)\"\r\n          class=\"p-6\">\r\n          \r\n          <div v-if=\"tableData.length === 0\" class=\"flex flex-col items-center justify-center py-12\">\r\n            <i class=\"el-icon-document text-5xl text-gray-300 mb-4\"></i>\r\n            <p class=\"text-gray-500\">暂无申报记录</p>\r\n          </div>\r\n          \r\n          <div v-else class=\"space-y-6\">\r\n            <div v-for=\"item in tableData\" :key=\"item.id\" \r\n              class=\"bg-white border border-gray-100 rounded-lg shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden\">\r\n              <div class=\"p-5 border-b border-gray-50\">\r\n                <div class=\"flex flex-wrap items-start justify-between\">\r\n                  <div class=\"flex items-center\">\r\n                    <div class=\"w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center mr-3\">\r\n                      <i class=\"el-icon-notebook-1 text-blue-500\"></i>\r\n                    </div>\r\n                    <div>\r\n                      <h3 class=\"text-lg font-medium text-gray-800\">{{ item.textbook ? item.textbook.textbookName : (item.textbookName || '未知教材') }}</h3>\r\n                      <p class=\"text-sm text-gray-500\">申请ID: #{{ item.id }} · {{ item.courseName }}</p>\r\n                      <p v-if=\"item.textbook\" class=\"text-xs text-gray-400 mt-1\">\r\n                        {{ item.textbook.author }} · {{ item.textbook.publisher }}\r\n                      </p>\r\n                    </div>\r\n                  </div>\r\n                  <div class=\"flex items-center space-x-2 mt-2 md:mt-0\">\r\n                    <el-tag size=\"small\" v-if=\"item.status === 0\" type=\"info\" effect=\"plain\" class=\"rounded-full\">待审核</el-tag>\r\n                    <el-tag size=\"small\" v-else-if=\"item.status === 1\" type=\"success\" effect=\"plain\" class=\"rounded-full\">已通过</el-tag>\r\n                    <el-tag size=\"small\" v-else-if=\"item.status === 2\" type=\"danger\" effect=\"plain\" class=\"rounded-full\">已驳回</el-tag>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              \r\n              <div class=\"px-5 py-4\">\r\n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\r\n                  <div class=\"flex flex-col\">\r\n                    <span class=\"text-xs text-gray-500\">学期</span>\r\n                    <span class=\"font-medium text-gray-700\">{{ item.semester }}</span>\r\n                  </div>\r\n                  <div class=\"flex flex-col\">\r\n                    <span class=\"text-xs text-gray-500\">学年</span>\r\n                    <span class=\"font-medium text-gray-700\">{{ item.academicYear }}</span>\r\n                  </div>\r\n                  <div class=\"flex flex-col\">\r\n                    <span class=\"text-xs text-gray-500\">学生人数</span>\r\n                    <span class=\"font-medium text-gray-700\">{{ item.studentCount }} 人</span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              \r\n              <div class=\"bg-gray-50 px-5 py-3 flex items-center justify-between\">\r\n                <div class=\"text-sm text-gray-500\">\r\n                  <i class=\"el-icon-time mr-1\"></i>\r\n                  {{ item.createTime ? item.createTime.substring(0, 16).replace('T', ' ') : '' }}\r\n                </div>\r\n                <div class=\"flex items-center space-x-2\">\r\n                  <el-tooltip content=\"修改申报\" placement=\"top\" :hide-after=\"1000\" v-if=\"item.status === 0\">\r\n                    <el-button\r\n                      type=\"primary\"\r\n                      size=\"mini\"\r\n                      icon=\"el-icon-edit\"\r\n                      circle\r\n                      @click=\"handleEdit(item)\"\r\n                      class=\"transform hover:scale-105 transition-transform\"\r\n                    ></el-button>\r\n                  </el-tooltip>\r\n                  <el-tooltip content=\"撤销申报\" placement=\"top\" :hide-after=\"1000\" v-if=\"item.status === 0\">\r\n                    <el-button\r\n                      type=\"danger\"\r\n                      size=\"mini\"\r\n                      icon=\"el-icon-delete\"\r\n                      circle\r\n                      @click=\"handleDelete(item)\"\r\n                      class=\"transform hover:scale-105 transition-transform\"\r\n                    ></el-button>\r\n                  </el-tooltip>\r\n                  <el-tooltip content=\"查看详情\" placement=\"top\" :hide-after=\"1000\">\r\n                    <el-button\r\n                      type=\"info\"\r\n                      size=\"mini\"\r\n                      icon=\"el-icon-view\"\r\n                      circle\r\n                      @click=\"handleView(item)\"\r\n                      class=\"transform hover:scale-105 transition-transform\"\r\n                    ></el-button>\r\n                  </el-tooltip>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 分页 -->\r\n          <div class=\"flex justify-center mt-8\">\r\n            <el-pagination\r\n              background\r\n              @size-change=\"handleSizeChange\"\r\n              @current-change=\"handleCurrentChange\"\r\n              :current-page=\"params.pageNum\"\r\n              :page-sizes=\"[5, 10, 20, 50]\"\r\n              :page-size=\"params.pageSize\"\r\n              layout=\"total, sizes, prev, pager, next, jumper\"\r\n              :total=\"total\"\r\n              class=\"pagination-container\"\r\n            ></el-pagination>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- 新增/编辑对话框 -->\r\n    <el-dialog :title=\"form.id ? '编辑申报' : '新增申报'\" :visible.sync=\"dialogVisible\" width=\"650px\" destroy-on-close @open=\"handleDialogOpen\">\r\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"120px\" label-position=\"right\">\r\n        <div class=\"bg-gray-50 p-6 rounded-lg mb-5\">\r\n          <h3 class=\"flex items-center text-lg font-medium text-gray-800 mb-4\">\r\n            <i class=\"el-icon-notebook-1 text-blue-500 mr-2\"></i>教材信息\r\n          </h3>\r\n          <el-form-item label=\"教材选择\" prop=\"textbookId\">\r\n            <el-select \r\n              v-model=\"form.textbookId\" \r\n              filterable \r\n              remote \r\n              reserve-keyword\r\n              :remote-method=\"searchTextbooks\" \r\n              :loading=\"textbooksLoading\"\r\n              placeholder=\"请输入教材名称搜索\" \r\n              class=\"w-full\"\r\n              @focus=\"loadInitialTextbooks\"\r\n              @change=\"handleTextbookChange\"\r\n            >\r\n              <el-option \r\n                v-for=\"item in textbooks\" \r\n                :key=\"item.id\" \r\n                :label=\"item.textbookName + ' - ' + item.publisher\" \r\n                :value=\"item.id\"\r\n              >\r\n                <div class=\"flex justify-between\">\r\n                  <span>{{ item.textbookName }}</span>\r\n                  <span class=\"text-gray-500 text-xs\">{{ item.publisher }}</span>\r\n                </div>\r\n              </el-option>\r\n            </el-select>\r\n            \r\n            <!-- 所选教材信息卡片 -->\r\n            <div v-if=\"selectedTextbook\" class=\"mt-3 p-3 bg-blue-50 rounded-lg border border-blue-100\">\r\n              <div class=\"flex justify-between items-start\">\r\n                <div>\r\n                  <p class=\"font-medium text-blue-700\">{{ selectedTextbook.textbookName }}</p>\r\n                  <p class=\"text-xs text-gray-600 mt-1\">作者：{{ selectedTextbook.author || '未知' }}</p>\r\n                </div>\r\n                <div class=\"text-right\">\r\n                  <p class=\"text-xs text-gray-600\">出版社：{{ selectedTextbook.publisher || '未知' }}</p>\r\n                  <p class=\"text-xs text-gray-500 mt-1\">ISBN：{{ selectedTextbook.isbn || '未知' }}</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </el-form-item>\r\n        </div>\r\n\r\n        <div class=\"bg-gray-50 p-6 rounded-lg mb-5\">\r\n          <h3 class=\"flex items-center text-lg font-medium text-gray-800 mb-4\">\r\n            <i class=\"el-icon-collection text-green-500 mr-2\"></i>课程信息\r\n          </h3>\r\n          <el-form-item label=\"课程名称\" prop=\"courseName\">\r\n            <el-input v-model=\"form.courseName\" placeholder=\"请输入课程名称\" prefix-icon=\"el-icon-reading\"></el-input>\r\n          </el-form-item>\r\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n            <el-form-item label=\"学期\" prop=\"semester\">\r\n              <el-input v-model=\"form.semester\" placeholder=\"例如：2024春季\" prefix-icon=\"el-icon-date\"></el-input>\r\n            </el-form-item>\r\n            <el-form-item label=\"学年\" prop=\"academicYear\">\r\n              <el-input v-model=\"form.academicYear\" placeholder=\"例如：2023-2024\" prefix-icon=\"el-icon-calendar\"></el-input>\r\n            </el-form-item>\r\n          </div>\r\n          <el-form-item label=\"预计学生人数\" prop=\"studentCount\">\r\n            <el-input-number \r\n              v-model=\"form.studentCount\" \r\n              :min=\"1\" \r\n              :max=\"500\" \r\n              controls-position=\"right\"\r\n              class=\"w-full\"\r\n            ></el-input-number>\r\n          </el-form-item>\r\n        </div>\r\n\r\n        <div class=\"bg-gray-50 p-6 rounded-lg\">\r\n          <h3 class=\"flex items-center text-lg font-medium text-gray-800 mb-4\">\r\n            <i class=\"el-icon-document-checked text-amber-500 mr-2\"></i>申报信息\r\n          </h3>\r\n          <el-form-item label=\"申报理由\" prop=\"applicationReason\">\r\n            <el-input \r\n              type=\"textarea\" \r\n              v-model=\"form.applicationReason\" \r\n              placeholder=\"请输入申报理由\" \r\n              rows=\"4\"\r\n            ></el-input>\r\n          </el-form-item>\r\n        </div>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogVisible = false\" class=\"hover:bg-gray-100 transition-colors\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveForm\" :loading=\"submitLoading\" \r\n          class=\"hover:bg-blue-600 transition-colors\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n    \r\n    <!-- 详情对话框 -->\r\n    <el-dialog title=\"申报详情\" :visible.sync=\"detailVisible\" width=\"700px\" destroy-on-close>\r\n      <div v-if=\"detailForm\" class=\"px-2\" v-loading=\"detailLoading\" element-loading-text=\"加载详情...\" element-loading-background=\"rgba(255, 255, 255, 0.7)\">\r\n        <div class=\"flex mb-6\">\r\n          <div class=\"w-1/2\">\r\n            <el-tag \r\n              :type=\"detailForm.status === 0 ? 'info' : (detailForm.status === 1 ? 'success' : 'danger')\"\r\n              effect=\"dark\"\r\n              class=\"rounded-full\"\r\n            >\r\n              {{ detailForm.status === 0 ? '待审核' : (detailForm.status === 1 ? '已通过' : '已驳回') }}\r\n            </el-tag>\r\n          </div>\r\n          <div class=\"w-1/2 text-right text-gray-500 text-sm\">\r\n            <i class=\"el-icon-time mr-1\"></i>\r\n            申报时间：{{ detailForm.createTime ? detailForm.createTime.substring(0, 16).replace('T', ' ') : '' }}\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 教材信息卡片 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm mb-6 overflow-hidden border border-gray-100 hover:shadow-md transition-all duration-300\">\r\n          <div class=\"bg-gray-50 px-5 py-3 border-b border-gray-100\">\r\n            <div class=\"flex items-center text-lg font-medium text-gray-800\">\r\n              <i class=\"el-icon-notebook-1 text-blue-500 mr-2\"></i>教材信息\r\n            </div>\r\n          </div>\r\n          <div class=\"p-5\">\r\n            <!-- 有教材对象时显示完整信息 -->\r\n            <div v-if=\"detailForm.textbook\" class=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">教材名称：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.textbook.textbookName }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">出版社：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.textbook.publisher }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">作者：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.textbook.author }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">ISBN：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.textbook.isbn }}</span>\r\n              </div>\r\n            </div>\r\n            <!-- 没有教材对象但有教材名称时 -->\r\n            <div v-else-if=\"detailForm.textbookName\" class=\"grid grid-cols-1 gap-5\">\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">教材名称：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.textbookName }}</span>\r\n              </div>\r\n              <div v-if=\"detailForm.textbookId\" class=\"bg-gray-50 p-3 rounded-lg text-sm text-gray-500 mt-2\">\r\n                <i class=\"el-icon-loading mr-2\" v-if=\"!detailForm.textbook\"></i>\r\n                正在加载教材详细信息...\r\n              </div>\r\n            </div>\r\n            <!-- 完全没有教材信息时 -->\r\n            <div v-else class=\"text-gray-500 flex items-center\">\r\n              <i class=\"el-icon-info-circle mr-2 text-gray-400\"></i>\r\n              无教材信息\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 课程信息卡片 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm mb-6 overflow-hidden border border-gray-100 hover:shadow-md transition-all duration-300\">\r\n          <div class=\"bg-gray-50 px-5 py-3 border-b border-gray-100\">\r\n            <div class=\"flex items-center text-lg font-medium text-gray-800\">\r\n              <i class=\"el-icon-collection text-green-500 mr-2\"></i>课程信息\r\n            </div>\r\n          </div>\r\n          <div class=\"p-5\">\r\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">课程名称：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.courseName }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">学期：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.semester }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">学年：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.academicYear }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-600 font-medium w-24\">学生人数：</span>\r\n                <span class=\"text-gray-800\">{{ detailForm.studentCount }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 申报理由卡片 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm mb-6 overflow-hidden border border-gray-100 hover:shadow-md transition-all duration-300\">\r\n          <div class=\"bg-gray-50 px-5 py-3 border-b border-gray-100\">\r\n            <div class=\"flex items-center text-lg font-medium text-gray-800\">\r\n              <i class=\"el-icon-document-checked text-amber-500 mr-2\"></i>申报理由\r\n            </div>\r\n          </div>\r\n          <div class=\"p-5\">\r\n            <div class=\"bg-gray-50 p-4 rounded-lg min-h-[80px] text-gray-800\">\r\n              {{ detailForm.applicationReason || '无申报理由' }}\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 审核信息卡片 -->\r\n        <div v-if=\"detailForm.status !== 0\" class=\"bg-white rounded-xl shadow-sm overflow-hidden border border-gray-100 hover:shadow-md transition-all duration-300\">\r\n          <div class=\"bg-gray-50 px-5 py-3 border-b border-gray-100\">\r\n            <div class=\"flex items-center text-lg font-medium text-gray-800\">\r\n              <i class=\"el-icon-s-check text-indigo-500 mr-2\"></i>审核信息\r\n            </div>\r\n          </div>\r\n          <div class=\"p-5\">\r\n            <div class=\"flex mb-3\">\r\n              <span class=\"text-gray-600 font-medium w-24\">审核结果：</span>\r\n              <span>\r\n                <el-tag v-if=\"detailForm.status === 1\" type=\"success\" effect=\"dark\" size=\"small\" class=\"rounded-full\">已通过</el-tag>\r\n                <el-tag v-else-if=\"detailForm.status === 2\" type=\"danger\" effect=\"dark\" size=\"small\" class=\"rounded-full\">已驳回</el-tag>\r\n              </span>\r\n            </div>\r\n            <div class=\"flex mb-4\">\r\n              <span class=\"text-gray-600 font-medium w-24\">审核时间：</span>\r\n              <span class=\"text-gray-800\">{{ detailForm.auditTime ? detailForm.auditTime.substring(0, 16).replace('T', ' ') : '' }}</span>\r\n            </div>\r\n            <div class=\"mb-2\">\r\n              <span class=\"text-gray-600 font-medium\">审核意见：</span>\r\n            </div>\r\n            <div class=\"bg-gray-50 p-4 rounded-lg min-h-[80px] text-gray-800\">\r\n              {{ detailForm.auditOpinion || '无审核意见' }}\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"detailVisible = false\" class=\"hover:bg-gray-100 transition-colors\">关 闭</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"TextbookApplication\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(localStorage.getItem(\"xm-user\") || \"{}\"),\r\n      loading: false,\r\n      submitLoading: false,\r\n      textbooksLoading: false,\r\n      detailLoading: false,\r\n      tableData: [],\r\n      total: 0,\r\n      dialogVisible: false,\r\n      detailVisible: false,\r\n      textbooks: [],\r\n      selectedTextbook: null, // 用于存储当前选择的教材\r\n      params: {\r\n        userId: null,\r\n        courseName: '',\r\n        semester: '',\r\n        status: '',\r\n        pageNum: 1,\r\n        pageSize: 10\r\n      },\r\n      form: {\r\n        id: null,\r\n        userId: null,\r\n        textbookId: null,\r\n        courseName: '',\r\n        semester: '',\r\n        academicYear: '',\r\n        studentCount: 30,\r\n        applicationReason: '',\r\n        status: 0\r\n      },\r\n      detailForm: null,\r\n      rules: {\r\n        textbookId: [\r\n          { required: true, message: '请选择教材', trigger: 'change' }\r\n        ],\r\n        courseName: [\r\n          { required: true, message: '请输入课程名称', trigger: 'blur' },\r\n          { min: 2, max: 100, message: '长度在 2 到 100 个字符', trigger: 'blur' }\r\n        ],\r\n        semester: [\r\n          { required: true, message: '请输入学期', trigger: 'blur' }\r\n        ],\r\n        academicYear: [\r\n          { required: true, message: '请输入学年', trigger: 'blur' }\r\n        ],\r\n        studentCount: [\r\n          { required: true, message: '请输入学生人数', trigger: 'blur' }\r\n        ]\r\n      }\r\n    };\r\n  },\r\n  created() {\r\n    if (this.user && this.user.id) {\r\n      this.params.userId = this.user.id;\r\n      this.form.userId = this.user.id;\r\n      this.$nextTick(() => {\r\n        this.loadData();\r\n      });\r\n    } else {\r\n      // Handle case when user is not logged in\r\n      console.error(\"User not logged in or user ID not found\");\r\n      this.$message.warning(\"请先登录后再访问此页面\");\r\n      // You might want to redirect to login page\r\n      // this.$router.push(\"/login\");\r\n    }\r\n  },\r\n  methods: {\r\n    // 加载申报数据\r\n    loadData() {\r\n      this.loading = true;\r\n      console.log(\"Loading data with params:\", this.params);\r\n      \r\n      // Ensure userId is set\r\n      if (!this.params.userId && this.user && this.user.id) {\r\n        this.params.userId = this.user.id;\r\n      }\r\n      \r\n      this.$request.get(\"/textbookApplication/selectPage\", {\r\n        params: this.params\r\n      }).then(res => {\r\n        console.log(\"API Response:\", res);\r\n        if (res.code === '200') {\r\n          this.tableData = res.data.list || [];\r\n          this.total = res.data.total || 0;\r\n          \r\n          // 检查是否需要加载教材信息\r\n          this.tableData.forEach(item => {\r\n            if (item.textbookId && !item.textbook) {\r\n              // 尝试通过mapper返回的textbookName构建临时textbook对象\r\n              if (item.textbookName) {\r\n                item.textbook = {\r\n                  id: item.textbookId,\r\n                  textbookName: item.textbookName\r\n                };\r\n              }\r\n            }\r\n          });\r\n        } else {\r\n          this.$message.error(res.msg || '查询失败');\r\n        }\r\n      }).catch(error => {\r\n        console.error(\"加载数据出错\", error);\r\n        this.$message.error('网络错误，请稍后重试');\r\n      }).finally(() => {\r\n        this.loading = false;\r\n      });\r\n    },\r\n    \r\n    // 处理对话框打开\r\n    handleDialogOpen() {\r\n      this.loadInitialTextbooks();\r\n    },\r\n    \r\n    // 加载初始教材列表\r\n    loadInitialTextbooks() {\r\n      if (this.textbooks.length === 0) {\r\n        this.textbooksLoading = true;\r\n        this.$request.get(\"/textbook/selectPage\", {\r\n          params: {\r\n            pageNum: 1,\r\n            pageSize: 10,\r\n            status: 1\r\n          }\r\n        }).then(res => {\r\n          console.log(\"Initial textbooks response:\", res);\r\n          if (res.code === '200') {\r\n            this.textbooks = res.data.list || [];\r\n          } else {\r\n            this.$message.warning('加载教材列表失败');\r\n          }\r\n        }).catch(error => {\r\n          console.error(\"加载初始教材列表出错\", error);\r\n        }).finally(() => {\r\n          this.textbooksLoading = false;\r\n        });\r\n      }\r\n    },\r\n    \r\n    // 搜索教材\r\n    searchTextbooks(query) {\r\n      if (query === '') {\r\n        this.loadInitialTextbooks();\r\n        return;\r\n      }\r\n      \r\n      this.textbooksLoading = true;\r\n      this.$request.get(\"/textbook/selectPage\", {\r\n        params: {\r\n          textbookName: query,\r\n          pageNum: 1,\r\n          pageSize: 10,\r\n          status: 1\r\n        }\r\n      }).then(res => {\r\n        console.log(\"Search textbooks response:\", res);\r\n        if (res.code === '200') {\r\n          this.textbooks = res.data.list || [];\r\n          if (this.textbooks.length === 0) {\r\n            this.$message.info(`没有找到与\"${query}\"相关的教材`);\r\n          }\r\n        } else {\r\n          this.$message.warning(res.msg || '搜索教材失败');\r\n        }\r\n      }).catch(error => {\r\n        console.error(\"搜索教材出错\", error);\r\n        this.$message.error('搜索教材失败，请重试');\r\n      }).finally(() => {\r\n        this.textbooksLoading = false;\r\n      });\r\n    },\r\n    \r\n    // 处理教材选择变化\r\n    handleTextbookChange(textbookId) {\r\n      // 找到选中的教材\r\n      const selected = this.textbooks.find(item => item.id === textbookId);\r\n      if (selected) {\r\n        this.selectedTextbook = selected;\r\n      } else if (textbookId) {\r\n        // 如果没有找到但有ID，则尝试从后端获取\r\n        this.fetchTextbookById(textbookId);\r\n      } else {\r\n        this.selectedTextbook = null;\r\n      }\r\n    },\r\n    \r\n    // 重置搜索参数\r\n    resetParams() {\r\n      this.params = {\r\n        userId: this.user.id,\r\n        courseName: '',\r\n        semester: '',\r\n        status: '',\r\n        pageNum: 1,\r\n        pageSize: 10\r\n      };\r\n      this.loadData();\r\n    },\r\n    \r\n    // 处理分页大小变化\r\n    handleSizeChange(val) {\r\n      this.params.pageSize = val;\r\n      this.loadData();\r\n    },\r\n    \r\n    // 处理页码变化\r\n    handleCurrentChange(val) {\r\n      this.params.pageNum = val;\r\n      this.loadData();\r\n    },\r\n    \r\n    // 打开新增对话框\r\n    handleAdd() {\r\n      this.form = {\r\n        id: null,\r\n        userId: this.user.id,\r\n        textbookId: null,\r\n        courseName: '',\r\n        semester: '',\r\n        academicYear: '',\r\n        studentCount: 30,\r\n        applicationReason: '',\r\n        status: 0\r\n      };\r\n      this.selectedTextbook = null; // 重置选中的教材\r\n      this.dialogVisible = true;\r\n      // 重置表单验证\r\n      this.$nextTick(() => {\r\n        if (this.$refs.form) {\r\n          this.$refs.form.resetFields();\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 打开编辑对话框\r\n    handleEdit(row) {\r\n      this.$request.get(`/textbookApplication/selectById/${row.id}`).then(res => {\r\n        console.log(\"Edit application response:\", res);\r\n        if (res.code === '200' && res.data) {\r\n          this.form = { ...res.data };\r\n          this.dialogVisible = true;\r\n          \r\n          // Get textbook details to show in select\r\n          if (this.form.textbookId && res.data.textbook) {\r\n            // 直接使用返回的textbook对象\r\n            this.textbooks = [res.data.textbook];\r\n            this.selectedTextbook = res.data.textbook;\r\n          } else if (this.form.textbookId) {\r\n            // If textbookId exists but textbook object doesn't, fetch the textbook\r\n            this.fetchTextbookById(this.form.textbookId);\r\n          } else {\r\n            this.selectedTextbook = null;\r\n          }\r\n        } else {\r\n          this.$message.error(res.msg || '获取申报数据失败');\r\n        }\r\n      }).catch(error => {\r\n        console.error(\"获取申报详情出错\", error);\r\n        this.$message.error('获取申报数据失败，请重试');\r\n      });\r\n    },\r\n    \r\n    // 获取教材详情\r\n    fetchTextbookById(id) {\r\n      this.$request.get(`/textbook/selectById/${id}`).then(res => {\r\n        if (res.code === '200' && res.data) {\r\n          this.textbooks = [res.data];\r\n          // 更新选中的教材\r\n          this.selectedTextbook = res.data;\r\n        } else {\r\n          this.$message.warning('获取教材详情失败');\r\n          console.warn(\"获取教材详情失败\", res);\r\n        }\r\n      }).catch(error => {\r\n        console.error(\"获取教材详情出错\", error);\r\n        this.$message.error('获取教材详情出错，请重试');\r\n      });\r\n    },\r\n    \r\n    // 查看详情\r\n    handleView(row) {\r\n      this.detailLoading = true;\r\n      this.detailVisible = true;\r\n      \r\n      this.$request.get(`/textbookApplication/selectById/${row.id}`).then(res => {\r\n        console.log(\"View application response:\", res);\r\n        if (res.code === '200' && res.data) {\r\n          this.detailForm = res.data;\r\n          \r\n          // 如果没有textbook对象但有textbookId，单独获取教材信息\r\n          if (!this.detailForm.textbook && this.detailForm.textbookId) {\r\n            this.loadTextbookForDetail(this.detailForm.textbookId);\r\n          } else {\r\n            this.detailLoading = false;\r\n          }\r\n        } else {\r\n          this.detailLoading = false;\r\n          this.$message.error(res.msg || '获取申报详情失败');\r\n        }\r\n      }).catch(error => {\r\n        this.detailLoading = false;\r\n        console.error(\"获取申报详情出错\", error);\r\n        this.$message.error('获取申报详情失败，请重试');\r\n      });\r\n    },\r\n    \r\n    // 为详情加载教材信息\r\n    loadTextbookForDetail(textbookId) {\r\n      this.$request.get(`/textbook/selectById/${textbookId}`).then(res => {\r\n        if (res.code === '200' && res.data) {\r\n          // 将教材信息添加到detailForm中\r\n          this.$set(this.detailForm, 'textbook', res.data);\r\n        } else {\r\n          console.warn(\"获取教材详情失败\", res);\r\n        }\r\n      }).catch(error => {\r\n        console.error(\"获取教材详情出错\", error);\r\n      }).finally(() => {\r\n        this.detailLoading = false;\r\n      });\r\n    },\r\n    \r\n    // 删除/撤销\r\n    handleDelete(row) {\r\n      this.$confirm('确认撤销该申报记录?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        this.$request.delete(`/textbookApplication/delete/${row.id}`).then(res => {\r\n          if (res.code === '200') {\r\n            this.$message.success('撤销成功');\r\n            this.loadData();\r\n          } else {\r\n            this.$message.error(res.msg || '撤销失败');\r\n          }\r\n        });\r\n      }).catch(() => {});\r\n    },\r\n    \r\n    // 保存表单\r\n    saveForm() {\r\n      this.$refs.form.validate(valid => {\r\n        if (valid) {\r\n          this.submitLoading = true;\r\n          const url = this.form.id ? '/textbookApplication/update' : '/textbookApplication/add';\r\n          const method = this.form.id ? 'put' : 'post';\r\n          \r\n          this.$request[method](url, this.form)\r\n            .then(res => {\r\n              if (res.code === '200') {\r\n                this.$message.success(this.form.id ? '修改成功' : '申报成功');\r\n                this.dialogVisible = false;\r\n                this.loadData();\r\n              } else {\r\n                this.$message.error(res.msg || (this.form.id ? '修改失败' : '申报失败'));\r\n              }\r\n            })\r\n            .catch(() => {\r\n              this.$message.error('操作失败，请重试');\r\n            })\r\n            .finally(() => {\r\n              this.submitLoading = false;\r\n            });\r\n        }\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* 添加自定义样式 */\r\n.el-button {\r\n  transition: all 0.3s ease;\r\n  border-radius: 6px;\r\n}\r\n\r\n.el-tag {\r\n  font-weight: 600;\r\n}\r\n\r\n.el-table {\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n}\r\n\r\n/* 表格高亮效果 */\r\n.el-table tr:hover > td {\r\n  background-color: #f8fafc !important;\r\n}\r\n\r\n/* 对话框样式 */\r\n:deep(.el-dialog__header) {\r\n  border-bottom: 1px solid #edf2f7;\r\n  padding: 16px 20px;\r\n}\r\n\r\n:deep(.el-dialog__body) {\r\n  padding: 20px;\r\n}\r\n\r\n:deep(.el-dialog__footer) {\r\n  border-top: 1px solid #edf2f7;\r\n  padding: 12px 20px;\r\n}\r\n\r\n/* 自定义按钮组 */\r\n.pagination-container {\r\n  margin: 10px 0;\r\n}\r\n\r\n/* 动画效果 */\r\n.fade-enter-active, .fade-leave-active {\r\n  transition: opacity 0.3s;\r\n}\r\n.fade-enter, .fade-leave-to {\r\n  opacity: 0;\r\n}\r\n\r\n/* 表单美化 */\r\n:deep(.el-form-item__label) {\r\n  font-weight: 500;\r\n  color: #4a5568;\r\n}\r\n\r\n:deep(.el-input__inner) {\r\n  border-radius: 6px;\r\n}\r\n\r\n/* 卡片悬停效果 */\r\n.card-hover {\r\n  transition: all 0.3s ease;\r\n}\r\n.card-hover:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);\r\n}\r\n</style>"]}]}