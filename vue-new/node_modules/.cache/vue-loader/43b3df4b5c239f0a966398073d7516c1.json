{"remainingRequest":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\manager\\Textbook.vue?vue&type=style&index=1&id=7b3419f2&scoped=true&lang=css","dependencies":[{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\manager\\Textbook.vue","mtime":1753500145977},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\css-loader\\dist\\cjs.js","mtime":1753409944823},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1753409923452},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\postcss-loader\\src\\index.js","mtime":1753409944465},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Textbook.vue"],"names":[],"mappings":";AA4xBA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"Textbook.vue","sourceRoot":"src/views/manager","sourcesContent":["<template>\r\n  <div>\r\n    <!-- 功能说明 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm p-6 mb-5\">\r\n      <div class=\"flex items-center\">\r\n        <i class=\"el-icon-reading text-3xl text-blue-500 mr-3\"></i>\r\n        <div>\r\n          <h2 class=\"text-xl font-bold text-gray-800 mb-1\">教材信息管理</h2>\r\n          <p class=\"text-gray-600\">本模块用于管理教材库中的教材信息，提供教材信息的增加、修改、删除和查询功能</p>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 搜索和操作区域 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm p-6 mb-5\">\r\n      <el-form :inline=\"true\" :model=\"searchForm\" ref=\"searchForm\">\r\n        <el-form-item>\r\n          <el-input \r\n            v-model=\"searchForm.textbookName\" \r\n            placeholder=\"请输入教材名称\" \r\n            prefix-icon=\"el-icon-reading\" \r\n            clearable\r\n            size=\"small\"\r\n          ></el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-input \r\n            v-model=\"searchForm.author\" \r\n            placeholder=\"请输入作者\" \r\n            prefix-icon=\"el-icon-user\" \r\n            clearable\r\n            size=\"small\"\r\n          ></el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-input \r\n            v-model=\"searchForm.publisher\" \r\n            placeholder=\"请输入出版社\" \r\n            prefix-icon=\"el-icon-office-building\" \r\n            clearable\r\n            size=\"small\"\r\n          ></el-input>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-select v-model=\"searchForm.categoryId\" placeholder=\"请选择分类\" clearable size=\"small\">\r\n            <el-option label=\"全部分类\" value=\"\"></el-option>\r\n            <el-option\r\n              v-for=\"category in categories\"\r\n              :key=\"category.id\"\r\n              :label=\"category.categoryName\"\r\n              :value=\"category.id\"\r\n            ></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\" icon=\"el-icon-search\" size=\"small\" class=\"mr-2\">查询</el-button>\r\n          <el-button @click=\"resetSearch\" icon=\"el-icon-refresh\" size=\"small\" class=\"mr-2\">重置</el-button>\r\n          <el-button type=\"success\" @click=\"queryAllTextbooks\" icon=\"el-icon-menu\" size=\"small\" class=\"mr-2\">查询全部</el-button>\r\n          <el-button type=\"primary\" @click=\"handleAdd\" icon=\"el-icon-plus\" size=\"small\" class=\"mr-2\">添加教材</el-button>\r\n          <el-button type=\"warning\" @click=\"exportToExcel\" icon=\"el-icon-download\" size=\"small\" class=\"mr-2\">\r\n            {{ selection.length > 0 ? '导出选中' : '导出全部' }}\r\n          </el-button>\r\n          <el-button type=\"danger\" @click=\"handleBatchDelete\" :disabled=\"selection.length === 0\" icon=\"el-icon-delete\" size=\"small\">\r\n            批量删除\r\n          </el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n\r\n    <!-- 教材表格 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm overflow-hidden mb-5\">\r\n      <el-table\r\n        :data=\"tableData\"\r\n        style=\"width: 100%\"\r\n        v-loading=\"loading\"\r\n        @selection-change=\"handleSelectionChange\"\r\n        :border=\"false\"\r\n        stripe\r\n        :cell-style=\"{padding: '16px 0'}\"\r\n        :header-cell-style=\"{background:'#f8fafc', color:'#475569', fontWeight: '600'}\"\r\n      >\r\n        <el-table-column type=\"selection\" width=\"55\"></el-table-column>\r\n        <el-table-column prop=\"id\" label=\"ID\" width=\"80\"></el-table-column>\r\n        <el-table-column label=\"封面\" width=\"80\" align=\"center\">\r\n          <template slot-scope=\"scope\">\r\n            <el-image\r\n              style=\"width: 50px; height: 60px\"\r\n              :src=\"scope.row.coverImage || 'https://via.placeholder.com/50x60?text=暂无封面'\"\r\n              fit=\"cover\"\r\n              :preview-src-list=\"scope.row.coverImage ? [scope.row.coverImage] : []\"\r\n            ></el-image>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"textbookName\" label=\"教材名称\" min-width=\"150\" show-overflow-tooltip></el-table-column>\r\n        <el-table-column prop=\"textbookCode\" label=\"教材编码\" min-width=\"120\"></el-table-column>\r\n        <el-table-column prop=\"author\" label=\"作者\" min-width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"publisher\" label=\"出版社\" min-width=\"120\" show-overflow-tooltip></el-table-column>\r\n        <el-table-column prop=\"isbn\" label=\"ISBN\" min-width=\"130\"></el-table-column>\r\n        <el-table-column prop=\"edition\" label=\"版次\" width=\"80\"></el-table-column>\r\n        <el-table-column prop=\"price\" label=\"价格\" width=\"100\">\r\n          <template slot-scope=\"scope\">\r\n            <span class=\"text-red-500 font-medium\">¥{{ scope.row.price }}</span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"categoryName\" label=\"分类\" min-width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"stockQuantity\" label=\"库存\" width=\"80\">\r\n          <template slot-scope=\"scope\">\r\n            <el-tag :type=\"scope.row.stockQuantity > 10 ? 'success' : scope.row.stockQuantity > 0 ? 'warning' : 'danger'\">\r\n              {{ scope.row.stockQuantity }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"status\" label=\"状态\" width=\"80\">\r\n          <template slot-scope=\"scope\">\r\n            <el-tag :type=\"scope.row.status === 1 ? 'success' : 'danger'\">\r\n              {{ scope.row.status === 1 ? '启用' : '禁用' }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" fixed=\"right\" width=\"180\" align=\"center\">\r\n          <template slot-scope=\"scope\">\r\n            <div class=\"flex justify-center space-x-2\">\r\n              <el-button type=\"primary\" size=\"mini\" icon=\"el-icon-edit\" circle @click=\"handleEdit(scope.row)\" class=\"transform hover:-translate-y-1 transition-transform\"></el-button>\r\n              <el-button type=\"info\" size=\"mini\" icon=\"el-icon-view\" circle @click=\"handleDetail(scope.row)\" class=\"transform hover:-translate-y-1 transition-transform\"></el-button>\r\n              <el-button type=\"danger\" size=\"mini\" icon=\"el-icon-delete\" circle @click=\"handleDelete(scope.row)\" class=\"transform hover:-translate-y-1 transition-transform\"></el-button>\r\n            </div>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </div>\r\n\r\n    <!-- 分页组件 -->\r\n    <div class=\"bg-white rounded-lg shadow-sm p-4 flex justify-end\">\r\n      <el-pagination\r\n        @size-change=\"handleSizeChange\"\r\n        @current-change=\"handleCurrentChange\"\r\n        :current-page=\"pageNum\"\r\n        :page-sizes=\"[10, 20, 50, 100]\"\r\n        :page-size=\"pageSize\"\r\n        layout=\"total, sizes, prev, pager, next, jumper\"\r\n        :total=\"total\"\r\n        background\r\n      ></el-pagination>\r\n    </div>\r\n\r\n    <!-- 添加/编辑教材对话框 -->\r\n    <el-dialog :title=\"dialogTitle\" :visible.sync=\"dialogVisible\" width=\"900px\" :close-on-click-modal=\"false\" custom-class=\"rounded-lg\">\r\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"100px\">\r\n        <el-row :gutter=\"30\">\r\n          <el-col :span=\"16\">\r\n            <!-- 左侧表单 -->\r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"教材名称\" prop=\"textbookName\">\r\n                  <el-input v-model=\"form.textbookName\" placeholder=\"请输入教材名称\" prefix-icon=\"el-icon-reading\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"教材编码\" prop=\"textbookCode\">\r\n                  <el-input v-model=\"form.textbookCode\" placeholder=\"请输入教材编码\" prefix-icon=\"el-icon-postcard\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"作者\" prop=\"author\">\r\n                  <el-input v-model=\"form.author\" placeholder=\"请输入作者\" prefix-icon=\"el-icon-user\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"出版社\" prop=\"publisher\">\r\n                  <el-input v-model=\"form.publisher\" placeholder=\"请输入出版社\" prefix-icon=\"el-icon-office-building\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"ISBN\" prop=\"isbn\">\r\n                  <el-input v-model=\"form.isbn\" placeholder=\"请输入ISBN\" prefix-icon=\"el-icon-postcard\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"版次\" prop=\"edition\">\r\n                  <el-input v-model=\"form.edition\" placeholder=\"请输入版次\" prefix-icon=\"el-icon-document\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"出版日期\" prop=\"publishDate\">\r\n                  <el-date-picker\r\n                    v-model=\"form.publishDate\"\r\n                    type=\"date\"\r\n                    placeholder=\"选择出版日期\"\r\n                    style=\"width: 100%\"\r\n                    format=\"yyyy-MM-dd\"\r\n                    value-format=\"yyyy-MM-dd\"\r\n                  ></el-date-picker>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"价格\" prop=\"price\">\r\n                  <el-input-number v-model=\"form.price\" :precision=\"2\" :min=\"0\" placeholder=\"请输入价格\" style=\"width: 100%\"></el-input-number>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"分类\" prop=\"categoryId\">\r\n                  <el-select v-model=\"form.categoryId\" placeholder=\"请选择分类\" style=\"width: 100%\">\r\n                    <el-option\r\n                      v-for=\"category in categories\"\r\n                      :key=\"category.id\"\r\n                      :label=\"category.categoryName\"\r\n                      :value=\"category.id\"\r\n                    ></el-option>\r\n                  </el-select>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"12\">\r\n                <el-form-item label=\"库存数量\" prop=\"stockQuantity\">\r\n                  <el-input-number v-model=\"form.stockQuantity\" :min=\"0\" placeholder=\"请输入库存数量\" style=\"width: 100%\"></el-input-number>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"24\">\r\n                <el-form-item label=\"状态\" prop=\"status\">\r\n                  <el-radio-group v-model=\"form.status\">\r\n                    <el-radio :label=\"1\">启用</el-radio>\r\n                    <el-radio :label=\"0\">禁用</el-radio>\r\n                  </el-radio-group>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"24\">\r\n                <el-form-item label=\"教材描述\" prop=\"description\">\r\n                  <el-input v-model=\"form.description\" type=\"textarea\" :rows=\"3\" placeholder=\"请输入教材描述\"></el-input>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n          </el-col>\r\n          \r\n          <el-col :span=\"8\">\r\n            <!-- 右侧封面 -->\r\n            <div class=\"flex flex-col items-center\">\r\n              <p class=\"mb-3 text-gray-700 font-medium\">教材封面</p>\r\n              <el-form-item prop=\"coverImage\" class=\"w-full\">\r\n                <el-upload\r\n                  class=\"cover-uploader\"\r\n                  :action=\"$baseUrl + '/files/upload'\"\r\n                  :headers=\"{ token: getToken() }\"\r\n                  :show-file-list=\"false\"\r\n                  :on-success=\"handleCoverSuccess\"\r\n                  :before-upload=\"beforeCoverUpload\">\r\n                  <div v-if=\"form.coverImage\" class=\"cover-preview\">\r\n                    <img :src=\"form.coverImage\" class=\"cover\">\r\n                    <div class=\"cover-hover-mask\">\r\n                      <i class=\"el-icon-edit text-xl mb-1\"></i>\r\n                      <span class=\"text-sm\">更换封面</span>\r\n                    </div>\r\n                  </div>\r\n                  <div v-else class=\"cover-upload-btn\">\r\n                    <i class=\"el-icon-plus text-2xl mb-1\"></i>\r\n                    <span class=\"text-sm\">上传封面</span>\r\n                  </div>\r\n                </el-upload>\r\n              </el-form-item>\r\n              <p class=\"text-xs text-gray-500\">支持JPG、PNG、GIF格式，大小不超过2MB</p>\r\n            </div>\r\n          </el-col>\r\n        </el-row>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"flex justify-end space-x-3\">\r\n        <el-button @click=\"dialogVisible = false\" icon=\"el-icon-close\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"saveTextbook\" :loading=\"submitLoading\" icon=\"el-icon-check\">确 定</el-button>\r\n      </div>\r\n    </el-dialog>\r\n\r\n    <!-- 教材详情对话框 -->\r\n    <el-dialog title=\"教材详情\" :visible.sync=\"detailDialogVisible\" width=\"700px\" custom-class=\"rounded-lg\">\r\n      <div v-if=\"currentTextbook\" class=\"px-5\">\r\n        <div class=\"flex mb-6\">\r\n          <div class=\"mr-6\">\r\n            <el-image\r\n              style=\"width: 120px; height: 150px\"\r\n              :src=\"currentTextbook.coverImage || 'https://via.placeholder.com/120x150?text=暂无封面'\"\r\n              fit=\"cover\"\r\n              :preview-src-list=\"currentTextbook.coverImage ? [currentTextbook.coverImage] : []\"\r\n            ></el-image>\r\n          </div>\r\n          <div class=\"flex-1\">\r\n            <h3 class=\"text-xl font-bold text-gray-800 mb-2\">{{ currentTextbook.textbookName }}</h3>\r\n            <p class=\"text-gray-600 mb-1\">作者：{{ currentTextbook.author }}</p>\r\n            <p class=\"text-gray-600 mb-1\">出版社：{{ currentTextbook.publisher }}</p>\r\n            <p class=\"text-gray-600 mb-1\">ISBN：{{ currentTextbook.isbn }}</p>\r\n            <p class=\"text-red-500 font-medium text-lg\">价格：¥{{ currentTextbook.price }}</p>\r\n          </div>\r\n        </div>\r\n        \r\n        <el-divider></el-divider>\r\n        \r\n        <div class=\"space-y-6\">\r\n          <div class=\"bg-gray-50 rounded-lg p-4\">\r\n            <h4 class=\"flex items-center text-gray-700 font-medium mb-3\">\r\n              <i class=\"el-icon-reading text-blue-500 mr-2\"></i> 基本信息\r\n            </h4>\r\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">教材ID:</span>\r\n                <span class=\"text-gray-800\">{{ currentTextbook.id }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">教材编码:</span>\r\n                <span class=\"text-gray-800\">{{ currentTextbook.textbookCode }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">版次:</span>\r\n                <span class=\"text-gray-800\">{{ currentTextbook.edition || '未设置' }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">出版日期:</span>\r\n                <span class=\"text-gray-800\">{{ currentTextbook.publishDate || '未设置' }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">分类:</span>\r\n                <span class=\"text-gray-800\">{{ currentTextbook.categoryName || '未分类' }}</span>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">库存:</span>\r\n                <el-tag :type=\"currentTextbook.stockQuantity > 10 ? 'success' : currentTextbook.stockQuantity > 0 ? 'warning' : 'danger'\">\r\n                  {{ currentTextbook.stockQuantity }}\r\n                </el-tag>\r\n              </div>\r\n              <div class=\"flex\">\r\n                <span class=\"text-gray-500 w-24\">状态:</span>\r\n                <el-tag :type=\"currentTextbook.status === 1 ? 'success' : 'danger'\">\r\n                  {{ currentTextbook.status === 1 ? '启用' : '禁用' }}\r\n                </el-tag>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          <div v-if=\"currentTextbook.description\" class=\"bg-gray-50 rounded-lg p-4\">\r\n            <h4 class=\"flex items-center text-gray-700 font-medium mb-3\">\r\n              <i class=\"el-icon-document text-green-500 mr-2\"></i> 教材描述\r\n            </h4>\r\n            <p class=\"text-gray-800 leading-relaxed\">{{ currentTextbook.description }}</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div slot=\"footer\" class=\"flex justify-end space-x-3\">\r\n        <el-button @click=\"detailDialogVisible = false\" icon=\"el-icon-close\">关 闭</el-button>\r\n        <el-button type=\"primary\" @click=\"handleEdit(currentTextbook)\" icon=\"el-icon-edit\">编辑信息</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport * as XLSX from 'xlsx';\r\n\r\nexport default {\r\n  name: \"TextbookManage\",\r\n  data() {\r\n    return {\r\n      // 搜索表单\r\n      searchForm: {\r\n        textbookName: \"\",\r\n        author: \"\",\r\n        publisher: \"\",\r\n        categoryId: \"\",\r\n      },\r\n      // 表格数据\r\n      tableData: [],\r\n      loading: false,\r\n      total: 0,\r\n      pageNum: 1,\r\n      pageSize: 10,\r\n      \r\n      // 选中项\r\n      selection: [],\r\n      \r\n      // 分类数据\r\n      categories: [],\r\n      \r\n      // 对话框\r\n      dialogVisible: false,\r\n      dialogTitle: \"添加教材\",\r\n      isEdit: false,\r\n      submitLoading: false,\r\n      \r\n      // 详情对话框\r\n      detailDialogVisible: false,\r\n      currentTextbook: null,\r\n      \r\n      // 表单\r\n      form: {\r\n        id: null,\r\n        textbookName: \"\",\r\n        textbookCode: \"\",\r\n        author: \"\",\r\n        publisher: \"\",\r\n        isbn: \"\",\r\n        edition: \"\",\r\n        publishDate: \"\",\r\n        price: null,\r\n        categoryId: null,\r\n        description: \"\",\r\n        coverImage: \"\",\r\n        status: 1,\r\n        stockQuantity: 0\r\n      },\r\n      \r\n      // 表单验证规则\r\n      rules: {\r\n        textbookName: [\r\n          { required: true, message: \"请输入教材名称\", trigger: \"blur\" }\r\n        ],\r\n        textbookCode: [\r\n          { required: true, message: \"请输入教材编码\", trigger: \"blur\" }\r\n        ],\r\n        author: [\r\n          { required: true, message: \"请输入作者\", trigger: \"blur\" }\r\n        ],\r\n        publisher: [\r\n          { required: true, message: \"请输入出版社\", trigger: \"blur\" }\r\n        ],\r\n        isbn: [\r\n          { required: true, message: \"请输入ISBN\", trigger: \"blur\" }\r\n        ],\r\n        price: [\r\n          { required: true, message: \"请输入价格\", trigger: \"blur\" }\r\n        ],\r\n        categoryId: [\r\n          { required: true, message: \"请选择分类\", trigger: \"change\" }\r\n        ],\r\n        stockQuantity: [\r\n          { required: true, message: \"请输入库存数量\", trigger: \"blur\" }\r\n        ]\r\n      }\r\n    };\r\n  },\r\n  created() {\r\n    this.fetchData();\r\n    this.loadCategories();\r\n  },\r\n  methods: {\r\n    // 获取数据\r\n    fetchData() {\r\n      this.loading = true;\r\n      \r\n      // 构建请求参数\r\n      const params = {\r\n        pageNum: this.pageNum,\r\n        pageSize: this.pageSize\r\n      };\r\n      \r\n      // 只有当搜索表单中有值时才添加到请求参数中\r\n      if (this.searchForm.textbookName) {\r\n        params.textbookName = this.searchForm.textbookName;\r\n      }\r\n      \r\n      if (this.searchForm.author) {\r\n        params.author = this.searchForm.author;\r\n      }\r\n      \r\n      if (this.searchForm.publisher) {\r\n        params.publisher = this.searchForm.publisher;\r\n      }\r\n      \r\n      if (this.searchForm.categoryId) {\r\n        params.categoryId = this.searchForm.categoryId;\r\n      }\r\n      \r\n      this.$request.get(\"/textbook/selectPage\", { params })\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.tableData = res.data.list || [];\r\n            this.total = res.data.total || 0;\r\n          } else {\r\n            this.$message.error(res.msg || \"获取教材数据失败\");\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"获取教材数据异常\");\r\n        })\r\n        .finally(() => {\r\n          this.loading = false;\r\n        });\r\n    },\r\n    \r\n    // 加载分类数据\r\n    loadCategories() {\r\n      this.$request.get(\"/textbookCategory/selectAll\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.categories = res.data || [];\r\n          }\r\n        })\r\n        .catch(() => {\r\n          this.$message.error(\"获取分类数据异常\");\r\n        });\r\n    },\r\n    \r\n    // 查询\r\n    handleSearch() {\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 重置查询\r\n    resetSearch() {\r\n      // 清除搜索表单\r\n      this.$refs.searchForm.resetFields();\r\n      this.pageNum = 1;\r\n      // 重新加载所有数据\r\n      this.fetchData();\r\n      this.$message.success(\"已重置搜索条件，显示所有教材数据\");\r\n    },\r\n    \r\n    // 查询全部教材\r\n    queryAllTextbooks() {\r\n      // 清除搜索表单\r\n      this.$refs.searchForm.resetFields();\r\n      this.pageNum = 1;\r\n      this.fetchData();\r\n      this.$message.success(\"已显示所有教材数据\");\r\n    },\r\n    \r\n    // 分页相关\r\n    handleSizeChange(val) {\r\n      this.pageSize = val;\r\n      this.fetchData();\r\n    },\r\n    \r\n    handleCurrentChange(val) {\r\n      this.pageNum = val;\r\n      this.fetchData();\r\n    },\r\n    \r\n    // 表格选中项变化\r\n    handleSelectionChange(selection) {\r\n      this.selection = selection;\r\n    },\r\n    \r\n    // 添加教材\r\n    handleAdd() {\r\n      this.dialogTitle = \"添加教材\";\r\n      this.isEdit = false;\r\n      this.form = {\r\n        id: null,\r\n        textbookName: \"\",\r\n        textbookCode: \"\",\r\n        author: \"\",\r\n        publisher: \"\",\r\n        isbn: \"\",\r\n        edition: \"\",\r\n        publishDate: \"\",\r\n        price: null,\r\n        categoryId: null,\r\n        description: \"\",\r\n        coverImage: \"\",\r\n        status: 1,\r\n        stockQuantity: 0\r\n      };\r\n      this.dialogVisible = true;\r\n      \r\n      // 清除验证\r\n      this.$nextTick(() => {\r\n        if (this.$refs.form) {\r\n          this.$refs.form.clearValidate();\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 编辑教材\r\n    handleEdit(row) {\r\n      this.dialogTitle = \"编辑教材\";\r\n      this.isEdit = true;\r\n      this.form = JSON.parse(JSON.stringify(row)); // 深拷贝，防止直接修改表格数据\r\n      this.dialogVisible = true;\r\n      \r\n      // 清除验证\r\n      this.$nextTick(() => {\r\n        if (this.$refs.form) {\r\n          this.$refs.form.clearValidate();\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 查看详情\r\n    handleDetail(row) {\r\n      this.currentTextbook = row;\r\n      this.detailDialogVisible = true;\r\n    },\r\n    \r\n    // 保存教材（添加或更新）\r\n    saveTextbook() {\r\n      this.$refs.form.validate(valid => {\r\n        if (valid) {\r\n          this.submitLoading = true;\r\n          \r\n          const request = this.isEdit \r\n            ? this.$request.put(\"/textbook/update\", this.form)\r\n            : this.$request.post(\"/textbook/add\", this.form);\r\n            \r\n          request.then(res => {\r\n              if (res.code === '200') {\r\n                this.$message.success(this.isEdit ? \"编辑成功\" : \"添加成功\");\r\n                this.dialogVisible = false;\r\n                this.fetchData();\r\n              } else {\r\n                this.$message.error(res.msg || (this.isEdit ? \"编辑失败\" : \"添加失败\"));\r\n              }\r\n            })\r\n            .catch(() => {\r\n              this.$message.error(this.isEdit ? \"编辑教材请求异常\" : \"添加教材请求异常\");\r\n            })\r\n            .finally(() => {\r\n              this.submitLoading = false;\r\n            });\r\n        }\r\n      });\r\n    },\r\n    \r\n    // 删除教材\r\n    handleDelete(row) {\r\n      this.$confirm(\"确定删除该教材吗?\", \"提示\", {\r\n        confirmButtonText: \"确定\",\r\n        cancelButtonText: \"取消\",\r\n        type: \"warning\"\r\n      }).then(() => {\r\n        this.$request.delete(`/textbook/delete/${row.id}`)\r\n          .then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success(\"删除成功\");\r\n              this.fetchData();\r\n            } else {\r\n              this.$message.error(res.msg || \"删除失败\");\r\n            }\r\n          })\r\n          .catch(() => {\r\n            this.$message.error(\"删除教材请求异常\");\r\n          });\r\n      }).catch(() => {});\r\n    },\r\n    \r\n    // 批量删除\r\n    handleBatchDelete() {\r\n      if (this.selection.length === 0) {\r\n        this.$message.warning(\"请选择要删除的教材\");\r\n        return;\r\n      }\r\n      \r\n      this.$confirm(`确定删除选中的 ${this.selection.length} 个教材吗?`, \"提示\", {\r\n        confirmButtonText: \"确定\",\r\n        cancelButtonText: \"取消\",\r\n        type: \"warning\"\r\n      }).then(() => {\r\n        const ids = this.selection.map(item => item.id);\r\n        \r\n        this.$request.delete(\"/textbook/delete/batch\", { data: ids })\r\n          .then(res => {\r\n            if (res.code === '200') {\r\n              this.$message.success(\"批量删除成功\");\r\n              this.fetchData();\r\n            } else {\r\n              this.$message.error(res.msg || \"批量删除失败\");\r\n            }\r\n          })\r\n          .catch(() => {\r\n            this.$message.error(\"批量删除教材请求异常\");\r\n          });\r\n      }).catch(() => {});\r\n    },\r\n\r\n    // 封面上传成功\r\n    handleCoverSuccess(response) {\r\n      // 根据后台API响应格式处理\r\n      if (response.code === '200') {\r\n        // 根据实际后台返回格式调整\r\n        this.form.coverImage = response.data;\r\n        // 如果后台返回的是对象且包含url字段\r\n        if (typeof response.data === 'object' && response.data.url) {\r\n          this.form.coverImage = response.data.url;\r\n        }\r\n        this.$message.success('封面上传成功');\r\n      } else {\r\n        this.$message.error(response.msg || '封面上传失败');\r\n      }\r\n    },\r\n\r\n    // 获取用户token\r\n    getToken() {\r\n      // 从localStorage中获取token\r\n      const userInfo = JSON.parse(localStorage.getItem('xm-user') || '{}');\r\n      return userInfo.token || '';\r\n    },\r\n\r\n    // 封面上传前校验\r\n    beforeCoverUpload(file) {\r\n      const isJPG = file.type === 'image/jpeg' || file.type === 'image/png' || file.type === 'image/gif';\r\n      const isLt2M = file.size / 1024 / 1024 < 2;\r\n\r\n      if (!isJPG) {\r\n        this.$message.error('上传封面图片只能是 JPG、PNG、GIF 格式!');\r\n      }\r\n      if (!isLt2M) {\r\n        this.$message.error('上传封面图片大小不能超过 2MB!');\r\n      }\r\n      return isJPG && isLt2M;\r\n    },\r\n    \r\n    // 导出Excel功能\r\n    exportToExcel() {\r\n      const dataToExport = this.selection.length > 0 ? this.selection : this.tableData;\r\n      \r\n      if (dataToExport.length === 0) {\r\n        this.$message.warning('暂无数据可导出');\r\n        return;\r\n      }\r\n      \r\n      try {\r\n        // 准备导出数据\r\n        const exportData = dataToExport.map((item, index) => {\r\n          return {\r\n            '序号': index + 1,\r\n            'ID': item.id,\r\n            '教材名称': item.textbookName,\r\n            '教材编码': item.textbookCode,\r\n            '作者': item.author,\r\n            '出版社': item.publisher,\r\n            'ISBN': item.isbn,\r\n            '版次': item.edition || '',\r\n            '出版日期': item.publishDate || '',\r\n            '价格': item.price,\r\n            '分类': item.categoryName || '',\r\n            '库存数量': item.stockQuantity,\r\n            '状态': item.status === 1 ? '启用' : '禁用',\r\n            '描述': item.description || ''\r\n          };\r\n        });\r\n        \r\n        // 创建工作簿\r\n        const ws = XLSX.utils.json_to_sheet(exportData);\r\n        const wb = XLSX.utils.book_new();\r\n        \r\n        // 设置列宽\r\n        const colWidths = [\r\n          { wch: 8 },   // 序号\r\n          { wch: 8 },   // ID\r\n          { wch: 25 },  // 教材名称\r\n          { wch: 15 },  // 教材编码\r\n          { wch: 15 },  // 作者\r\n          { wch: 20 },  // 出版社\r\n          { wch: 18 },  // ISBN\r\n          { wch: 10 },  // 版次\r\n          { wch: 12 },  // 出版日期\r\n          { wch: 10 },  // 价格\r\n          { wch: 12 },  // 分类\r\n          { wch: 10 },  // 库存数量\r\n          { wch: 8 },   // 状态\r\n          { wch: 30 }   // 描述\r\n        ];\r\n        ws['!cols'] = colWidths;\r\n        \r\n        // 添加工作表到工作簿\r\n        XLSX.utils.book_append_sheet(wb, ws, '教材信息');\r\n        \r\n        // 生成文件名（包含当前日期时间）\r\n        const now = new Date();\r\n        const fileName = `教材信息_${now.getFullYear()}${String(now.getMonth() + 1).padStart(2, '0')}${String(now.getDate()).padStart(2, '0')}_${String(now.getHours()).padStart(2, '0')}${String(now.getMinutes()).padStart(2, '0')}.xlsx`;\r\n        \r\n        // 导出文件\r\n        XLSX.writeFile(wb, fileName);\r\n        \r\n        const exportType = this.selection.length > 0 ? '选中' : '全部';\r\n        this.$message.success(`导出成功！共导出 ${exportData.length} 条${exportType}记录`);\r\n      } catch (error) {\r\n        console.error('导出Excel失败:', error);\r\n        this.$message.error('导出Excel失败，请重试');\r\n      }\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* 封面上传样式 */\r\n:deep(.cover-uploader .el-upload) {\r\n  border: 1px dashed #d9d9d9;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  position: relative;\r\n  overflow: hidden;\r\n  width: 150px;\r\n  height: 180px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s;\r\n}\r\n\r\n:deep(.cover-uploader .el-upload:hover) {\r\n  border-color: #409EFF;\r\n}\r\n\r\n.cover-preview {\r\n  position: relative;\r\n  width: 150px;\r\n  height: 180px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.cover {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  border-radius: 6px;\r\n}\r\n\r\n.cover-hover-mask {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  background: rgba(0, 0, 0, 0.6);\r\n  color: white;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  opacity: 0;\r\n  transition: opacity 0.3s;\r\n  border-radius: 6px;\r\n}\r\n\r\n.cover-preview:hover .cover-hover-mask {\r\n  opacity: 1;\r\n}\r\n\r\n.cover-upload-btn {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #8c939d;\r\n  font-size: 14px;\r\n}\r\n\r\n.cover-upload-btn:hover {\r\n  color: #409EFF;\r\n}\r\n</style>\r\n\r\n\r\n\r\n<style scoped>\r\n/* 封面上传样式 */\r\n:deep(.cover-uploader .el-upload) {\r\n  border: 1px dashed #d9d9d9;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n  position: relative;\r\n  overflow: hidden;\r\n  width: 150px;\r\n  height: 180px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  transition: all 0.3s;\r\n}\r\n\r\n:deep(.cover-uploader .el-upload:hover) {\r\n  border-color: #409EFF;\r\n}\r\n\r\n.cover-preview {\r\n  position: relative;\r\n  width: 150px;\r\n  height: 180px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.cover {\r\n  width: 100%;\r\n  height: 100%;\r\n  object-fit: cover;\r\n  border-radius: 6px;\r\n}\r\n\r\n.cover-hover-mask {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  background: rgba(0, 0, 0, 0.6);\r\n  color: white;\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  opacity: 0;\r\n  transition: opacity 0.3s;\r\n  border-radius: 6px;\r\n}\r\n\r\n.cover-preview:hover .cover-hover-mask {\r\n  opacity: 1;\r\n}\r\n\r\n.cover-upload-btn {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: #8c939d;\r\n  font-size: 14px;\r\n}\r\n\r\n.cover-upload-btn:hover {\r\n  color: #409EFF;\r\n}\r\n</style>"]}]}