{"remainingRequest":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\front\\Home.vue?vue&type=style&index=0&id=5826cf82&scoped=true&lang=css","dependencies":[{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\src\\views\\front\\Home.vue","mtime":1753498552933},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\css-loader\\dist\\cjs.js","mtime":1753409944823},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1753409923452},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\postcss-loader\\src\\index.js","mtime":1753409944465},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-高校教材管理系统\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Home.vue"],"names":[],"mappings":";AAoqBA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"Home.vue","sourceRoot":"src/views/front","sourcesContent":["<template>\r\n  <div class=\"p-0\">\r\n    <!-- 欢迎区域 -->\r\n    <div class=\"bg-gradient-to-r from-gray-50 to-blue-50 rounded-xl p-8 md:p-10 flex flex-col md:flex-row items-center mb-6 relative overflow-hidden\">\r\n      <div class=\"z-10 flex-1\">\r\n        <h1 class=\"text-2xl md:text-3xl font-bold text-gray-800 mb-4\">欢迎使用高校教材管理系统</h1>\r\n        <p class=\"text-base text-gray-600 mb-6 max-w-xl\">便捷高效的教材查询、申报与管理平台</p>\r\n        <div class=\"flex flex-wrap gap-4\">\r\n          <el-button type=\"primary\" size=\"medium\" round @click=\"$router.push('/front/textbooks')\">\r\n            浏览教材 <i class=\"el-icon-arrow-right ml-1\"></i>\r\n          </el-button>\r\n          <el-button type=\"success\" size=\"medium\" round @click=\"$router.push('/front/textbook-application')\">\r\n            教材申报 <i class=\"el-icon-arrow-right ml-1\"></i>\r\n          </el-button>\r\n        </div>\r\n      </div>\r\n      <div class=\"flex items-center justify-center md:flex-shrink-0 md:w-72\">\r\n        <!-- <img src=\"@/assets/imgs/banner-img.png\" alt=\"教材管理\" /> -->\r\n      </div>\r\n      \r\n      <!-- 装饰圆圈 -->\r\n      <div class=\"absolute top-0 right-0 w-64 h-64 rounded-full bg-blue-500 bg-opacity-5 -mt-20 -mr-20\"></div>\r\n      <div class=\"absolute bottom-0 left-0 w-80 h-80 rounded-full bg-blue-500 bg-opacity-5 -mb-40 -ml-40\"></div>\r\n    </div>\r\n\r\n    <!-- 统计卡片 -->\r\n    <el-row :gutter=\"20\" class=\"mb-6\">\r\n      <el-col :span=\"6\">\r\n        <div class=\"h-24 rounded-xl bg-gradient-to-r from-blue-500 to-blue-600 shadow-lg flex items-center px-6 text-white transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl\">\r\n          <div class=\"text-3xl mr-5\">\r\n            <i class=\"el-icon-collection\"></i>\r\n          </div>\r\n          <div class=\"flex-1\">\r\n            <div class=\"text-2xl font-bold\">{{ stats.textbookCount }}</div>\r\n            <div class=\"text-sm opacity-90\">教材总数</div>\r\n          </div>\r\n        </div>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <div class=\"h-24 rounded-xl bg-gradient-to-r from-green-500 to-green-600 shadow-lg flex items-center px-6 text-white transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl\">\r\n          <div class=\"text-3xl mr-5\">\r\n            <i class=\"el-icon-notebook-2\"></i>\r\n          </div>\r\n          <div class=\"flex-1\">\r\n            <div class=\"text-2xl font-bold\">{{ stats.newTextbookCount }}</div>\r\n            <div class=\"text-sm opacity-90\">新增教材</div>\r\n          </div>\r\n        </div>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <div class=\"h-24 rounded-xl bg-gradient-to-r from-amber-500 to-amber-600 shadow-lg flex items-center px-6 text-white transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl\">\r\n          <div class=\"text-3xl mr-5\">\r\n            <i class=\"el-icon-document-checked\"></i>\r\n          </div>\r\n          <div class=\"flex-1\">\r\n            <div class=\"text-2xl font-bold\">{{ stats.applicationCount }}</div>\r\n            <div class=\"text-sm opacity-90\">已完成申报</div>\r\n          </div>\r\n        </div>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <div class=\"h-24 rounded-xl bg-gradient-to-r from-purple-500 to-purple-600 shadow-lg flex items-center px-6 text-white transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-xl\">\r\n          <div class=\"text-3xl mr-5\">\r\n            <i class=\"el-icon-user\"></i>\r\n          </div>\r\n          <div class=\"flex-1\">\r\n            <div class=\"text-2xl font-bold\">{{ stats.userCount }}</div>\r\n            <div class=\"text-sm opacity-90\">注册用户</div>\r\n          </div>\r\n        </div>\r\n      </el-col>\r\n    </el-row>\r\n    \r\n    <!-- 通知轮播 -->\r\n    <div class=\"bg-white rounded-xl px-5 h-10 flex items-center mb-6 shadow-sm\">\r\n      <i class=\"el-icon-bell text-amber-500 text-lg mr-4\"></i>\r\n      <el-carousel height=\"40px\" direction=\"vertical\" :autoplay=\"true\" :interval=\"4000\" indicator-position=\"none\" class=\"flex-1\">\r\n        <el-carousel-item v-for=\"(notice, index) in notices\" :key=\"index\">\r\n          <div class=\"flex items-center justify-between h-10 cursor-pointer\" @click=\"viewNotice(notice)\">\r\n            <span class=\"text-sm text-gray-700 truncate\">{{ notice.title }}</span>\r\n            <span class=\"text-xs text-gray-500 ml-4\">{{ notice.time }}</span>\r\n          </div>\r\n        </el-carousel-item>\r\n      </el-carousel>\r\n    </div>\r\n    \r\n    <!-- 内容区域 -->\r\n    <el-row :gutter=\"24\" class=\"mb-6\">\r\n      <!-- 左侧：教材推荐 -->\r\n      <el-col :span=\"16\">\r\n        <div class=\"bg-white rounded-xl shadow-sm overflow-hidden mb-6\">\r\n          <div class=\"flex justify-between items-center p-5 border-b border-gray-100\">\r\n            <div class=\"flex items-center\">\r\n              <i class=\"el-icon-reading text-blue-500 text-xl mr-2\"></i>\r\n              <span class=\"text-lg font-medium text-gray-800\">教材推荐</span>\r\n            </div>\r\n            <el-button type=\"text\" @click=\"$router.push('/front/textbooks')\">\r\n              查看全部 <i class=\"el-icon-arrow-right\"></i>\r\n            </el-button>\r\n          </div>\r\n          \r\n          <div v-loading=\"recommendLoading\" class=\"p-5\">\r\n            <!-- 有数据时显示 -->\r\n            <el-row :gutter=\"24\" v-if=\"recommendBooks.length > 0\">\r\n              <el-col :lg=\"8\" :md=\"12\" :sm=\"24\" v-for=\"(book, index) in recommendBooks\" :key=\"index\" :class=\"{'mb-6': true}\">\r\n                <div class=\"bg-white rounded-xl shadow-sm overflow-hidden h-72 hover:shadow-md transition-all duration-300 cursor-pointer\" @click=\"viewBookDetail(book)\">\r\n                  <div class=\"h-40 flex items-center justify-center relative\">\r\n                    <div v-if=\"book.coverImage\" class=\"absolute inset-0 bg-gray-50 flex items-center justify-center\">\r\n                      <img \r\n                        :src=\"book.coverImage\" \r\n                        class=\"max-h-full max-w-full object-contain\" \r\n                        alt=\"教材封面\"\r\n                        @load=\"onImageLoad(book.id)\"\r\n                        @error=\"onImageError(book.id)\"\r\n                        :class=\"{'opacity-0': !loadedImages[book.id]}\"\r\n                      />\r\n                      <div v-if=\"!loadedImages[book.id]\" class=\"absolute inset-0 flex items-center justify-center\">\r\n                        <i class=\"el-icon-loading text-gray-400\"></i>\r\n                      </div>\r\n                    </div>\r\n                    <div v-else class=\"absolute inset-0\" :style=\"{ backgroundColor: book.coverColor }\">\r\n                      <div class=\"flex items-center justify-center h-full\">\r\n                        <i class=\"el-icon-notebook-2 text-white text-4xl\"></i>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                  <div class=\"p-4\">\r\n                    <h3 class=\"text-base font-medium text-gray-800 mb-2 truncate\">{{ book.textbookName }}</h3>\r\n                    <div class=\"flex justify-between text-xs text-gray-500 mb-3\">\r\n                      <span class=\"flex items-center\">\r\n                        <i class=\"el-icon-user mr-1\"></i> {{ book.author }}\r\n                      </span>\r\n                      <span class=\"flex items-center\">\r\n                        <i class=\"el-icon-office-building mr-1\"></i> {{ book.publisher }}\r\n                      </span>\r\n                    </div>\r\n                    <div class=\"flex flex-wrap gap-1\">\r\n                      <el-tag size=\"mini\" type=\"info\">{{ book.categoryName }}</el-tag>\r\n                      <el-tag size=\"mini\" type=\"success\">{{ book.publishYear }}年版</el-tag>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </el-col>\r\n            </el-row>\r\n            \r\n            <!-- 无数据时显示 -->\r\n            <div v-else-if=\"!recommendLoading\" class=\"flex flex-col items-center justify-center py-10\">\r\n              <i class=\"el-icon-notebook-2 text-gray-300 text-5xl mb-4\"></i>\r\n              <p class=\"text-gray-500\">暂无推荐教材</p>\r\n              <el-button size=\"small\" type=\"primary\" plain class=\"mt-4\" @click=\"fetchRecommendBooks\">\r\n                <i class=\"el-icon-refresh mr-1\"></i> 重新加载\r\n              </el-button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 申请流程 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n          <div class=\"flex items-center p-5 border-b border-gray-100\">\r\n            <i class=\"el-icon-guide text-blue-500 text-xl mr-2\"></i>\r\n            <span class=\"text-lg font-medium text-gray-800\">申报流程</span>\r\n          </div>\r\n          \r\n          <div class=\"flex flex-wrap justify-between items-center px-8 py-6\">\r\n            <div class=\"flex flex-col items-center text-center\">\r\n              <div class=\"w-14 h-14 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center text-2xl mb-3\">\r\n                <i class=\"el-icon-edit-outline\"></i>\r\n              </div>\r\n              <h4 class=\"text-sm font-medium text-gray-700 mb-1\">填写申请</h4>\r\n              <p class=\"text-xs text-gray-500\">填写教材信息和申报原因</p>\r\n            </div>\r\n            \r\n            <div class=\"text-gray-300 text-xl mx-2\">\r\n              <i class=\"el-icon-arrow-right\"></i>\r\n            </div>\r\n            \r\n            <div class=\"flex flex-col items-center text-center\">\r\n              <div class=\"w-14 h-14 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center text-2xl mb-3\">\r\n                <i class=\"el-icon-upload\"></i>\r\n              </div>\r\n              <h4 class=\"text-sm font-medium text-gray-700 mb-1\">提交申报</h4>\r\n              <p class=\"text-xs text-gray-500\">提交申请等待审核</p>\r\n            </div>\r\n            \r\n            <div class=\"text-gray-300 text-xl mx-2\">\r\n              <i class=\"el-icon-arrow-right\"></i>\r\n            </div>\r\n            \r\n            <div class=\"flex flex-col items-center text-center\">\r\n              <div class=\"w-14 h-14 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center text-2xl mb-3\">\r\n                <i class=\"el-icon-view\"></i>\r\n              </div>\r\n              <h4 class=\"text-sm font-medium text-gray-700 mb-1\">教师审核</h4>\r\n              <p class=\"text-xs text-gray-500\">教师评审申报内容</p>\r\n            </div>\r\n            \r\n            <div class=\"text-gray-300 text-xl mx-2\">\r\n              <i class=\"el-icon-arrow-right\"></i>\r\n            </div>\r\n            \r\n            <div class=\"flex flex-col items-center text-center\">\r\n              <div class=\"w-14 h-14 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center text-2xl mb-3\">\r\n                <i class=\"el-icon-circle-check\"></i>\r\n              </div>\r\n              <h4 class=\"text-sm font-medium text-gray-700 mb-1\">申报完成</h4>\r\n              <p class=\"text-xs text-gray-500\">通过审核完成申报</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </el-col>\r\n      \r\n      <!-- 右侧：通知和快捷入口 -->\r\n      <el-col :span=\"8\">\r\n        <!-- 通知公告 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm overflow-hidden mb-6\">\r\n          <div class=\"flex justify-between items-center p-5 border-b border-gray-100\">\r\n            <div class=\"flex items-center\">\r\n              <i class=\"el-icon-bell text-blue-500 text-xl mr-2\"></i>\r\n              <span class=\"text-lg font-medium text-gray-800\">通知公告</span>\r\n            </div>\r\n            <el-button type=\"text\" @click=\"$router.push('/front/notice')\">\r\n              更多 <i class=\"el-icon-arrow-right\"></i>\r\n            </el-button>\r\n          </div>\r\n          \r\n          <div v-if=\"notices.length > 0\" class=\"py-2\">\r\n            <div v-for=\"(item, index) in notices\" :key=\"index\" \r\n              class=\"flex items-center justify-between px-5 py-3 border-b border-gray-50 hover:bg-gray-50 transition-colors cursor-pointer\" \r\n              @click=\"viewNotice(item)\">\r\n              <div class=\"flex-1\">\r\n                <div class=\"text-sm text-gray-700 mb-1 truncate\">{{ item.title }}</div>\r\n                <div class=\"text-xs text-gray-400 flex items-center\">\r\n                  <i class=\"el-icon-time mr-1\"></i> {{ item.time }}\r\n                </div>\r\n              </div>\r\n              <i class=\"el-icon-arrow-right text-gray-300\"></i>\r\n            </div>\r\n          </div>\r\n          <div v-else class=\"py-10 text-center text-gray-400\">\r\n            <i class=\"el-icon-info text-3xl mb-2\"></i>\r\n            <p class=\"text-sm\">暂无通知</p>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 快捷入口 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm overflow-hidden mb-6\">\r\n          <div class=\"flex items-center p-5 border-b border-gray-100\">\r\n            <i class=\"el-icon-menu text-blue-500 text-xl mr-2\"></i>\r\n            <span class=\"text-lg font-medium text-gray-800\">快捷入口</span>\r\n          </div>\r\n          \r\n          <div class=\"grid grid-cols-2 gap-4 p-5\">\r\n            <div class=\"bg-gray-50 rounded-lg p-4 flex flex-col items-center text-center cursor-pointer hover:bg-blue-50 hover:text-blue-500 transition-all duration-300\" \r\n                @click=\"$router.push('/front/textbooks')\">\r\n              <i class=\"el-icon-notebook-2 text-2xl mb-2\"></i>\r\n              <span class=\"text-sm\">教材浏览</span>\r\n            </div>\r\n            <div class=\"bg-gray-50 rounded-lg p-4 flex flex-col items-center text-center cursor-pointer hover:bg-blue-50 hover:text-blue-500 transition-all duration-300\" \r\n                @click=\"$router.push('/front/textbook-application')\">\r\n              <i class=\"el-icon-document-checked text-2xl mb-2\"></i>\r\n              <span class=\"text-sm\">教材申报</span>\r\n            </div>\r\n            <div class=\"bg-gray-50 rounded-lg p-4 flex flex-col items-center text-center cursor-pointer hover:bg-blue-50 hover:text-blue-500 transition-all duration-300\" \r\n                @click=\"$router.push('/front/person')\">\r\n              <i class=\"el-icon-user text-2xl mb-2\"></i>\r\n              <span class=\"text-sm\">个人中心</span>\r\n            </div>\r\n            <div class=\"bg-gray-50 rounded-lg p-4 flex flex-col items-center text-center cursor-pointer hover:bg-blue-50 hover:text-blue-500 transition-all duration-300\" \r\n                @click=\"$router.push('/front/notice')\">\r\n              <i class=\"el-icon-bell text-2xl mb-2\"></i>\r\n              <span class=\"text-sm\">通知公告</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 帮助中心 -->\r\n        <div class=\"bg-white rounded-xl shadow-sm overflow-hidden\">\r\n          <div class=\"flex items-center p-5 border-b border-gray-100\">\r\n            <i class=\"el-icon-question text-blue-500 text-xl mr-2\"></i>\r\n            <span class=\"text-lg font-medium text-gray-800\">帮助中心</span>\r\n          </div>\r\n          \r\n          <div class=\"divide-y divide-gray-50\">\r\n            <div class=\"flex items-center px-5 py-3 cursor-pointer hover:bg-gray-50 hover:text-blue-500 transition-colors\">\r\n              <i class=\"el-icon-document mr-2\"></i>\r\n              <span class=\"text-sm\">如何申报教材？</span>\r\n            </div>\r\n            <div class=\"flex items-center px-5 py-3 cursor-pointer hover:bg-gray-50 hover:text-blue-500 transition-colors\">\r\n              <i class=\"el-icon-document mr-2\"></i>\r\n              <span class=\"text-sm\">教材申报流程指南</span>\r\n            </div>\r\n            <div class=\"flex items-center px-5 py-3 cursor-pointer hover:bg-gray-50 hover:text-blue-500 transition-colors\">\r\n              <i class=\"el-icon-document mr-2\"></i>\r\n              <span class=\"text-sm\">常见问题解答</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 教材详情对话框 -->\r\n    <el-dialog \r\n      title=\"教材详情\" \r\n      :visible.sync=\"detailDialogVisible\" \r\n      width=\"800px\" \r\n      :close-on-click-modal=\"true\"\r\n      custom-class=\"textbook-detail-dialog\"\r\n    >\r\n      <div v-if=\"currentBook\" class=\"flex flex-col md:flex-row\">\r\n        <!-- 封面 -->\r\n        <div class=\"w-full md:w-1/3 flex justify-center md:justify-start mb-6 md:mb-0\">\r\n          <div class=\"bg-gray-100 w-48 h-64 rounded-lg overflow-hidden flex items-center justify-center shadow\">\r\n            <img v-if=\"currentBook.coverImage\" :src=\"currentBook.coverImage\" class=\"w-full h-full object-contain\" />\r\n            <div v-else class=\"flex flex-col items-center justify-center w-full h-full\" :style=\"{ backgroundColor: currentBook.coverColor || '#4e7df9' }\">\r\n              <i class=\"el-icon-notebook-2 text-white text-4xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- 信息 -->\r\n        <div class=\"w-full md:w-2/3 md:pl-6\">\r\n          <h2 class=\"text-2xl font-bold text-gray-800 mb-2\">{{ currentBook.textbookName }}</h2>\r\n          \r\n          <div class=\"bg-gray-50 rounded-lg p-4 mb-4\">\r\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">作者</div>\r\n                <div class=\"font-medium\">{{ currentBook.author || '暂无作者信息' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">出版社</div>\r\n                <div class=\"font-medium\">{{ currentBook.publisher || '暂无出版社信息' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">出版年份</div>\r\n                <div class=\"font-medium\">{{ currentBook.publishYear || '暂无出版年份' }}</div>\r\n              </div>\r\n              <div>\r\n                <div class=\"text-sm text-gray-500\">分类</div>\r\n                <div class=\"font-medium\">{{ currentBook.categoryName || '暂无分类信息' }}</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          \r\n          <!-- 详细描述 -->\r\n          <div v-if=\"currentBook.description\">\r\n            <h3 class=\"text-lg font-semibold text-gray-700 mb-2\">教材简介</h3>\r\n            <div class=\"bg-gray-50 rounded-lg p-4\">\r\n              <p class=\"text-gray-700 whitespace-pre-wrap\">\r\n                {{ currentBook.description || '暂无教材简介' }}\r\n              </p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"detailDialogVisible = false\">关闭</el-button>\r\n        <el-button \r\n          type=\"primary\" \r\n          @click=\"gotoTextbookDetail\"\r\n        >\r\n          查看详情\r\n        </el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"FrontHome\",\r\n  data() {\r\n    return {\r\n      banners: [\r\n        { \r\n          title: '教材申报进行中', \r\n          desc: '2023年秋季学期教材申报工作已经开始，请及时提交申请', \r\n          buttonText: '立即申报',\r\n          color: '#409EFF',\r\n          route: '/front/textbook-application'\r\n        },\r\n        { \r\n          title: '新版教材上线', \r\n          desc: '多门专业课程已更新教材版本，请查看最新教材目录', \r\n          buttonText: '查看教材',\r\n          color: '#67C23A',\r\n          route: '/front/textbook'\r\n        },\r\n        { \r\n          title: '系统使用指南', \r\n          desc: '不知道如何使用系统？点击查看详细操作指南', \r\n          buttonText: '查看指南',\r\n          color: '#E6A23C',\r\n          route: '/front/notice'\r\n        }\r\n      ],\r\n      recommendBooks: [],\r\n      recommendLoading: false,\r\n      notices: [],\r\n      noticeLoading: false,\r\n      stats: {\r\n        textbookCount: \"500+\",\r\n        newTextbookCount: \"50+\",\r\n        applicationCount: \"120\",\r\n        userCount: \"200+\"\r\n      },\r\n      loadedImages: {}, // 跟踪已加载的图片\r\n      detailDialogVisible: false, // 教材详情对话框的可见性\r\n      currentBook: null // 当前选中的教材详情\r\n    };\r\n  },\r\n  created() {\r\n    this.fetchRecommendBooks();\r\n    this.fetchNotices();\r\n    this.fetchStatistics();\r\n  },\r\n  methods: {\r\n    // 查看通知详情\r\n    viewNotice(notice) {\r\n      this.$router.push(`/front/notice/${notice.id}`);\r\n    },\r\n    \r\n    // 查看教材详情\r\n    viewBookDetail(book) {\r\n      this.currentBook = book; // 设置当前选中的教材\r\n      this.detailDialogVisible = true; // 显示详情对话框\r\n    },\r\n\r\n    // 跳转到教材详情页\r\n    gotoTextbookDetail() {\r\n      if (this.currentBook && this.currentBook.id) {\r\n        this.$router.push(`/front/textbooks?id=${this.currentBook.id}`);\r\n      } else {\r\n        this.$message.warning('无法跳转到详情页，教材ID不存在');\r\n      }\r\n      this.detailDialogVisible = false; // 关闭详情对话框\r\n    },\r\n    \r\n    // 获取推荐教材\r\n    fetchRecommendBooks() {\r\n      this.recommendLoading = true;\r\n      this.$request.get(\"/textbook/recommend\")\r\n        .then(res => {\r\n          this.recommendLoading = false;\r\n          if (res.code === '200') {\r\n            // 处理后端返回的数据，确保字段一致性\r\n            this.recommendBooks = res.data.map(book => {\r\n              // 初始化图片加载状态\r\n              if (book.id) {\r\n                this.$set(this.loadedImages, book.id, false);\r\n              }\r\n              return {\r\n                id: book.id,\r\n                textbookName: book.textbookName,\r\n                author: book.author || '未知作者',\r\n                publisher: book.publisher || '未知出版社',\r\n                coverImage: book.coverImage,\r\n                // 根据ID生成随机颜色用于没有封面时显示\r\n                coverColor: this.generateColorFromId(book.id),\r\n                categoryName: book.categoryName || '未分类',\r\n                publishYear: book.publishDate ? new Date(book.publishDate).getFullYear() : '未知',\r\n                description: book.description // 添加描述字段\r\n              };\r\n            });\r\n          } else {\r\n            this.$message.error(res.msg || '获取推荐教材失败');\r\n            // 加载失败时使用备用数据\r\n            this.loadFallbackData();\r\n          }\r\n        })\r\n        .catch(error => {\r\n          this.recommendLoading = false;\r\n          console.error('获取推荐教材异常:', error);\r\n          this.$message.error('获取推荐教材异常');\r\n          // 加载失败时使用备用数据\r\n          this.loadFallbackData();\r\n        });\r\n    },\r\n    \r\n    // 加载备用数据\r\n    loadFallbackData() {\r\n      this.recommendLoading = false;\r\n      \r\n      const fallbackBooks = [\r\n        { \r\n          id: 1,\r\n          textbookName: '高等数学（第7版）', \r\n          author: '同济大学', \r\n          publisher: '高等教育出版社', \r\n          coverColor: '#4e7df9',\r\n          categoryName: '数学',\r\n          publishYear: '2020',\r\n          description: '本书是同济大学数学系编写的高等数学教材，内容全面，例题丰富，适合各类理工科专业学生使用。'\r\n        },\r\n        { \r\n          id: 2,\r\n          textbookName: '大学物理学', \r\n          author: '赵凯华', \r\n          publisher: '高等教育出版社', \r\n          coverColor: '#67C23A',\r\n          categoryName: '物理',\r\n          publishYear: '2019',\r\n          description: '本书是赵凯华教授编写的一本系统介绍大学物理学的教材，内容深入浅出，适合物理学专业学生学习。'\r\n        },\r\n        { \r\n          id: 3,\r\n          textbookName: '计算机网络', \r\n          author: '谢希仁', \r\n          publisher: '电子工业出版社', \r\n          coverColor: '#E6A23C',\r\n          categoryName: '计算机',\r\n          publishYear: '2021',\r\n          description: '本书是谢希仁教授编写的一本全面介绍计算机网络基础知识的教材，适合计算机相关专业学生学习。'\r\n        },\r\n        { \r\n          id: 4,\r\n          textbookName: '数据结构与算法', \r\n          author: '严蔚敏', \r\n          publisher: '清华大学出版社', \r\n          coverColor: '#F56C6C',\r\n          categoryName: '计算机',\r\n          publishYear: '2018',\r\n          description: '本书是严蔚敏教授编写的一本经典的数据结构与算法教材，内容全面，例题丰富，适合计算机专业学生学习。'\r\n        },\r\n        { \r\n          id: 5,\r\n          textbookName: '操作系统原理', \r\n          author: '汤小丹', \r\n          publisher: '西安电子科技大学出版社', \r\n          coverColor: '#909399',\r\n          categoryName: '计算机',\r\n          publishYear: '2020',\r\n          description: '本书是汤小丹教授编写的一本深入浅出的操作系统原理教材，适合计算机专业学生学习。'\r\n        },\r\n        { \r\n          id: 6,\r\n          textbookName: '线性代数', \r\n          author: '李尚志', \r\n          publisher: '北京大学出版社', \r\n          coverColor: '#9c27b0',\r\n          categoryName: '数学',\r\n          publishYear: '2022',\r\n          description: '本书是李尚志教授编写的一本系统介绍线性代数基础知识的教材，适合数学专业学生学习。'\r\n        }\r\n      ];\r\n      \r\n      // 初始化备用数据的图片加载状态\r\n      fallbackBooks.forEach(book => {\r\n        if (book.id) {\r\n          this.$set(this.loadedImages, book.id, true); // 备用数据没有真实图片，直接设为已加载\r\n        }\r\n      });\r\n      \r\n      this.recommendBooks = fallbackBooks;\r\n    },\r\n    \r\n    // 根据ID生成颜色\r\n    generateColorFromId(id) {\r\n      const colors = [\r\n        '#4e7df9', '#67C23A', '#E6A23C', '#F56C6C', \r\n        '#909399', '#9c27b0', '#2196f3', '#ff9800'\r\n      ];\r\n      return colors[id % colors.length] || colors[0];\r\n    },\r\n\r\n    // 图片加载成功\r\n    onImageLoad(id) {\r\n      this.loadedImages[id] = true;\r\n    },\r\n\r\n    // 图片加载失败\r\n    onImageError(id) {\r\n      this.loadedImages[id] = true; // 设置为已加载，避免重复加载\r\n    },\r\n\r\n    // 获取通知公告\r\n    fetchNotices() {\r\n      this.noticeLoading = true;\r\n      this.$request.get(\"/notice/selectAll\")\r\n        .then(res => {\r\n          this.noticeLoading = false;\r\n          if (res.code === '200') {\r\n            // 格式化通知数据并限制显示数量\r\n            const noticeList = res.data || [];\r\n            this.notices = noticeList.map(notice => {\r\n              return {\r\n                id: notice.id,\r\n                title: notice.title,\r\n                time: notice.time ? this.formatDate(notice.time) : '未知时间',\r\n                content: notice.content\r\n              };\r\n            }).slice(0, 5); // 只显示最新的5条通知\r\n          } else {\r\n            console.error('获取通知公告失败:', res.msg);\r\n            this.loadFallbackNotices();\r\n          }\r\n        })\r\n        .catch(error => {\r\n          this.noticeLoading = false;\r\n          console.error('获取通知公告异常:', error);\r\n          this.loadFallbackNotices();\r\n        });\r\n    },\r\n\r\n    // 加载备用通知数据\r\n    loadFallbackNotices() {\r\n      this.notices = [\r\n        { title: '关于2023学年教材申报工作开始的通知', time: '2023-07-15', id: 1 },\r\n        { title: '新版教材管理系统正式上线公告', time: '2023-07-10', id: 2 },\r\n        { title: '关于加强教材质量审核的通知', time: '2023-07-05', id: 3 },\r\n        { title: '2023年教材出版社合作名单公示', time: '2023-06-30', id: 4 }\r\n      ];\r\n    },\r\n\r\n    // 获取统计数据\r\n    fetchStatistics() {\r\n      // 获取教材总数\r\n      this.$request.get(\"/textbook/selectAll\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            const textbooks = res.data || [];\r\n            this.stats.textbookCount = textbooks.length + \"+\";\r\n            \r\n            // 计算最近一个月的新增教材数量\r\n            const oneMonthAgo = new Date();\r\n            oneMonthAgo.setMonth(oneMonthAgo.getMonth() - 1);\r\n            \r\n            const newTextbooks = textbooks.filter(book => {\r\n              if (!book.createTime) return false;\r\n              const createDate = new Date(book.createTime);\r\n              return createDate > oneMonthAgo;\r\n            });\r\n            \r\n            this.stats.newTextbookCount = newTextbooks.length + \"+\";\r\n          }\r\n        })\r\n        .catch(error => {\r\n          console.error('获取教材统计数据异常:', error);\r\n        });\r\n\r\n      // 获取申报数量\r\n      this.$request.get(\"/textbookApplication/selectAll\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.stats.applicationCount = (res.data || []).length;\r\n          }\r\n        })\r\n        .catch(error => {\r\n          console.error('获取申报数据异常:', error);\r\n        });\r\n\r\n      // 获取用户数量\r\n      this.$request.get(\"/user/selectAll\")\r\n        .then(res => {\r\n          if (res.code === '200') {\r\n            this.stats.userCount = (res.data || []).length + \"+\";\r\n          }\r\n        })\r\n        .catch(error => {\r\n          console.error('获取用户数据异常:', error);\r\n        });\r\n    },\r\n\r\n    // 格式化日期\r\n    formatDate(dateStr) {\r\n      if (!dateStr) return '';\r\n      const date = new Date(dateStr);\r\n      return date.getFullYear() + '-' + \r\n             String(date.getMonth() + 1).padStart(2, '0') + '-' + \r\n             String(date.getDate()).padStart(2, '0');\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n/* Tailwind 已经覆盖了所有样式，不需要额外的CSS */\r\n\r\n/* 对话框样式 */\r\n:deep(.textbook-detail-dialog) {\r\n  border-radius: 0.5rem;\r\n  overflow: hidden;\r\n}\r\n\r\n:deep(.el-dialog__header) {\r\n  padding: 1rem;\r\n  border-bottom: 1px solid #f0f0f0;\r\n  background-color: #f9fafb;\r\n}\r\n\r\n:deep(.el-dialog__body) {\r\n  padding: 1.5rem;\r\n}\r\n</style> "]}]}