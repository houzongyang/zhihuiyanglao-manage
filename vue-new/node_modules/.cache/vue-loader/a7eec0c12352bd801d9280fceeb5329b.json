card shadow=\"hover\" class=\"stats-card\">\r\n          <div class=\"stats-icon users\">\r\n            <i class=\"el-icon-user\"></i>\r\n          </div>\r\n          <div class=\"stats-info\">\r\n            <div class=\"stats-title\">用户总数</div>\r\n            <div class=\"stats-value\">186</div>\r\n            <div class=\"stats-desc\">注册用户</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card shadow=\"hover\" class=\"stats-card\">\r\n          <div class=\"stats-icon applications\">\r\n            <i class=\"el-icon-document\"></i>\r\n          </div>\r\n          <div class=\"stats-info\">\r\n            <div class=\"stats-title\">申报数量</div>\r\n            <div class=\"stats-value\">120</div>\r\n            <div class=\"stats-desc\">教材申报</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"6\">\r\n        <el-card shadow=\"hover\" class=\"stats-card\">\r\n          <div class=\"stats-icon notices\">\r\n            <i class=\"el-icon-bell\"></i>\r\n          </div>\r\n          <div class=\"stats-info\">\r\n            <div class=\"stats-title\">通知公告</div>\r\n            <div class=\"stats-value\">35</div>\r\n            <div class=\"stats-desc\">最新系统通知</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n    \r\n    <el-row :gutter=\"20\" class=\"content-section\">\r\n      <el-col :span=\"16\">\r\n        <el-card class=\"chart-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"chart-header\">\r\n            <span>教材申报统计</span>\r\n            <el-radio-group v-model=\"chartType\" size=\"small\">\r\n              <el-radio-button label=\"week\">本周</el-radio-button>\r\n              <el-radio-button label=\"month\">本月</el-radio-button>\r\n              <el-radio-button label=\"year\">本年</el-radio-button>\r\n            </el-radio-group>\r\n          </div>\r\n          <div class=\"chart-placeholder\">\r\n            <i class=\"el-icon-data-line\"></i>\r\n            <p>申报数据统计图表</p>\r\n            <p class=\"chart-desc\">展示教材申报数量变化趋势</p>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"8\">\r\n        <el-card class=\"notice-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"notice-header\">\r\n            <span>最新通知</span>\r\n            <el-button type=\"text\">更多</el-button>\r\n          </div>\r\n          <div v-if=\"notices.length > 0\">\r\n            <div v-for=\"(item, index) in notices\" :key=\"index\" class=\"notice-item\">\r\n              <div class=\"notice-title\">{{ item.title }}</div>\r\n              <div class=\"notice-time\">{{ item.time }}</div>\r\n            </div>\r\n          </div>\r\n          <div v-else class=\"empty-data\">\r\n            <i class=\"el-icon-info\"></i>\r\n            <p>暂无通知</p>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n    \r\n    <el-row :gutter=\"20\" class=\"content-section\">\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"recent-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"recent-header\">\r\n            <span>最近教材</span>\r\n            <el-button type=\"text\">查看全部</el-button>\r\n          </div>\r\n          <el-table :data=\"recentBooks\" style=\"width: 100%\">\r\n            <el-table-column prop=\"name\" label=\"教材名称\" width=\"180\"></el-table-column>\r\n            <el-table-column prop=\"author\" label=\"作者\" width=\"120\"></el-table-column>\r\n            <el-table-column prop=\"publisher\" label=\"出版社\"></el-table-column>\r\n            <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"180\"></el-table-column>\r\n          </el-table>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"info-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"info-header\">\r\n            <span>系统信息</span>\r\n          </div>\r\n          <div class=\"info-content\">\r\n            <div class=\"info-item\">\r\n              <span class=\"info-label\">当前版本：</span>\r\n              <span class=\"info-value\">v1.0.0</span>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <span class=\"info-label\">更新日期：</span>\r\n              <span class=\"info-value\">2023-07-20</span>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <span class=\"info-label\">系统状态：</span>\r\n              <span class=\"info-value\"><el-tag size=\"small\" type=\"success\">正常运行中</el-tag></span>\r\n            </div>\r\n            <div class=\"info-item\">\r\n              <span class=\"info-label\">服务支持：</span>\r\n              <span class=\"info-value\">高校教材管理系统团队</span>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Home\",\r\n  data() {\r\n    return {\r\n      chartType: 'month',\r\n      notices: [\r\n        { title: '关于2023学年教材申报工作开始的通知', time: '2023-07-15' },\r\n        { title: '新版教材管理系统正式上线公告', time: '2023-07-10' },\r\n        { title: '关于加强教材质量审核的通知', time: '2023-07-05' },\r\n        { title: '2023年教材出版社合作名单公示', time: '2023-06-30' }\r\n      ],\r\n      recentBooks: [\r\n        { name: '高等数学（第7版）', author: '同济大学', publisher: '高等教育出版社', createTime: '2023-07-18' },\r\n        { name: '大学物理学', author: '赵凯华', publisher: '高等教育出版社', createTime: '2023-07-15' },\r\n        { name: '计算机网络', author: '谢希仁', publisher: '电子工业出版社', createTime: '2023-07-10' },\r\n        { name: '数据结构（C语言版）', author: '严蔚敏', publisher: '清华大学出版社', createTime: '2023-07-05' }\r\n      ]\r\n    };\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.home-container {\r\n  padding: 10px;\r\n}\r\n\r\n.welcome-section {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.welcome-title {\r\n  font-size: 22px;\r\n  font-weight: bold;\r\n  color: #303133;\r\n  margin-bottom: 10px;\r\n}\r\