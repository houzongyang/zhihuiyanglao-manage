 </div>\r\n\r\n      <div class=\"layout-header-center\">\r\n        <el-breadcrumb separator-class=\"el-icon-arrow-right\">\r\n          <el-breadcrumb-item :to=\"{ path: '/' }\">首页</el-breadcrumb-item>\r\n          <el-breadcrumb-item :to=\"{ path: $route.path }\">{{\r\n            $route.meta.name\r\n          }}</el-breadcrumb-item>\r\n        </el-breadcrumb>\r\n      </div>\r\n\r\n      <div class=\"layout-header-right\">\r\n        <div class=\"header-icon-group\">\r\n          <el-tooltip content=\"全屏\" placement=\"bottom\">\r\n            <i\r\n              class=\"el-icon-full-screen header-icon\"\r\n              @click=\"toggleFullScreen\"\r\n            ></i>\r\n          </el-tooltip>\r\n          <el-tooltip content=\"刷新页面\" placement=\"bottom\">\r\n            <i class=\"el-icon-refresh header-icon\" @click=\"refreshPage\"></i>\r\n          </el-tooltip>\r\n        </div>\r\n        <el-dropdown trigger=\"click\" placement=\"bottom\">\r\n          <div class=\"avatar\">\r\n            <img\r\n              :src=\"\r\n                user.avatar ||\r\n                'https://cube.elemecdn.com/3/7c/3ea6beec64369c2642b92c6726f1epng.png'\r\n              \"\r\n            />\r\n            <div>{{ user.name || \"管理员\" }}</div>\r\n            <i class=\"el-icon-arrow-down avatar-arrow\"></i>\r\n          </div>\r\n          <el-dropdown-menu slot=\"dropdown\">\r\n            <el-dropdown-item @click.native=\"$router.push('/person')\">\r\n              <i class=\"el-icon-user\"></i> 个人信息\r\n            </el-dropdown-item>\r\n            <el-dropdown-item @click.native=\"logout\">\r\n              <i class=\"el-icon-switch-button\"></i> 退出登录\r\n            </el-dropdown-item>\r\n          </el-dropdown-menu>\r\n        </el-dropdown>\r\n      </div>\r\n    </div>\r\n\r\n    <!--  主体  -->\r\n    <div class=\"layout-main\">\r\n      <!--  侧边栏  -->\r\n      <div class=\"layout-main-left\">\r\n        <el-menu\r\n          :default-openeds=\"['info', 'textbook']\"\r\n          router\r\n          :default-active=\"$route.path\"\r\n          background-color=\"#304156\"\r\n          text-color=\"#bfcbd9\"\r\n          active-text-color=\"#409EFF\"\r\n          unique-opened\r\n        >\r\n          <el-menu-item index=\"/home\" class=\"menu-item\">\r\n            <i class=\"el-icon-s-home menu-icon\"></i>\r\n            <span slot=\"title\">系统首页</span>\r\n          </el-menu-item>\r\n          \r\n          <el-submenu index=\"info\" class=\"submenu\">\r\n            <template slot=\"title\">\r\n              <i class=\"el-icon-user menu-icon\"></i>\r\n              <span>个人信息</span>\r\n            </template>\r\n            <el-menu-item index=\"/person\" class=\"menu-item\">\r\n              <i class=\"el-icon-user-solid menu-icon\"></i>\r\n              <span>个人中心</span>\r\n            </el-menu-item>\r\n          </el-submenu>\r\n        </el-menu>\r\n      </div>\r\n\r\n      <!--  内容区  -->\r\n      <div class=\"layout-main-right\">\r\n        <router-view class=\"router-view\"></router-view>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Layout\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(localStorage.getItem(\"textbook-user\") || \"{}\")\r\n    };\r\n  },\r\n  methods: {\r\n    // 全屏切换\r\n    toggleFullScreen() {\r\n      if (!document.fullscreenElement) {\r\n        document.documentElement.requestFullscreen();\r\n      } else {\r\n        if (document.exitFullscreen) {\r\n          document.exitFullscreen();\r\n        }\r\n      }\r\n    },\r\n    // 刷新页面\r\n    refreshPage() {\r\n      location.reload();\r\n    },\r\n    // 退出登录\r\n    logout() {\r\n      this.$confirm('确定退出登录吗?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        // 清除用户信息\r\n        localStorage.removeItem(\"textbook-user\");\r\n        // 跳转到登录页\r\n        this.$router.push(\"/login\");\r\n        this.$message({\r\n          type: 'success',\r\n          message: '退出成功!'\r\n        });\r\n      }).catch(() => {});\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.layout-container {\r\n  display: flex;\r\n  flex-direction: column;\r\n  height: 100vh;\r\n  overflow: hidden;\r\n}\r\n\r\n.layout-header {\r\n  height: 60px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 0 15px;\r\n  background-color: #fff;\r\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\r\n}\r\n\r\n.layout-header-left {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo-image {\r\n  width: 40px;\r\n  height: 40px;\r\n  margin-right: 10px;\r\n}\r\n\r\n.title {\r\n  font-size: 18px;\r\n  font-weight: bold;\r\n  color: #303133;\r\n}\r\n\r\n.layout-header-right {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.header-icon-group {\r\n  display: flex;\r\n  margin-right: 20px;\r\n}\r\n\r\n.header-icon {\r\n  font-size: 20px;\r\n  color: #606266;\r\n  margin-right: 15px;\r\n  cursor: pointer;\r\n}\r\n\r\n.avatar {\r\n  display: flex;\r\n  align-items: center;\r\n  cursor: pointer;\r\n}\r\n\r\n.avatar img {\r\n  width: 30px;\r\n  height: 30px;\r\n  border-radius: 50%;\r\n  margin-right: 8px;\r\n}\r\n\r\n.avatar-arrow {\r\n  font-size: 12px;\r\n  margin-left: 5px;\r\n  color: #909399;\r\n}\r\n\r\n.layout-main {\r\n  flex: 1;\r\n  display: flex;\r\n  overflow: hidden;\r\n}\r\n\r\n.layout-main-left {\r\n  width: 220px;\r\n  height: 100%;\r\n  background-color: #304156;\r\n  overflow-y: auto;\r\n}\r\n\r\n.layout-main-right {\r\n  flex: 1;\r\n  padding: 15px;\r\n  overflow-y: auto;\r\n  background-color: #f0f2f5;\r\n}\r\n\r\n.router-view {\r\n  background-color: #fff;\r\n  border-radius: 4px;\r\n  padding: 20px;\r\n  box-shadow: 0 1px 4px rgba(0, 21, 41, 0.08);\r\n  min-height: calc(100% - 30px);\r\n}\r\n\r\n.menu-item {\r\n  height: 50px;\r\n  line-height: 50px;\r\n}\r\n\r\n.menu-icon {\r\n  margin-right: 5px;\r\n}\r\n\r\n.submenu {\r\n  background-color: #304156 !important;\r\n}\r\n</style> "]}]}