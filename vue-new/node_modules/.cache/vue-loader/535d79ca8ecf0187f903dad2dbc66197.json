{"remainingRequest":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\src\\views\\nurse\\Home.vue?vue&type=style&index=0&id=5da2c5cb&scoped=true&lang=css","dependencies":[{"path":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\src\\views\\nurse\\Home.vue","mtime":1754890715996},{"path":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\node_modules\\css-loader\\dist\\cjs.js","mtime":1753409944823},{"path":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1753409923452},{"path":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\node_modules\\postcss-loader\\src\\index.js","mtime":1753409944465},{"path":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1753409945612},{"path":"D:\\bishe\\springboot+vue网站\\毕设-智慧养老\\xm-association-manager\\vue-new\\node_modules\\vue-loader\\lib\\index.js","mtime":1753409923280}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Home.vue"],"names":[],"mappings":";AAmNA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"Home.vue","sourceRoot":"src/views/nurse","sourcesContent":["<template>\r\n  <div class=\"home-container\">\r\n    <div class=\"welcome-section\">\r\n      <div class=\"welcome-title\">\r\n        <i class=\"el-icon-s-home\"></i> 欢迎使用智慧养老护理管理系统\r\n      </div>\r\n      <div class=\"welcome-desc\">为老人提供专业、贴心的护理服务</div>\r\n    </div>\r\n    \r\n    <el-row :gutter=\"20\" class=\"stats-section\">\r\n      <el-col :span=\"8\">\r\n        <el-card shadow=\"hover\" class=\"stats-card\">\r\n          <div class=\"stats-icon care\">\r\n            <i class=\"el-icon-s-help\"></i>\r\n          </div>\r\n          <div class=\"stats-info\">\r\n            <div class=\"stats-title\">今日护理</div>\r\n            <div class=\"stats-value\">8</div>\r\n            <div class=\"stats-desc\">需要完成的护理任务</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"8\">\r\n        <el-card shadow=\"hover\" class=\"stats-card\">\r\n          <div class=\"stats-icon health\">\r\n            <i class=\"el-icon-view\"></i>\r\n          </div>\r\n          <div class=\"stats-info\">\r\n            <div class=\"stats-title\">健康监控</div>\r\n            <div class=\"stats-value\">24</div>\r\n            <div class=\"stats-desc\">负责的老人健康监控</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      <el-col :span=\"8\">\r\n        <el-card shadow=\"hover\" class=\"stats-card\">\r\n          <div class=\"stats-icon completed\">\r\n            <i class=\"el-icon-circle-check\"></i>\r\n          </div>\r\n          <div class=\"stats-info\">\r\n            <div class=\"stats-title\">已完成</div>\r\n            <div class=\"stats-value\">156</div>\r\n            <div class=\"stats-desc\">本月完成的护理记录</div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n    \r\n    <el-row :gutter=\"20\" class=\"content-section\">\r\n      <el-col :span=\"16\">\r\n        <el-card class=\"pending-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"pending-header\">\r\n            <span>今日护理安排</span>\r\n            <el-button type=\"text\" @click=\"$router.push('/nurse/care-assignment')\">查看全部</el-button>\r\n          </div>\r\n          <div v-if=\"todayTasks.length > 0\">\r\n            <el-table :data=\"todayTasks\" style=\"width: 100%\">\r\n              <el-table-column prop=\"elderName\" label=\"老人姓名\" width=\"120\"></el-table-column>\r\n              <el-table-column prop=\"careType\" label=\"护理类型\" width=\"140\"></el-table-column>\r\n              <el-table-column prop=\"timeSlot\" label=\"时间段\" width=\"140\"></el-table-column>\r\n              <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\r\n                <template slot-scope=\"scope\">\r\n                  <el-tag v-if=\"scope.row.status === 'pending'\" type=\"warning\" size=\"small\">待完成</el-tag>\r\n                  <el-tag v-else-if=\"scope.row.status === 'in-progress'\" type=\"primary\" size=\"small\">进行中</el-tag>\r\n                  <el-tag v-else type=\"success\" size=\"small\">已完成</el-tag>\r\n                </template>\r\n              </el-table-column>\r\n              <el-table-column label=\"操作\" width=\"120\">\r\n                <template slot-scope=\"scope\">\r\n                  <el-button v-if=\"scope.row.status !== 'completed'\" type=\"primary\" size=\"mini\" @click=\"handleCare(scope.row)\">开始护理</el-button>\r\n                  <el-button v-else type=\"info\" size=\"mini\" disabled>已完成</el-button>\r\n                </template>\r\n              </el-table-column>\r\n            </el-table>\r\n          </div>\r\n          <div v-else class=\"empty-data\">\r\n            <i class=\"el-icon-s-order\"></i>\r\n            <p>今日无护理安排</p>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n      \r\n      <el-col :span=\"8\">\r\n        <el-card class=\"notice-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"notice-header\">\r\n            <span>健康提醒</span>\r\n            <el-button type=\"text\" @click=\"$router.push('/nurse/health-reminder')\">更多</el-button>\r\n          </div>\r\n          <div v-if=\"healthReminders.length > 0\">\r\n            <div v-for=\"(item, index) in healthReminders\" :key=\"index\" class=\"notice-item\">\r\n              <div class=\"notice-title\">{{ item.title }}</div>\r\n              <div class=\"notice-time\">{{ item.time }}</div>\r\n              <el-tag v-if=\"item.priority === 'high'\" type=\"danger\" size=\"mini\" style=\"margin-top: 5px;\">紧急</el-tag>\r\n            </div>\r\n          </div>\r\n          <div v-else class=\"empty-data\">\r\n            <i class=\"el-icon-info\"></i>\r\n            <p>暂无健康提醒</p>\r\n          </div>\r\n        </el-card>\r\n        \r\n        <el-card class=\"shortcut-card\" shadow=\"hover\">\r\n          <div slot=\"header\" class=\"shortcut-header\">\r\n            <span>快捷入口</span>\r\n          </div>\r\n          <div class=\"shortcut-buttons\">\r\n            <el-button type=\"primary\" icon=\"el-icon-s-help\" @click=\"$router.push('/nurse/care-record')\">护理记录</el-button>\r\n            <el-button type=\"success\" icon=\"el-icon-view\" @click=\"$router.push('/nurse/health-monitoring')\">健康监控</el-button>\r\n            <el-button type=\"info\" icon=\"el-icon-sugar\" @click=\"$router.push('/nurse/user-medication')\">药物管理</el-button>\r\n            <el-button type=\"warning\" icon=\"el-icon-user\" @click=\"$router.push('/nurse/person')\">个人中心</el-button>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n    \r\n    <el-dialog\r\n      title=\"护理记录\"\r\n      :visible.sync=\"careDialogVisible\"\r\n      width=\"60%\">\r\n      <div v-if=\"currentTask\">\r\n        <p><strong>老人姓名：</strong>{{ currentTask.elderName }}</p>\r\n        <p><strong>护理类型：</strong>{{ currentTask.careType }}</p>\r\n        <p><strong>时间段：</strong>{{ currentTask.timeSlot }}</p>\r\n        \r\n        <el-form :model=\"careForm\" label-width=\"100px\" class=\"care-form\">\r\n          <el-form-item label=\"护理内容\">\r\n            <el-input type=\"textarea\" v-model=\"careForm.content\" rows=\"4\" placeholder=\"请详细描述护理过程和内容\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item label=\"血压\">\r\n            <el-input v-model=\"careForm.bloodPressure\" placeholder=\"例：120/80mmHg\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item label=\"心率\">\r\n            <el-input v-model=\"careForm.heartRate\" placeholder=\"例：72次/分\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item label=\"体温\">\r\n            <el-input v-model=\"careForm.temperature\" placeholder=\"例：36.5℃\"></el-input>\r\n          </el-form-item>\r\n          <el-form-item label=\"情绪状态\">\r\n            <el-select v-model=\"careForm.moodStatus\" placeholder=\"请选择\">\r\n              <el-option label=\"良好\" value=\"GOOD\"></el-option>\r\n              <el-option label=\"一般\" value=\"NORMAL\"></el-option>\r\n              <el-option label=\"较差\" value=\"POOR\"></el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n          <el-form-item label=\"异常情况\">\r\n            <el-input type=\"textarea\" v-model=\"careForm.abnormalSituation\" rows=\"3\" placeholder=\"如有异常情况请详细记录\"></el-input>\r\n          </el-form-item>\r\n        </el-form>\r\n      </div>\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"careDialogVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"submitCareRecord\">完成护理</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"NurseHome\",\r\n  data() {\r\n    return {\r\n      todayTasks: [\r\n        { id: 1, elderName: '张奶奶', careType: '日常护理', timeSlot: '08:00-09:00', status: 'pending' },\r\n        { id: 2, elderName: '李爷爷', careType: '用药护理', timeSlot: '09:30-10:00', status: 'pending' },\r\n        { id: 3, elderName: '王奶奶', careType: '康复护理', timeSlot: '10:30-11:30', status: 'in-progress' },\r\n        { id: 4, elderName: '赵爷爷', careType: '体检护理', timeSlot: '14:00-15:00', status: 'completed' }\r\n      ],\r\n      healthReminders: [\r\n        { title: '张奶奶血压异常，需要关注', time: '刚刚', priority: 'high' },\r\n        { title: '李爷爷今日需要服药提醒', time: '30分钟前', priority: 'normal' },\r\n        { title: '王奶奶康复训练时间到', time: '1小时前', priority: 'normal' },\r\n        { title: '赵爷爷体检报告已出', time: '2小时前', priority: 'normal' }\r\n      ],\r\n      careDialogVisible: false,\r\n      currentTask: null,\r\n      careForm: {\r\n        content: '',\r\n        bloodPressure: '',\r\n        heartRate: '',\r\n        temperature: '',\r\n        moodStatus: 'GOOD',\r\n        abnormalSituation: ''\r\n      }\r\n    };\r\n  },\r\n  methods: {\r\n    handleCare(row) {\r\n      this.currentTask = row;\r\n      this.careForm = {\r\n        content: '',\r\n        bloodPressure: '',\r\n        heartRate: '',\r\n        temperature: '',\r\n        moodStatus: 'GOOD',\r\n        abnormalSituation: ''\r\n      };\r\n      this.careDialogVisible = true;\r\n    },\r\n    submitCareRecord() {\r\n      // 调用护理记录API\r\n      this.$message.success('护理记录提交成功');\r\n      // 更新任务状态\r\n      this.currentTask.status = 'completed';\r\n      this.careDialogVisible = false;\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n.home-container {\r\n  padding: 10px;\r\n}\r\n\r\n.welcome-section {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.welcome-title {\r\n  font-size: 22px;\r\n  font-weight: bold;\r\n  color: #303133;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.welcome-desc {\r\n  font-size: 14px;\r\n  color: #606266;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.stats-section {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.stats-card {\r\n  display: flex;\r\n  height: 100px;\r\n  overflow: hidden;\r\n}\r\n\r\n.stats-icon {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 80px;\r\n  font-size: 36px;\r\n  color: #fff;\r\n}\r\n\r\n.care {\r\n  background-color: #409EFF;\r\n}\r\n\r\n.health {\r\n  background-color: #67C23A;\r\n}\r\n\r\n.completed {\r\n  background-color: #E6A23C;\r\n}\r\n\r\n.stats-info {\r\n  flex: 1;\r\n  padding: 15px;\r\n}\r\n\r\n.stats-title {\r\n  font-size: 14px;\r\n  color: #909399;\r\n}\r\n\r\n.stats-value {\r\n  font-size: 24px;\r\n  font-weight: bold;\r\n  margin: 5px 0;\r\n}\r\n\r\n.stats-desc {\r\n  font-size: 12px;\r\n  color: #C0C4CC;\r\n}\r\n\r\n.content-section {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pending-header, .notice-header, .shortcut-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.notice-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.notice-item {\r\n  padding: 10px 0;\r\n  border-bottom: 1px solid #EBEEF5;\r\n}\r\n\r\n.notice-title {\r\n  font-size: 14px;\r\n  margin-bottom: 5px;\r\n  white-space: nowrap;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n}\r\n\r\n.notice-time {\r\n  font-size: 12px;\r\n  color: #909399;\r\n}\r\n\r\n.shortcut-buttons {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.shortcut-buttons .el-button {\r\n  width: 100%;\r\n  margin: 0;\r\n}\r\n\r\n.empty-data {\r\n  padding: 30px 0;\r\n  text-align: center;\r\n  color: #909399;\r\n}\r\n\r\n.empty-data i {\r\n  font-size: 40px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.care-form {\r\n  margin-top: 20px;\r\n}\r\n</style>\r\n"]}]}